// Özellikler
const features = [
  {
    icon: "🔄",
    title: "Otomatik Senkronizasyon",
    description: "Tüm platformlarda ürün, stok ve fiyat senkronizasyonu",
    details: [
      "Gerçek zamanlı stok güncelleme",
      "Otomatik fiyat güncelleme",
      "Ürün bilgisi senkronizasyonu",
      "Toplu güncelleme özelliği"
    ]
  },
  {
    icon: "📦",
    title: "Sipariş Yönetimi",
    description: "Tüm siparişlerinizi tek panelden yönetin",
    details: [
      "Çoklu platform sipariş takibi",
      "Otomatik sipariş aktarımı",
      "Kargo entegrasyonu",
      "Fatura otomasyonu"
    ]
  },
  {
    icon: "📊",
    title: "Analiz ve Raporlama",
    description: "Tüm satış kanallarınızın performansını tek yerden takip edin",
    details: [
      "Platform bazlı satış raporları",
      "Kar marjı analizi",
      "En çok satan ürünler",
      "Müşteri davranış analizi"
    ]
  },
  {
    icon: "🤖",
    title: "Akıllı Stok Yönetimi",
    description: "Çoklu platform stok optimizasyonu",
    details: [
      "Otomatik stok alarmları",
      "Çapraz stok yönetimi",
      "Minimum stok seviyesi",
      "Stok devir hızı analizi"
    ]
  },
  {
    icon: "💳",
    title: "Ödeme ve Fatura",
    description: "Tüm ödeme ve fatura işlemlerini otomatikleştirin",
    details: [
      "Çoklu ödeme sistemi entegrasyonu",
      "Otomatik fatura kesme",
      "Vergi hesaplama",
      "Müşteri ödeme takibi"
    ]
  },
  {
    icon: "🚚",
    title: "Kargo Entegrasyonu",
    description: "Tüm kargo firmalarıyla entegre çözüm",
    details: [
      "Çoklu kargo firması entegrasyonu",
      "Otomatik kargo etiketi",
      "Takip numarası yönetimi",
      "Kargo maliyet analizi"
    ]
  }
];

// İstatistikler
const statistics = [
  { number: "%70", label: "Zaman Tasarrufu", icon: "⏱️" },
  { number: "%60", label: "Hata Azalması", icon: "✅" },
  { number: "%45", label: "Satış Artışı", icon: "📈" },
  { number: "24/7", label: "Senkronizasyon", icon: "🔄" }
];

// Entegrasyon süreci
const integrationProcess = [
  {
    step: 1,
    title: "Platform Seçimi",
    description: "Entegre etmek istediğiniz platformları seçin",
    icon: "🎯"
  },
  {
    step: 2,
    title: "API Bağlantısı",
    description: "Platform API'larını sistemimize bağlayalım",
    icon: "🔗"
  },
  {
    step: 3,
    title: "Test Süreci",
    description: "Entegrasyonu test edin ve onaylayın",
    icon: "🧪"
  },
  {
    step: 4,
    title: "Canlıya Geçiş",
    description: "Sisteminizi canlı ortama taşıyalım",
    icon: "🚀"
  },
  {
    step: 5,
    title: "Eğitim ve Destek",
    description: "Ekibinize sistem eğitimi verelim",
    icon: "👨‍🏫"
  }
];

// Başarı hikayeleri
const successStories = [
  {
    company: "Giyim Perakende",
    platforms: ["Trendyol", "Hepsiburada", "n11"],
    results: [
      "Günlük sipariş işleme süresi %80 azaldı",
      "Stok hataları tamamen ortadan kalktı",
      "Aylık satışlar %65 arttı"
    ],
    quote: "Artık 3 farklı platformdaki 500+ ürünümü tek ekrandan yönetebiliyorum."
  },
  {
    company: "Elektronik Toptan",
    platforms: ["Amazon", "Shopify", "Trendyol"],
    results: [
      "Manuel veri girişi tamamen bitti",
      "Sipariş işleme hızı 5 kat arttı",
      "Müşteri memnuniyeti %40 yükseldi"
    ],
    quote: "Global satışlarımızı tek sistemden yönetmek işimizi inanılmaz kolaylaştırdı."
  }
];

// İç linkler
const relatedPages = [
  { title: "Stok Yönetimi", url: "/stok-yonetimi", desc: "E-ticaret stok optimizasyonu" },
  { title: "Satış Yönetimi", url: "/satis-yonetimi", desc: "Çoklu kanal satış yönetimi" },
  { title: "Müşteri Hizmetleri", url: "/musteri-hizmetleri", desc: "E-ticaret desteği" },
  { title: "ERP Sistemi", url: "/erp-sistemi", desc: "Entegre iş yönetimi" }
];
---

<BaseLayout 
  title="E-Ticaret Entegrasyonu | Stok Pratik - Çoklu Platform Yönetimi" 
  description="E-ticaret entegrasyonu ile Trendyol, Hepsiburada, n11, Amazon ve diğer tüm platformlardaki işlemlerinizi tek sistemden yönetin. Otomatik senkronizasyon, sipariş yönetimi ve stok kontrolü ile e-ticaret işinizi kolaylaştırın."
>
  
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <span class="hero-badge">E-Ticaret Çözümü</span>
          <h1>E-Ticaret Entegrasyonu ile <span class="highlight">Tüm Platformlarınızı Tek Elden Yönetin</span></h1>
          <p class="hero-subtitle hero-badge highlight">Trendyol, Hepsiburada, n11, Amazon ve diğer tüm e-ticaret platformlarını tek sistemde birleştirin</p>
          
          
          
          <div class="hero-buttons">
            <a 
              href="https://wa.me/+905325000999?text=Merhaba,%20E-Ticaret%20Entegrasyonu%20demo%20talep%20ediyorum" 
              class="btn btn-secondary btn-large"
              target="_blank"
              rel="noopener noreferrer"
            >
              🛒 Ücretsiz Demo İste
            </a>
            <a 
              href="tel:+905325000999" 
              class="btn btn-secondary btn-large"
            >
              📞 E-Ticaret Danışmanı
            </a>
          </div>
          
          <div class="platform-tags">
            <div class="platform-tag">
              <span class="platform-icon">🛍️</span>
              <span>Trendyol</span>
            </div>
            <div class="platform-tag">
              <span class="platform-icon">📦</span>
              <span>Hepsiburada</span>
            </div>
            <div class="platform-tag">
              <span class="platform-icon">🏪</span>
              <span>n11</span>
            </div>
            <div class="platform-tag">
              <span class="platform-icon">📚</span>
              <span>Amazon</span>
            </div>
            <div class="platform-tag">
              <span class="platform-icon">🛒</span>
              <span>Shopify</span>
            </div>
          </div>
        </div>
        
        <div class="hero-image">
          <div class="ecommerce-dashboard">
            <div class="dashboard-header">
              <div class="dashboard-title">
                <span class="title-icon">📊</span>
                <span>E-Ticaret Yönetim Paneli</span>
              </div>
              <div class="dashboard-refresh">
                <span class="refresh-icon">🔄</span>
                <span class="refresh-text">Son Güncelleme: 2 dk önce</span>
              </div>
            </div>
            
            <div class="platform-stats">
              <div class="platform-stat">
                <div class="platform-name">🛍️ Trendyol</div>
                <div class="platform-orders">12 Sipariş</div>
                <div class="platform-sales">₺8,450</div>
              </div>
              <div class="platform-stat">
                <div class="platform-name">📦 Hepsiburada</div>
                <div class="platform-orders">8 Sipariş</div>
                <div class="platform-sales">₺5,200</div>
              </div>
              <div class="platform-stat">
                <div class="platform-name">🏪 n11</div>
                <div class="platform-orders">6 Sipariş</div>
                <div class="platform-sales">₺3,800</div>
              </div>
            </div>
            
            <div class="order-overview">
              <div class="section-title">📦 Bugünkü Siparişler</div>
              <div class="order-list">
                <div class="order-item">
                  <div class="order-platform">🛍️ Trendyol</div>
                  <div class="order-id">#7892</div>
                  <div class="order-amount">₺450</div>
                  <div class="order-status shipped">Kargoda</div>
                </div>
                <div class="order-item">
                  <div class="order-platform">📦 Hepsiburada</div>
                  <div class="order-id">#7891</div>
                  <div class="order-amount">₺680</div>
                  <div class="order-status pending">Hazırlanıyor</div>
                </div>
                <div class="order-item">
                  <div class="order-platform">🏪 n11</div>
                  <div class="order-id">#7890</div>
                  <div class="order-amount">₺320</div>
                  <div class="order-status new">Yeni</div>
                </div>
              </div>
            </div>
            
            <div class="stock-alert">
              <div class="alert-icon">⚠️</div>
              <div class="alert-text">Trendyol'da 3 üründe stok kritik seviyede</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Platformlar -->
  <section class="platforms-section">
    <div class="container">
      <div class="section-header">
        <h2>Desteklediğimiz E-Ticaret Platformları</h2>
        <p>Tüm popüler e-ticaret platformlarıyla tam entegrasyon</p>
      </div>
      
      <div class="platforms-grid">
        {ecommercePlatforms.map((platform, index) => (
          <div class="platform-card" key={index}>
            <div class="platform-header">
              <div class="platform-icon">{platform.icon}</div>
              <h3>{platform.name}</h3>
            </div>
            
            <div class="platform-features">
              <h4>Entegrasyon Özellikleri:</h4>
              <ul>
                {platform.features.map((feature, i) => (
                  <li key={i}>
                    <span class="feature-icon">✓</span>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
            
            <div class="platform-stats">
              <div class="stat">
                <div class="stat-label">Kurulum Süresi</div>
                <div class="stat-value">{platform.integrationTime}</div>
              </div>
              <div class="stat">
                <div class="stat-label">Memnuniyet Oranı</div>
                <div class="stat-value success">{platform.satisfaction}</div>
              </div>
            </div>
            
            <a 
              href={`https://wa.me/+905325000999?text=Merhaba,%20${encodeURIComponent(platform.name)}%20entegrasyonu%20hakkında%20bilgi%20almak%20istiyorum`}
              class="btn btn-platform"
              target="_blank"
              rel="noopener noreferrer"
            >
              🔗 Bu Platform İçin Entegrasyon İste
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Problem Çözüm -->
  <section class="problem-section">
    <div class="container">
      <div class="section-header">
        <h2>E-Ticaret Yönetim Zorluklarını Çözüyoruz</h2>
        <p>Çoklu platform yönetiminin zorluklarına akıllı çözümler</p>
      </div>
      
      <div class="problem-grid">
        <div class="problem-card">
          <div class="problem-icon">😫</div>
          <h3>Manuel Veri Girişi</h3>
          <p>Her platforma ayrı ayrı ürün ve stok güncelleme</p>
          <ul>
            <li>Zaman kaybı ve hata riski</li>
            <li>Stok tutarsızlıkları</li>
            <li>Fiyat güncelleme zorluğu</li>
          </ul>
        </div>
        
        <div class="solution-card">
          <div class="solution-icon">✅</div>
          <h3>Otomatik Senkronizasyon</h3>
          <p class=" hero-badge highlight">Tüm platformlara otomatik veri aktarımı</p>
          <ul>
            <li>Tek tıkla tüm platform güncelleme</li>
            <li>Gerçek zamanlı stok senkronizasyonu</li>
            <li>Otomatik fiyat güncelleme</li>
          </ul>
        </div>
        
        <div class="problem-card">
          <div class="problem-icon">📉</div>
          <h3>Dağınık Sipariş Takibi</h3>
          <p>Farklı platformlardaki siparişleri takip zorluğu</p>
          <ul>
            <li>Sipariş kaçırma riski</li>
            <li>Kargo takibi karmaşası</li>
            <li>Müşteri iletişim sorunları</li>
          </ul>
        </div>
        
        <div class="solution-card">
          <div class="solution-icon">📦</div>
          <h3>Merkezi Sipariş Yönetimi</h3>
          <p class=" hero-badge highlight">Tüm platform siparişlerini tek ekranda takip</p>
          <ul>
            <li>Tüm siparişler tek panelde</li>
            <li>Otomatik kargo entegrasyonu</li>
            <li>Müşteri iletişim merkezi</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Özellikler -->
  <section class="features-section">
    <div class="container">
      <div class="section-header">
        <h2>Stok Pratik E-Ticaret Entegrasyonu Özellikleri</h2>
        <p>Çoklu platform yönetimi için ihtiyacınız olan tüm araçlar</p>
      </div>
      
      <div class="features-grid">
        {features.map((feature, index) => (
          <div class="feature-card" key={index}>
            <div class="feature-header">
              <div class="feature-icon">{feature.icon}</div>
              <div>
                <h3>{feature.title}</h3>
                <p class="feature-desc">{feature.description}</p>
              </div>
            </div>
            
            <ul class="feature-details">
              {feature.details.map((detail, i) => (
                <li key={i}>
                  <span class="detail-check">✓</span>
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Entegrasyon Süreci -->
  <section class="process-section">
    <div class="container">
      <div class="section-header">
        <h2>5 Adımda E-Ticaret Entegrasyonu</h2>
        <p>Hızlı ve sorunsuz entegrasyon sürecimiz</p>
      </div>
      
      <div class="process-timeline">
        {integrationProcess.map((step, index) => (
          <div class="process-step" key={index}>
            <div class="step-number">{step.step}</div>
            <div class="step-icon">{step.icon}</div>
            <div class="step-content">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
              <div class="step-duration">
                {index === 0 && "15 Dakika"}
                {index === 1 && "2-24 Saat"}
                {index === 2 && "24 Saat"}
                {index === 3 && "2 Saat"}
                {index === 4 && "2 Saat"}
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <div class="process-result">
        <div class="result-icon">🏆</div>
        <div class="result-content">
          <h3>Stok Pratik ile Tam Entegrasyon!</h3>
          <p class=" hero-badge highlight">Stok Pratik ile e-ticaret platformlarınızı hızlıca entegre edin, işinize odaklanın.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Başarı Hikayeleri -->
  <section class="success-section">
    <div class="container">
      <div class="section-header">
        <h2>E-Ticaret Entegrasyonu ile Büyüyen İşletmeler</h2>
        <p>Stok Pratik ile çoklu platform yönetimini başaran müşterilerimiz</p>
      </div>
      
      <div class="success-stories">
        {successStories.map((story, index) => (
          <div class="story-card" key={index}>
            <div class="story-header">
              <div class="story-company">{story.company}</div>
              <div class="story-platforms">
                {story.platforms.map((platform, i) => (
                  <span class="platform-badge" key={i}>{platform}</span>
                ))}
              </div>
            </div>
            
            <div class="story-results">
              <h4>📈 Elde Edilen Sonuçlar</h4>
              <ul>
                {story.results.map((result, i) => (
                  <li key={i}>
                    <span class="result-icon">🚀</span>
                    {result}
                  </li>
                ))}
              </ul>
            </div>
            
            <div class="story-quote">
              <div class="quote-icon">❝</div>
              <p>{story.quote}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Teknik Özellikler -->
  <section class="technical-section">
    <div class="container">
      <div class="section-header">
        <h2>Teknik Özellikler ve Güvenlik</h2>
        <p>Profesyonel e-ticaret entegrasyonu için güvenli altyapı</p>
      </div>
      
      <div class="technical-grid">
        <div class="technical-card">
          <div class="technical-icon">🔒</div>
          <h3>Güvenlik</h3>
          <ul>
            <li>SSL Şifreleme</li>
            <li>API Güvenlik Duvarı</li>
            <li>Veri Yedekleme</li>
            <li>Rol Tabanlı Erişim</li>
          </ul>
        </div>
        
        <div class="technical-card">
          <div class="technical-icon">⚡</div>
          <h3>Performans</h3>
          <ul>
            <li>99.9% Uptime</li>
            <li>Gerçek Zamanlı Senkronizasyon</li>
            <li>Hızlı API Yanıtları</li>
            <li>Ölçeklenebilir Altyapı</li>
          </ul>
        </div>
        
        <div class="technical-card">
          <div class="technical-icon">🔄</div>
          <h3>Senkronizasyon</h3>
          <ul>
            <li>5 Dakikada Bir Güncelleme</li>
            <li>Çoklu API Desteği</li>
            <li>Hata Yönetimi</li>
            <li>Otomatik Yeniden Deneme</li>
          </ul>
        </div>
        
        <div class="technical-card">
          <div class="technical-icon">📞</div>
          <h3>Destek</h3>
          <ul>
            <li>7/24 Teknik Destek</li>
            <li>API Dokümantasyonu</li>
            <li>Video Eğitimler</li>
            <li>Canlı Yardım</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- İlgili Sayfalar -->
  <section class="related-pages">
    <div class="container">
      <div class="section-header">
        <h2>E-Ticaret Entegrasyonu ile Tamamlayan Sistemler</h2>
        <p>E-ticaret işinizi büyütmek için diğer çözümlerimiz</p>
      </div>
      
      <div class="pages-grid">
        {relatedPages.map((page, index) => (
          <a href={page.url} class="page-card" key={index}>
            <h3>{page.title}</h3>
            <p>{page.desc}</p>
            <div class="page-link">
              <span>İncele</span>
              <span class="arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Son CTA -->
  <section class="final-cta">
    <div class="container">
      <div class="cta-content">
        <div class="cta-icon">🛒</div>
        <h2>E-Ticaret Platformlarınızı Tek Elde Birleştirin!</h2>
        <p>14 gün ücretsiz deneme ile çoklu platform yönetiminin farkını yaşayın.</p>
        
        <div class="cta-buttons">
          <a 
            href="https://wa.me/+905325000999?text=Merhaba,%20E-Ticaret%20Entegrasyonu%20demo%20talep%20ediyorum"
            class="btn btn-primary btn-large"
            target="_blank"
            rel="noopener noreferrer"
          >
            🚀 Ücretsiz Demo Başlat
          </a>
          
          <a 
            href="tel:+905325000999"
            class="btn btn-secondary btn-large"
          >
            📞 E-Ticaret Danışmanı
          </a>
        </div>
        
        <div class="cta-benefits">
          <div class="benefit">
            <span class="benefit-icon">🔧</span>
            <span>Ücretsiz Kurulum</span>
          </div>
          <div class="benefit">
            <span class="benefit-icon">👨‍🏫</span>
            <span>Platform Eğitimi</span>
          </div>
          <div class="benefit">
            <span class="benefit-icon">🔄</span>
            <span>Veri Aktarım Desteği</span>
