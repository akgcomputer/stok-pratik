---
// src/pages/musteri-hizmetleri.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/variables.css';
import '../styles/global.css';
import '../styles/components.css';

// Özellikler
const features = [
  {
    icon: "📞",
    title: "Çoklu İletişim Kanalı",
    description: "Müşterilerinizle her kanaldan iletişim kurun",
    details: [
      "WhatsApp Business entegrasyonu",
      "E-posta yönetimi",
      "Telefon görüşme kayıtları",
      "Canlı destek chat sistemi"
    ]
  },
  {
    icon: "🎯",
    title: "Otomatik Yanıtlama",
    description: "Sık sorulan sorulara otomatik yanıt verin",
    details: [
      "AI destekli chatbot",
      "Soru-cevap veritabanı",
      "Otomatik yönlendirme",
      "7/24 destek sağlama"
    ]
  },
  {
    icon: "📊",
    title: "Performans Analizi",
    description: "Müşteri hizmetleri performansınızı ölçün",
    details: [
      "Çağrı istatistikleri",
      "Memnuniyet anketleri",
      "Çözüm süreleri",
      "Ekip performans raporları"
    ]
  },
  {
    icon: "📋",
    title: "Talep Yönetimi",
    description: "Tüm müşteri taleplerini sistematik yönetin",
    details: [
      "Talep takip sistemi",
      "Öncelik sıralaması",
      "Otomatik atama",
      "SLA (Hizmet Seviyesi Anlaşması) takibi"
    ]
  },
  {
    icon: "🤝",
    title: "Müşteri Deneyimi",
    description: "Müşteri deneyimini kişiselleştirin",
    details: [
      "Müşteri geçmişi görüntüleme",
      "Kişiselleştirilmiş çözümler",
      "Proaktif destek",
      "Sadakat programı yönetimi"
    ]
  },
  {
    icon: "📱",
    title: "Mobil Uygulama",
    description: "Mobil cihazlardan müşteri desteği sağlayın",
    details: [
      "Mobil destek uygulaması",
      "Anında bildirimler",
      "Fotoğraf/video paylaşımı",
      "Konum bazlı destek"
    ]
  }
];

// Destek kanalları
const supportChannels = [
  {
    channel: "WhatsApp Destek",
    icon: "💬",
    features: [
      "Anlık mesajlaşma",
      "Dosya paylaşımı",
      "Otomatik yanıtlar",
      "Çoklu kullanıcı"
    ],
    responseTime: "2 Dakika",
    satisfaction: "%95"
  },
  {
    channel: "Telefon Destek",
    icon: "📞",
    features: [
      "Çağrı kayıtları",
      "Bekleme süresi takibi",
      "IVR (Sesli Yanıt Sistemi)",
      "Çağrı yönlendirme"
    ],
    responseTime: "30 Saniye",
    satisfaction: "%92"
  },
  {
    channel: "E-posta Destek",
    icon: "📧",
    features: [
      "Otomatik yanıtlama",
      "Şablon e-postalar",
      "Dosya ekleri",
      "Takip sistematiği"
    ],
    responseTime: "2 Saat",
    satisfaction: "%90"
  },
  {
    channel: "Canlı Chat",
    icon: "💻",
    features: [
      "Gerçek zamanlı sohbet",
      "Ekran paylaşımı",
      "Co-browsing",
      "Anket ve değerlendirme"
    ],
    responseTime: "1 Dakika",
    satisfaction: "%94"
  }
];

// İstatistikler
const statistics = [
  { number: "%40", label: "Müşteri Memnuniyeti Artışı", icon: "😊" },
  { number: "%50", label: "Yanıt Süresi Azalması", icon: "⚡" },
  { number: "%35", label: "Operasyon Maliyeti Düşüşü", icon: "💰" },
  { number: "7/24", label: "Kesintisiz Destek", icon: "🌙" }
];

// Müşteri hizmetleri metrikleri
const serviceMetrics = [
  {
    metric: "İlk Yanıt Süresi",
    target: "< 5 Dakika",
    importance: "Müşteri sabrı ve memnuniyeti"
  },
  {
    metric: "Çözüm Süresi",
    target: "< 24 Saat",
    importance: "Sorun çözme hızı"
  },
  {
    metric: "Müşteri Memnuniyeti",
    target: "> %90",
    importance: "Hizmet kalitesi"
  },
  {
    metric: "Tekrar Çağrı Oranı",
    target: "< %10",
    importance: "Kalıcı çözümler"
  }
];

// Başarı hikayeleri
const successStories = [
  {
    company: "E-Ticaret Şirketi",
    challenge: "Günlük 500+ müşteri talebi",
    solution: "Otomatik yanıt ve chatbot sistemi",
    results: [
      "Yanıt süresi %60 azaldı",
      "Müşteri memnuniyeti %45 arttı",
      "İnsan kaynağı ihtiyacı %30 düştü"
    ]
  },
  {
    company: "Finans Kurumu",
    challenge: "Karmaşık ürün sorguları",
    solution: "Bilgi bankası ve eğitimli ekip",
    results: [
      "Doğru yanıt oranı %95'e çıktı",
      "Ekip verimliliği %40 arttı",
      "Şikayet oranı %70 azaldı"
    ]
  }
];

// İç linkler
const relatedPages = [
  { title: "CRM Sistemi", url: "/crm", desc: "Müşteri ilişkileri yönetimi" },
  { title: "Satış Yönetimi", url: "/satis-yonetimi", desc: "Satış ve destek entegrasyonu" },
  { title: "ERP Sistemi", url: "/erp-sistemi", desc: "Entegre iş yönetimi" },
  { title: "Proje Yönetimi", url: "/proje-yonetimi", desc: "Destek projeleri takibi" }
];
---

<BaseLayout 
  title="Müşteri Hizmetleri Yönetimi | Stok Pratik - Müşteri Memnuniyeti" 
  description="Müşteri hizmetleri yönetim sistemi ile müşteri memnuniyetinizi artırın. Çoklu iletişim kanalları, otomatik yanıtlama ve performans analizi ile müşteri desteğinizi profesyonelleştirin."
>
  
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <span class="hero-badge">Müşteri Deneyimi Çözümü</span>
          <h1>Müşteri Hizmetleri ile <span class="highlight">Müşteri Memnuniyetinizi Artırın</span></h1>
          <p class="hero-subtitle hero-badge highlight">Çoklu iletişim kanalları, otomatik yanıtlama ve performans analizi ile müşteri desteğinizi profesyonelleştirin</p>
          
          
          
          <div class="hero-buttons">
            <a 
              href="https://wa.me/+905325000999?text=Merhaba,%20Müşteri%20Hizmetleri%20Sistemi%20demo%20talep%20ediyorum" 
              class="btn btn-secondary btn-large"
              target="_blank"
              rel="noopener noreferrer"
            >
              🤝 Ücretsiz Demo İste
            </a>
            <a 
              href="tel:+905325000999" 
              class="btn btn-secondary btn-large"
            >
              📞 Müşteri Hizmetleri Danışmanı
            </a>
          </div>
          
          <div class="support-channels">
            <div class="channel-tag">
              <span class="channel-icon">💬</span>
              <span>WhatsApp Destek</span>
            </div>
            <div class="channel-tag">
              <span class="channel-icon">📞</span>
              <span>Telefon Destek</span>
            </div>
            <div class="channel-tag">
              <span class="channel-icon">📧</span>
              <span>E-posta Destek</span>
            </div>
            <div class="channel-tag">
              <span class="channel-icon">💻</span>
              <span>Canlı Chat</span>
            </div>
          </div>
        </div>
        
        <div class="hero-image">
          <div class="support-dashboard">
            <div class="dashboard-header">
              <div class="dashboard-title">
                <span class="title-icon">📊</span>
                <span>Müşteri Desteği Paneli</span>
              </div>
              <div class="dashboard-status">
                <span class="status-indicator online"></span>
                <span class="status-text">Çevrimiçi</span>
              </div>
            </div>
            
            <div class="active-tickets">
              <div class="section-title">🎫 Aktif Destek Talepleri</div>
              <div class="ticket-list">
                <div class="ticket-item high">
                  <div class="ticket-id">#7892</div>
                  <div class="ticket-subject">Ürün İade Talebi</div>
                  <div class="ticket-time">4 dakika önce</div>
                </div>
                <div class="ticket-item medium">
                  <div class="ticket-id">#7891</div>
                  <div class="ticket-subject">Teknik Destek</div>
                  <div class="ticket-time">12 dakika önce</div>
                </div>
                <div class="ticket-item low">
                  <div class="ticket-id">#7890</div>
                  <div class="ticket-subject">Bilgi Talebi</div>
                  <div class="ticket-time">25 dakika önce</div>
                </div>
              </div>
            </div>
            
            <div class="support-metrics">
              <div class="metric">
                <div class="metric-label">Bugünkü Talepler</div>
                <div class="metric-value">42</div>
              </div>
              <div class="metric">
                <div class="metric-label">Ort. Yanıt Süresi</div>
                <div class="metric-value">3.2 dk</div>
              </div>
              <div class="metric">
                <div class="metric-label">Çözüm Oranı</div>
                <div class="metric-value success">%94</div>
              </div>
            </div>
            
            <div class="live-chat-preview">
              <div class="chat-header">💬 Canlı Sohbet</div>
              <div class="chat-messages">
                <div class="message customer">
                  <div class="message-text">Ürünüm henüz gelmedi, takip edebilir misiniz?</div>
                  <div class="message-time">14:32</div>
                </div>
                <div class="message agent">
                  <div class="message-text">Tabii ki, kargo numaranızı kontrol ediyorum...</div>
                  <div class="message-time">14:33</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Çözüm -->
  <section class="problem-section">
    <div class="container">
      <div class="section-header">
        <h2>Müşteri Hizmetleri Zorluklarını Çözüyoruz</h2>
        <p>İşletmelerin yaşadığı müşteri desteği problemlerine profesyonel çözümler</p>
      </div>
      
      <div class="problem-grid">
        <div class="problem-card">
          <div class="problem-icon">😫</div>
          <h3>Dağınık İletişim</h3>
          <p>Farklı kanallardan gelen mesajların takip zorluğu</p>
          <ul>
            <li>WhatsApp, e-posta, telefon karışıklığı</li>
            <li>Müşteri geçmişi takipsizliği</li>
            <li>Yanıtların gecikmesi</li>
          </ul>
        </div>
        
        <div class="solution-card">
          <div class="solution-icon">✅</div>
          <h3>Merkezi İletişim Paneli</h3>
          <p>Tüm iletişim kanallarını tek platformda birleştirme</p>
          <ul>
            <li>Tüm kanallar tek ekranda</li>
            <li>Tam müşteri geçmişi</li>
            <li>Anlık yanıt ve takip</li>
          </ul>
        </div>
        
        <div class="problem-card">
          <div class="problem-icon">📉</div>
          <h3>Yavaş Yanıt Süreleri</h3>
          <p>Müşteri taleplerine geç yanıt verme sorunu</p>
          <ul>
            <li>Uzun bekleme süreleri</li>
            <li>Müşteri memnuniyetsizliği</li>
            <li>Kayıp satış fırsatları</li>
          </ul>
        </div>
        
        <div class="solution-card">
          <div class="solution-icon">⚡</div>
          <h3>Otomatik Yanıt Sistemi</h3>
          <p>Sık sorulan sorulara anında otomatik yanıt verme</p>
          <ul>
            <li>AI destekli chatbot</li>
            <li>7/24 otomatik destek</li>
            <li>İnsan kaynağı optimizasyonu</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Özellikler -->
  <section class="features-section">
    <div class="container">
      <div class="section-header">
        <h2>Stok Pratik Müşteri Hizmetleri Özellikleri</h2>
        <p>Müşteri memnuniyeti için ihtiyacınız olan tüm araçlar</p>
      </div>
      
      <div class="features-grid">
        {features.map((feature, index) => (
          <div class="feature-card" key={index}>
            <div class="feature-header">
              <div class="feature-icon">{feature.icon}</div>
              <div>
                <h3>{feature.title}</h3>
                <p class="feature-desc">{feature.description}</p>
              </div>
            </div>
            
            <ul class="feature-details">
              {feature.details.map((detail, i) => (
                <li key={i}>
                  <span class="detail-check">✓</span>
                  {detail}
                </li>
              ))}
            </ul>
            
            <div class="feature-cta">
              <a 
                href={`https://wa.me/+905325000999?text=Merhaba,%20${encodeURIComponent(feature.title)}%20özelliği%20hakkında%20bilgi%20almak%20istiyorum`}
                class="btn-feature"
                target="_blank"
                rel="noopener noreferrer"
              >
                Bu Özellik Hakkında Bilgi Al
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Destek Kanalları -->
  <section class="channels-section">
    <div class="container">
      <div class="section-header">
        <h2>Tüm İletişim Kanallarında Mükemmel Destek</h2>
        <p>Müşterilerinizin tercih ettiği her kanalda profesyonel destek sağlayın</p>
      </div>
      
      <div class="channels-grid">
        {supportChannels.map((channel, index) => (
          <div class="channel-card" key={index}>
            <div class="channel-header">
              <div class="channel-icon">{channel.icon}</div>
              <h3>{channel.channel}</h3>
            </div>
            
            <div class="channel-features">
              <h4>Özellikler:</h4>
              <ul>
                {channel.features.map((feature, i) => (
                  <li key={i}>
                    <span class="feature-icon">✨</span>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
            
            <div class="channel-stats">
              <div class="stat">
                <div class="stat-label">Ort. Yanıt Süresi</div>
                <div class="stat-value">{channel.responseTime}</div>
              </div>
              <div class="stat">
                <div class="stat-label">Memnuniyet Oranı</div>
                <div class="stat-value success">{channel.satisfaction}</div>
              </div>
            </div>
            
            <a 
              href={`https://wa.me/+905325000999?text=Merhaba,%20${encodeURIComponent(channel.channel)}%20için%20müşteri%20hizmetleri%20demo%20talep%20ediyorum`}
              class="btn btn-channel"
              target="_blank"
              rel="noopener noreferrer"
            >
              📞 Bu Kanal İçin Demo İste
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Hizmet Metrikleri -->
  <section class="metrics-section">
    <div class="container">
      <div class="section-header">
        <h2>Müşteri Hizmetleri Performans Metrikleri</h2>
        <p>Başarılı müşteri hizmetleri için izlemeniz gereken kritik metrikler</p>
      </div>
      
      <div class="metrics-grid">
        {serviceMetrics.map((metric, index) => (
          <div class="metric-card" key={index}>
            <div class="metric-header">
              <h3>{metric.metric}</h3>
              <div class="metric-target">{metric.target}</div>
            </div>
            <p class="metric-importance">{metric.importance}</p>
            <div class="metric-tools">
              <div class="tool">📊 Raporlama</div>
              <div class="tool">🔔 Uyarı Sistemi</div>
              <div class="tool">📈 Performans Analizi</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Destek Süreci -->
  <section class="process-section">
    <div class="container">
      <div class="section-header">
        <h2>5 Adımda Mükemmel Müşteri Desteği</h2>
        <p>Stok Pratik ile müşteri destek süreçlerinizi standartlaştırın</p>
      </div>
      
      <div class="process-flow">
        <div class="process-step">
          <div class="step-number">1</div>
          <div class="step-content">
            <h3>Talep Alma</h3>
            <p>Müşteri talebini herhangi bir kanaldan alın</p>
            <div class="step-channels">
              <span class="channel">💬 WhatsApp</span>
              <span class="channel">📞 Telefon</span>
              <span class="channel">📧 E-posta</span>
            </div>
          </div>
        </div>
        
        <div class="process-step">
          <div class="step-number">2</div>
          <div class="step-content">
            <h3>Önceliklendirme</h3>
            <p>Talebi aciliyetine göre önceliklendirin</p>
            <div class="step-priorities">
              <span class="priority high">Yüksek</span>
              <span class="priority medium">Orta</span>
              <span class="priority low">Düşük</span>
            </div>
          </div>
        </div>
        
        <div class="process-step">
          <div class="step-number">3</div>
          <div class="step-content">
            <h3>Çözüm Üretme</h3>
            <p>Uygun çözümü bulun ve müşteriye sunun</p>
            <div class="step-solutions">
              <span class="solution">📋 Bilgi Bankası</span>
              <span class="solution">👨‍💻 Uzman Destek</span>
              <span class="solution">🔧 Teknik Çözüm</span>
            </div>
          </div>
        </div>
        
        <div class="process-step">
          <div class="step-number">4</div>
          <div class="step-content">
            <h3>Takip ve İletişim</h3>
            <p>Çözüm sürecini takip edin, müşteriyi bilgilendirin</p>
            <div class="step-tracking">
              <span class="track">⏱️ Süre Takibi</span>
              <span class="track">📞 Geri Bildirim</span>
              <span class="track">✅ Onay Alma</span>
            </div>
          </div>
        </div>
        
        <div class="process-step">
          <div class="step-number">5</div>
          <div class="step-content">
            <h3>Değerlendirme</h3>
            <p>Süreci analiz edin, iyileştirme yapın</p>
            <div class="step-evaluation">
              <span class="eval">📊 Performans Analizi</span>
              <span class="eval">😊 Memnuniyet Anketi</span>
              <span class="eval">🔄 Süreç İyileştirme</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Başarı Hikayeleri -->
  <section class="success-section">
    <div class="container">
      <div class="section-header">
        <h2>Müşteri Hizmetlerinde Başarı Hikayeleri</h2>
        <p>Stok Pratik ile müşteri memnuniyetini artıran işletmeler</p>
      </div>
      
      <div class="success-stories">
        {successStories.map((story, index) => (
          <div class="story-card" key={index}>
            <div class="story-header">
              <div class="story-company">{story.company}</div>
              <div class="story-challenge">
                <strong>Zorluk:</strong> {story.challenge}
              </div>
            </div>
            
            <div class="story-solution">
              <h4>✨ Çözümümüz</h4>
              <p>{story.solution}</p>
            </div>
            
            <div class="story-results">
              <h4>📈 Elde Edilen Sonuçlar</h4>
              <ul>
                {story.results.map((result, i) => (
                  <li key={i}>
                    <span class="result-icon">✅</span>
                    {result}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Entegrasyonlar -->
  <section class="integrations-section">
    <div class="container">
      <div class="section-header">
        <h2>Mevcut Sistemlerinizle Tam Entegrasyon</h2>
        <p>Müşteri hizmetleri sistemimiz diğer araçlarınızla uyumlu çalışır</p>
      </div>
      
      <div class="integrations-grid">
        <div class="integration-card">
          <div class="integration-icon">📦</div>
          <h4>Stok Yönetimi</h4>
          <p>Stok bilgileri anlık erişim</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">💰</div>
          <h4>Muhasebe Sistemi</h4>
          <p>Fatura ve ödeme bilgileri</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">📊</div>
          <h4>CRM Sistemi</h4>
          <p>Müşteri verileri senkronizasyonu</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">🛒</div>
          <h4>E-Ticaret</h4>
          <p>Sipariş ve kargo takibi</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">📅</div>
          <h4>Takvim Sistemleri</h4>
          <p>Randevu ve takip planlaması</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">🤖</div>
          <h4>AI Asistanlar</h4>
          <p>Yapay zeka destekli çözümler</p>
        </div>
      </div>
    </div>
  </section>

  <!-- İlgili Sayfalar -->
  <section class="related-pages">
    <div class="container">
      <div class="section-header">
        <h2>Müşteri Hizmetleri ile Entegre Çalışan Sistemler</h2>
        <p>Müşteri deneyiminizi tamamlayan diğer çözümlerimiz</p>
      </div>
      
      <div class="pages-grid">
        {relatedPages.map((page, index) => (
          <a href={page.url} class="page-card" key={index}>
