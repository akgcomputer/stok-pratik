      "API entegrasyonu",
      "Ürün yönetimi",
      "Fiyat güncelleme",
      "Mağaza performansı"
    ],
    integrationTime: "48 Saat",
    satisfaction: "%96"
  },
  {
    name: "n11",
    icon: "🏪",
    features: [
      "Ürün aktarımı",
      "Sipariş yönetimi",
      "Müşteri yorumları",
      "Kampanya yönetimi"
    ],
    integrationTime: "24 Saat",
    satisfaction: "%97"
  },
  {
    name: "Amazon",
    icon: "📚",
