  {
    metric: "İlk Çözüm Oranı",
    title: "İlk Müdahalede Çözülen Arızalar",
    target: "> %85",
    impact: "Müşteri memnuniyeti artar, maliyetler düşer"
  },
  {
    metric: "Ortalama Müdahale Süresi",
