---
// src/pages/mobil-saha-uygulamasi.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Mobil Saha Uygulaması - Stok Pratik ERP">
  <!-- Hero Section -->
  <section class="hero-section py-16 bg-gradient-to-br from-primary-red-light to-bg-white">
    <div class="container">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-5xl font-bold mb-6 bg-gradient-to-r from-primary-red to-primary-red-dark bg-clip-text text-transparent">
          Mobil Saha Uygulaması
        </h1>
        <p class="text-xl text-text-gray mb-8">
          Satış ekibiniz için güçlü mobil çözüm. Saha satış temsilcilerinizin ihtiyaç duyduğu tüm araçlar cebinizde.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a 
            href="https://wa.me/+905325000999?text=Merhaba,%20Mobil%20Saha%20Uygulaması%20demo%20talep%20ediyorum" 
            class="btn btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="mr-2">📱</span>
            Demo Talep Et
          </a>
          <a 
            href="#ozellikler" 
            class="btn btn-secondary"
          >
            Özellikleri Keşfet
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Özellikler -->
  <section id="ozellikler" class="features-section py-16 bg-bg-light">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4">Mobil Saha Uygulaması Özellikleri</h2>
        <p class="text-text-gray max-w-2xl mx-auto">
          Saha satış ekibinizin verimliliğini artıracak kapsamlı özellikler
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Özellik 1 -->
        <div class="feature-card bg-white p-6 rounded-lg shadow-md">
          <div class="feature-icon mb-4 text-primary-red text-3xl">
            🛒
          </div>
          <h3 class="text-xl font-semibold mb-3">Sipariş Yönetimi</h3>
          <ul class="space-y-2 text-text-gray">
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Mobil sipariş oluşturma</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Çevrimdışı çalışma</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Otomatik senkronizasyon</span>
            </li>
          </ul>
        </div>

        <!-- Özellik 2 -->
        <div class="feature-card bg-white p-6 rounded-lg shadow-md">
          <div class="feature-icon mb-4 text-primary-red text-3xl">
            👥
          </div>
          <h3 class="text-xl font-semibold mb-3">Müşteri Yönetimi</h3>
          <ul class="space-y-2 text-text-gray">
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Müşteri kartlarına mobil erişim</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Yeni müşteri kaydı</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Satış geçmişi görüntüleme</span>
            </li>
          </ul>
        </div>

        <!-- Özellik 3 -->
        <div class="feature-card bg-white p-6 rounded-lg shadow-md">
          <div class="feature-icon mb-4 text-primary-red text-3xl">
            📊
          </div>
          <h3 class="text-xl font-semibold mb-3">Raporlama & Analiz</h3>
          <ul class="space-y-2 text-text-gray">
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Anlık satış raporları</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Performans takibi</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Hedef takip sistemi</span>
            </li>
          </ul>
        </div>

        <!-- Özellik 4 -->
        <div class="feature-card bg-white p-6 rounded-lg shadow-md">
          <div class="feature-icon mb-4 text-primary-red text-3xl">
            🗺️
          </div>
          <h3 class="text-xl font-semibold mb-3">Saha Takibi</h3>
          <ul class="space-y-2 text-text-gray">
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>GPS tabanlı ziyaret takibi</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Rota optimizasyonu</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Ziyaret notları ve fotoğraf ekleme</span>
            </li>
          </ul>
        </div>

        <!-- Özellik 5 -->
        <div class="feature-card bg-white p-6 rounded-lg shadow-md">
          <div class="feature-icon mb-4 text-primary-red text-3xl">
            📦
          </div>
          <h3 class="text-xl font-semibold mb-3">Stok Kontrolü</h3>
          <ul class="space-y-2 text-text-gray">
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Anlık stok sorgulama</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Stok uyarıları</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Ürün kataloğuna erişim</span>
            </li>
          </ul>
        </div>

        <!-- Özellik 6 -->
        <div class="feature-card bg-white p-6 rounded-lg shadow-md">
          <div class="feature-icon mb-4 text-primary-red text-3xl">
            📄
          </div>
          <h3 class="text-xl font-semibold mb-3">Dokümantasyon</h3>
          <ul class="space-y-2 text-text-gray">
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Mobil fatura kesme</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>İrsaliye düzenleme</span>
            </li>
            <li class="flex items-start">
              <span class="text-green-500 mr-2 mt-1 flex-shrink-0">✓</span>
              <span>Doküman paylaşımı</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Avantajlar -->
  <section class="benefits-section py-16 bg-white">
    <div class="container">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold mb-4">Mobil Saha Uygulamasının Avantajları</h2>
        <p class="text-text-gray max-w-2xl mx-auto">
          İşletmenize ve satış ekibinize sağlayacağı faydalar
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-bg-light p-8 rounded-lg">
          <h3 class="text-2xl font-semibold mb-4 text-primary-red">İşletmeniz İçin</h3>
          <ul class="space-y-4">
            <li class="flex items-start">
              <div class="bg-primary-red text-white p-2 rounded-full mr-4">
                📈
              </div>
              <div>
                <h4 class="font-semibold mb-1">Satış Artışı</h4>
                <p class="text-text-gray">Saha satışlarında %40'a varan artış</p>
              </div>
            </li>
            <li class="flex items-start">
              <div class="bg-primary-red text-white p-2 rounded-full mr-4">
                ⏱️
              </div>
              <div>
                <h4 class="font-semibold mb-1">Zaman Tasarrufu</h4>
                <p class="text-text-gray">İşlem sürelerinde %60 azalma</p>
              </div>
            </li>
            <li class="flex items-start">
              <div class="bg-primary-red text-white p-2 rounded-full mr-4">
                📊
              </div>
              <div>
                <h4 class="font-semibold mb-1">Gerçek Zamanlı Takip</h4>
                <p class="text-text-gray">Anlık satış ve performans takibi</p>
              </div>
            </li>
          </ul>
        </div>

        <div class="bg-bg-light p-8 rounded-lg">
          <h3 class="text-2xl font-semibold mb-4 text-primary-red">Satış Ekibiniz İçin</h3>
          <ul class="space-y-4">
            <li class="flex items-start">
              <div class="bg-primary-red text-white p-2 rounded-full mr-4">
                📱
              </div>
              <div>
                <h4 class="font-semibold mb-1">Mobil Çalışma</h4>
                <p class="text-text-gray">Her yerden, her zaman erişim</p>
              </div>
            </li>
            <li class="flex items-start">
              <div class="bg-primary-red text-white p-2 rounded-full mr-4">
                🔌
              </div>
              <div>
                <h4 class="font-semibold mb-1">Çevrimdışı Mod</h4>
                <p class="text-text-gray">İnternet olmayan ortamlarda çalışma</p>
              </div>
            </li>
            <li class="flex items-start">
              <div class="bg-primary-red text-white p-2 rounded-full mr-4">
                🔄
              </div>
              <div>
                <h4 class="font-semibold mb-1">Kolay Senkronizasyon</h4>
                <p class="text-text-gray">Veriler otomatik merkez sistemle senkronize</p>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Platformlar -->
  <section class="platforms-section py-16 bg-gradient-to-r from-primary-red-light to-bg-light">
    <div class="container text-center">
      <h2 class="text-3xl font-bold mb-8">Tüm Platformlarda Mevcut</h2>
      <div class="flex flex-wrap justify-center gap-8 mb-12">
        <div class="platform-card bg-white p-6 rounded-lg shadow-md">
          <div class="text-4xl mb-4">
            🍎
          </div>
          <h3 class="text-xl font-semibold">iOS</h3>
          <p class="text-text-gray">iPhone ve iPad</p>
        </div>
        <div class="platform-card bg-white p-6 rounded-lg shadow-md">
          <div class="text-4xl mb-4">
            🤖
          </div>
          <h3 class="text-xl font-semibold">Android</h3>
          <p class="text-text-gray">Tüm Android cihazlar</p>
        </div>
        <div class="platform-card bg-white p-6 rounded-lg shadow-md">
          <div class="text-4xl mb-4">
            🌐
          </div>
          <h3 class="text-xl font-semibold">Web</h3>
          <p class="text-text-gray">Tarayıcı üzerinden</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section py-16 bg-primary-red text-white">
    <div class="container text-center">
      <h2 class="text-3xl font-bold mb-6">Mobil Saha Uygulamasını Hemen Deneyin</h2>
      <p class="text-xl mb-8 max-w-2xl mx-auto">
        Satış ekibinizin verimliliğini artırın, iş süreçlerinizi optimize edin.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a 
          href="https://wa.me/+905325000999?text=Merhaba,%20Mobil%20Saha%20Uygulaması%20demo%20talep%20ediyorum" 
          class="btn bg-white text-primary-red hover:bg-gray-100 flex items-center justify-center"
          target="_blank"
          rel="noopener noreferrer"
        >
          <span class="mr-2">💬</span>
          WhatsApp'tan Demo Talep Et
        </a>
        <a 
          href="tel:+905325000999" 
          class="btn bg-transparent border-2 border-white text-white hover:bg-white hover:text-primary-red"
        >
          <span class="mr-2">📞</span>
          Hemen Ara: 0532 500 09 99
        </a>
      </div>
    </div>
  </section>

  <style>
    :global(body) {
      scroll-behavior: smooth;
    }

    /* Hero Section */
    .hero-section {
      background: linear-gradient(135deg, var(--primary-red-light) 0%, var(--bg-white) 100%);
    }

    /* Container */
    .container {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 1rem;
    }

    /* Butonlar */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 0.75rem 1.5rem;
      border-radius: 0.5rem;
      font-weight: 600;
      text-decoration: none;
      transition: all 0.3s ease;
      border: 2px solid transparent;
      cursor: pointer;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary-red), var(--primary-red-dark));
      color: white;
      border-color: var(--primary-red);
    }

    .btn-primary:hover {
      background: linear-gradient(135deg, var(--primary-red-dark), var(--primary-red-darker));
    }

    .btn-secondary {
      background: white;
      color: var(--primary-red);
      border: 2px solid var(--primary-red);
    }

    .btn-secondary:hover {
      background: var(--primary-red-light);
    }

    /* Feature Cards */
    .feature-card {
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      border: 1px solid #e5e7eb;
    }

    .feature-card:hover {
      transform: translateY(-5px);
      box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    }

    .feature-icon {
      color: var(--primary-red);
    }

    /* Platform Cards */
    .platform-card {
      transition: transform 0.3s ease;
      min-width: 150px;
    }

    .platform-card:hover {
      transform: translateY(-5px);
    }

    /* CTA Section */
    .cta-section {
      background: linear-gradient(135deg, var(--primary-red), var(--primary-red-dark));
    }

    /* Utility Classes */
    .py-16 { padding-top: 4rem; padding-bottom: 4rem; }
    .mb-4 { margin-bottom: 1rem; }
    .mb-6 { margin-bottom: 1.5rem; }
    .mb-8 { margin-bottom: 2rem; }
    .mb-12 { margin-bottom: 3rem; }
    .mt-1 { margin-top: 0.25rem; }
    .mr-2 { margin-right: 0.5rem; }
    .mr-4 { margin-right: 1rem; }
    .text-center { text-align: center; }
    .text-3xl { font-size: 1.875rem; line-height: 2.25rem; }
    .text-4xl { font-size: 2.25rem; line-height: 2.5rem; }
    .text-5xl { font-size: 3rem; line-height: 1; }
    .text-xl { font-size: 1.25rem; line-height: 1.75rem; }
    .text-2xl { font-size: 1.5rem; line-height: 2rem; }
    .font-bold { font-weight: 700; }
    .font-semibold { font-weight: 600; }
    .rounded-lg { border-radius: 0.5rem; }
    .rounded-full { border-radius: 9999px; }
    .shadow-md { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06); }
    .bg-white { background-color: white; }
    .bg-bg-light { background-color: #f9fafb; }
    .bg-primary-red { background-color: #dc2626; }
    .bg-primary-red-light { background-color: #fef2f2; }
    .text-primary-red { color: #dc2626; }
    .text-white { color: white; }
    .text-text-gray { color: #6b7280; }
    .text-green-500 { color: #10b981; }
    .p-2 { padding: 0.5rem; }
    .p-6 { padding: 1.5rem; }
    .p-8 { padding: 2rem; }
    .flex { display: flex; }
    .flex-col { flex-direction: column; }
    .flex-wrap { flex-wrap: wrap; }
    .items-start { align-items: flex-start; }
    .items-center { align-items: center; }
    .justify-center { justify-content: center; }
    .flex-shrink-0 { flex-shrink: 0; }
    .mx-auto { margin-left: auto; margin-right: auto; }
    .max-w-4xl { max-width: 56rem; }
    .max-w-2xl { max-width: 42rem; }
    .gap-4 { gap: 1rem; }
    .gap-8 { gap: 2rem; }
    .space-y-2 > * + * { margin-top: 0.5rem; }
    .space-y-4 > * + * { margin-top: 1rem; }

    /* Grid */
    .grid { display: grid; }
    .grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
    .gap-8 { gap: 2rem; }

    /* Responsive */
    @media (min-width: 768px) {
      .md\:grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      .sm\:flex-row { flex-direction: row; }
    }

    @media (min-width: 1024px) {
      .lg\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }

    @media (max-width: 768px) {
      .hero-section h1 {
        font-size: 2.5rem;
      }
      
      .platforms-section .flex {
        flex-direction: column;
        align-items: center;
      }
      
      .platform-card {
        width: 100%;
        max-width: 250px;
      }
    }

    @media (max-width: 480px) {
      .hero-section h1 {
        font-size: 2rem;
      }
      
      .cta-section .flex {
        flex-direction: column;
      }
    }
 
  :root {
    --primary-red: #dc2626;
    --primary-red-dark: #b91c1c;
    --primary-red-darker: #991b1b;
    --primary-red-light: #fef2f2;
    --bg-white: #ffffff;
    --bg-light: #f9fafb;
    --text-gray: #6b7280;
    --border-color: #e5e7eb;
  }
  
  /* Diğer CSS kodları buraya */
</style>

 
</BaseLayout>
