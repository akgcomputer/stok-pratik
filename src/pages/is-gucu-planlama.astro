---
// src/pages/is-gucu-planlama.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/variables.css';
import '../styles/global.css';
import '../styles/components.css';

// Özellikler
const features = [
  {
    icon: "📅",
    title: "Vardiyalı Çalışma Planı",
    description: "7/24 çalışan işletmeler için esnek vardiya planlama",
    details: [
      "Otomatik vardiya oluşturma",
      "Çalışan tercihleri",
      "Vardiya değişim talepleri",
      "Yasal çalışma saatleri kontrolü"
    ]
  },
  {
    icon: "👥",
    title: "Personel Yönetimi",
    description: "Tüm personel bilgilerini tek platformda yönetin",
    details: [
      "Personel profilleri",
      "Yetki ve izin yönetimi",
      "Performans takibi",
      "Eğitim ve sertifikalar"
    ]
  },
  {
    icon: "⏱️",
    title: "Devam Kontrolü",
    description: "Otomatik devam-devamsızlık takibi",
    details: [
      "Parmak izi/yüz tanıma entegrasyonu",
      "Mobil check-in/out",
      "Geç kalma erken çıkma takibi",
      "Fazla mesai hesaplama"
    ]
  },
  {
    icon: "📊",
    title: "Performans Analizi",
    description: "Çalışan verimliliğini ölçün ve analiz edin",
    details: [
      "Verimlilik raporları",
      "Proje bazlı performans",
      "Ekip karşılaştırmaları",
      "Hedef takip sistemi"
    ]
  },
  {
    icon: "💰",
    title: "Maaş Bordrosu",
    description: "Otomatik maaş hesaplama ve bordro yönetimi",
    details: [
      "Otomatik maaş hesaplama",
      "SGK bildirimleri",
      "Vergi kesintileri",
      "Avans yönetimi"
    ]
  },
  {
    icon: "📱",
    title: "Mobil Uygulama",
    description: "Çalışanlar için özel mobil uygulama",
    details: [
      "Vardiya görüntüleme",
      "İzin talep etme",
      "Mobil check-in",
      "Bildirimler"
    ]
  }
];

// Sektör çözümleri
const industrySolutions = [
  {
    industry: "Üretim Fabrikaları",
    icon: "🏭",
    challenges: [
      "Çoklu vardiya yönetimi",
      "Makine-personel uyumu",
      "Üretim hattı planlaması",
      "Kalifiye personel dağılımı"
    ],
    benefits: [
      "%30 verimlilik artışı",
      "%25 işgücü maliyeti azalması",
      "%40 planlama süresi tasarrufu"
    ]
  },
  {
    industry: "Perakende Zincirleri",
    icon: "🏬",
    challenges: [
      "Çoklu şube personel yönetimi",
      "Zirve saat personel planlaması",
      "Part-time çalışan yönetimi",
      "Mağaza bazlı ihtiyaç planlaması"
    ],
    benefits: [
      "%35 personel optimizasyonu",
      "%20 fazla mesai azalması",
      "%45 planlama hatası azalması"
    ]
  },
  {
    industry: "Sağlık Sektörü",
    icon: "🏥",
    challenges: [
      "7/24 nöbet sistemi",
      "Uzman dağılımı",
      "Acil durum planlaması",
      "Dinlenme süreleri takibi"
    ],
    benefits: [
      "%50 nöbet planlama süresi azalması",
      "%30 personel memnuniyeti artışı",
      "%40 yasal uyumluluk"
    ]
  },
  {
    industry: "Çağrı Merkezleri",
    icon: "📞",
    challenges: [
      "Zirve saat planlaması",
      "Dil yetenekleri dağılımı",
      "Mola yönetimi",
      "Performans bazlı planlama"
    ],
    benefits: [
      "%40 müşteri memnuniyeti artışı",
      "%25 bekleme süresi azalması",
      "%35 personel verimliliği artışı"
    ]
  }
];

// İstatistikler
const statistics = [
  { number: "%40", label: "Planlama Süresi Tasarrufu", icon: "⏱️" },
  { number: "%25", label: "Fazla Mesai Azalması", icon: "💰" },
  { number: "%35", label: "Personel Verimliliği Artışı", icon: "📈" },
  { number: "7/24", label: "Sistem Erişimi", icon: "🌐" }
];

// İş gücü planlama adımları
const planningSteps = [
  {
    step: 1,
    title: "İş Yükü Analizi",
    description: "Haftalık/aylık iş yükünü analiz edin",
    icon: "📋"
  },
  {
    step: 2,
    title: "Personel Yetenek Eşleştirme",
    description: "İşe uygun personeli otomatik eşleştirin",
    icon: "👨‍💼"
  },
  {
    step: 3,
    title: "Vardiya Planı Oluştur",
    description: "Otomatik vardiya planını oluşturun",
    icon: "📅"
  },
  {
    step: 4,
    title: "Onay ve Dağıtım",
    description: "Planı onaylayıp çalışanlara iletin",
    icon: "✅"
  },
  {
    step: 5,
    title: "Gerçek Zamanlı Takip",
    description: "Planın uygulanmasını anlık takip edin",
    icon: "👁️"
  },
  {
    step: 6,
    title: "Performans Değerlendirme",
    description: "Sonuçları analiz ederek iyileştirin",
    icon: "📊"
  }
];

// İç linkler
const relatedPages = [
  { title: "ERP Sistemi", url: "/erp-sistemi", desc: "Tüm iş süreçleriniz için entegre çözüm" },
  { title: "Stok Yönetimi", url: "/stok-yonetimi", desc: "Üretim ve stok entegrasyonu" },
  { title: "Üretim Yönetimi", url: "/uretim-yonetimi", desc: "Üretim planlama ve takip" },
  { title: "Proje Yönetimi", url: "/proje-yonetimi", desc: "Proje bazlı iş gücü planlama" }
];
---

<BaseLayout 
  title="İş Gücü Planlama Sistemi | Personel Yönetimi - Stok Pratik" 
  description="İş gücü planlama sistemi ile personel yönetiminizi optimize edin. Vardiyalı çalışma planı, performans takibi ve otomatik maaş hesaplama ile verimliliğinizi artırın."
>
  
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <span class="hero-badge">İnsan Kaynakları Çözümü</span>
          <h1>İş Gücü Planlama Sistemi ile <span class="highlight">Personel Verimliliğinizi Artırın</span></h1>
          <p class="hero-subtitle hero-badge highlight">Vardiyalı çalışma planı, performans takibi ve otomatik maaş hesaplama ile iş gücü yönetiminizi optimize edin</p>
          
          <div class="hero-stats">
            {statistics.map((stat, index) => (
              <div class="stat-item" key={index}>
                <div class="stat-icon">{stat.icon}</div>
                <div class="stat-number">{stat.number}</div>
                <div class="stat-label">{stat.label}</div>
              </div>
            ))}
          </div>
          
          <div class="hero-buttons">
            <a 
              href="https://wa.me/+905325000999?text=Merhaba,%20İş%20Gücü%20Planlama%20Sistemi%20demo%20talep%20ediyorum" 
              class="btn btn-primary btn-large"
              target="_blank"
              rel="noopener noreferrer"
            >
              📅 Ücretsiz Demo İste
            </a>
            <a 
              href="tel:+905325000999" 
              class="btn btn-secondary btn-large"
            >
              📞 Hemen Ara: 0532 500 09 99
            </a>
          </div>
          
          <div class="hero-features">
            <div class="feature">
              <span class="feature-icon">🤖</span>
              <span>Otomatik Planlama</span>
            </div>
            <div class="feature">
              <span class="feature-icon">📱</span>
              <span>Mobil Uygulama</span>
            </div>
            <div class="feature">
              <span class="feature-icon">🔒</span>
              <span>SGK Uyumlu</span>
            </div>
            <div class="feature">
              <span class="feature-icon">⚡</span>
              <span>Gerçek Zamanlı</span>
            </div>
          </div>
        </div>
        
        <div class="hero-image">
          <div class="workforce-dashboard">
            <div class="dashboard-header">
              <div class="dashboard-title">
                <span class="title-icon">👥</span>
                <span>İş Gücü Planlama Paneli</span>
              </div>
              <div class="dashboard-period">Bu Hafta: 12-18 Ağustos</div>
            </div>
            
            <div class="shift-overview">
              <div class="shift-card">
                <div class="shift-type">Sabah</div>
                <div class="shift-hours">08:00 - 16:00</div>
                <div class="shift-count">24 Çalışan</div>
              </div>
              <div class="shift-card">
                <div class="shift-type">Akşam</div>
                <div class="shift-hours">16:00 - 00:00</div>
                <div class="shift-count">18 Çalışan</div>
              </div>
              <div class="shift-card">
                <div class="shift-type">Gece</div>
                <div class="shift-hours">00:00 - 08:00</div>
                <div class="shift-count">12 Çalışan</div>
              </div>
            </div>
            
            <div class="personnel-status">
              <div class="status-item">
                <div class="status-label">İş Başında</div>
                <div class="status-value success">42</div>
              </div>
              <div class="status-item">
                <div class="status-label">İzinli</div>
                <div class="status-value warning">8</div>
              </div>
              <div class="status-item">
                <div class="status-label">Hasta</div>
                <div class="status-value danger">4</div>
              </div>
              <div class="status-item">
                <div class="status-label">Toplam</div>
                <div class="status-value">54</div>
              </div>
            </div>
            
            <div class="urgent-alerts">
              <div class="alert-icon">⚠️</div>
              <div class="alert-text">2 vardiyada personel eksikliği var</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Çözüm -->
  <section class="challenge-section">
    <div class="container">
      <div class="section-header">
        <h2>İş Gücü Planlama Zorluklarını Çözüyoruz</h2>
        <p>İşletmelerin yaşadığı personel planlama problemlerine akıllı çözümler</p>
      </div>
      
      <div class="challenge-grid">
        <div class="challenge-card">
          <div class="challenge-icon">😫</div>
          <h3>Manuel Planlama</h3>
          <p>Excel tabloları ile saatler süren manuel planlama</p>
          <ul>
            <li>Hatalı planlama riski</li>
            <li>Zaman kaybı</li>
            <li>Son dakika değişiklikleri</li>
          </ul>
        </div>
        
        <div class="solution-card">
          <div class="solution-icon">🤖</div>
          <h3>Otomatik Planlama</h3>
          <p>Akıllı algoritmalar ile dakikalar içinde plan oluşturma</p>
          <ul>
            <li>%90 zaman tasarrufu</li>
            <li>Hatasız planlama</li>
            <li>Anlık güncelleme</li>
          </ul>
        </div>
        
        <div class="challenge-card">
          <div class="challenge-icon">💸</div>
          <h3>Yüksek Fazla Mesai</h3>
          <p>Plansızlıktan kaynaklanan yüksek fazla mesai maliyetleri</p>
          <ul>
            <li>Bütçe aşımı</li>
            <li>Personel yorgunluğu</li>
            <li>Verimlilik kaybı</li>
          </ul>
        </div>
        
        <div class="solution-card">
          <div class="solution-icon">📊</div>
          <h3>Optimize Planlama</h3>
          <p>İş yükü analizi ile optimal personel dağılımı</p>
          <ul>
            <li>%30 fazla mesai azalması</li>
            <li>Maliyet optimizasyonu</li>
            <li>Verimlilik artışı</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Özellikler -->
  <section class="features-section">
    <div class="container">
      <div class="section-header">
        <h2>Stok Pratik İş Gücü Planlama Özellikleri</h2>
        <p>Personel yönetiminizi kolaylaştıran kapsamlı çözümler</p>
      </div>
      
      <div class="features-grid">
        {features.map((feature, index) => (
          <div class="feature-card" key={index}>
            <div class="feature-header">
              <div class="feature-icon">{feature.icon}</div>
              <div>
                <h3>{feature.title}</h3>
                <p class="feature-desc">{feature.description}</p>
              </div>
            </div>
            
            <ul class="feature-details">
              {feature.details.map((detail, i) => (
                <li key={i}>
                  <span class="detail-check">✓</span>
                  {detail}
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Sektör Çözümleri -->
  <section class="industry-section">
    <div class="container">
      <div class="section-header">
        <h2>Sektörünüze Özel İş Gücü Çözümleri</h2>
        <p>Her sektörün ihtiyacına göre özelleştirilmiş planlama</p>
      </div>
      
      <div class="industry-grid">
        {industrySolutions.map((solution, index) => (
          <div class="industry-card" key={index}>
            <div class="industry-header">
              <div class="industry-icon">{solution.icon}</div>
              <h3>{solution.industry}</h3>
            </div>
            
            <div class="challenges-section">
              <h4>🎯 Zorluklar</h4>
              <ul>
                {solution.challenges.map((challenge, i) => (
                  <li key={i}>{challenge}</li>
                ))}
              </ul>
            </div>
            
            <div class="benefits-section">
              <h4>✅ Kazançlar</h4>
              <div class="benefits-list">
                {solution.benefits.map((benefit, i) => (
                  <div class="benefit-item" key={i}>
                    <span class="benefit-icon">🚀</span>
                    <span>{benefit}</span>
                  </div>
                ))}
              </div>
            </div>
            
            <a 
              href={`https://wa.me/+905325000999?text=Merhaba,%20${encodeURIComponent(solution.industry)}%20için%20iş%20gücü%20planlama%20sistemi%20hakkında%20bilgi%20almak%20istiyorum`}
              class="btn btn-industry"
              target="_blank"
              rel="noopener noreferrer"
            >
              👥 Bu Sektör İçin Demo İste
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Planlama Süreci -->
  <section class="process-section">
    <div class="container">
      <div class="section-header">
        <h2>6 Adımda Akıllı İş Gücü Planlaması</h2>
        <p>Stok Pratik ile iş gücü planlama süreciniz nasıl işler?</p>
      </div>
      
      <div class="process-timeline">
        {planningSteps.map((step, index) => (
          <div class="process-step" key={index}>
            <div class="step-number">{step.step}</div>
            <div class="step-content">
              <div class="step-header">
                <div class="step-icon">{step.icon}</div>
                <h3>{step.title}</h3>
              </div>
              <p class="step-description">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
      
      <div class="process-result">
        <div class="result-icon">🎉</div>
        <div class="result-content">
          <h3>Optimize Edilmiş İş Gücü ve %40 Verimlilik Artışı!</h3>
          <p>Stok Pratik ile iş gücü planlamanızı otomatikleştirin, maliyetlerinizi düşürün ve verimliliğinizi artırın.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Entegrasyonlar -->
  <section class="integration-section">
    <div class="container">
      <div class="section-header">
        <h2>Diğer Sistemlerle Tam Entegrasyon</h2>
        <p>İş gücü planlama sistemimiz diğer sistemlerinizle uyumlu çalışır</p>
      </div>
      
      <div class="integrations-grid">
        <div class="integration-card">
          <div class="integration-icon">📦</div>
          <h3>Stok Yönetimi</h3>
          <p>Stok seviyelerine göre otomatik personel planlaması</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">🏭</div>
          <h3>Üretim Planlama</h3>
          <p>Üretim planına uygun iş gücü dağılımı</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">💰</div>
          <h3>Muhasebe Sistemi</h3>
          <p>Otomatik maaş hesaplama ve bordro entegrasyonu</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">🔒</div>
          <h3>SGK ve Vergi</h3>
          <p>Yasal bildirimler için otomatik entegrasyon</p>
        </div>
      </div>
    </div>
  </section>

  <!-- İlgili Sayfalar -->
  <section class="related-pages">
    <div class="container">
      <div class="section-header">
        <h2>Entegre Çalışan Diğer Çözümlerimiz</h2>
        <p>İş gücü planlama ile birlikte kullanabileceğiniz sistemler</p>
      </div>
      
      <div class="pages-grid">
        {relatedPages.map((page, index) => (
          <a href={page.url} class="page-card" key={index}>
            <h3>{page.title}</h3>
            <p>{page.desc}</p>
            <div class="page-link">
              <span>İncele</span>
              <span class="arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Son CTA -->
  <section class="final-cta">
    <div class="container">
      <div class="cta-content">
        <div class="cta-icon">👥</div>
        <h2>İş Gücü Planlamanızı Ücretsiz Analiz Edelim</h2>
        <p class="hero-badge highlight">Uzman ekibimiz işletmenizin iş gücü ihtiyacını analiz edip size özel çözüm sunsun.</p>
        
        <div class="cta-buttons">
          <a 
            href="https://wa.me/+905325000999?text=Merhaba,%20İş%20Gücü%20Planlama%20analizi%20ve%20demo%20talep%20ediyorum"
            class="btn btn-secondary btn-large"
            target="_blank"
            rel="noopener noreferrer"
          >
            📊 Ücretsiz Analiz İste
          </a>
          
          <a 
            href="tel:+905325000999"
            class="btn btn-secondary btn-large"
          >
            📞 Canlı Destek Al
          </a>
        </div>
        
        <div class="cta-benefits">
          <div class="benefit">
            <span class="benefit-icon">🎯</span>
            <span>Ücretsiz İş Gücü Analizi</span>
          </div>
          <div class="benefit">
            <span class="benefit-icon">👨‍🏫</span>
            <span>Canlı Sistem Eğitimi</span>
          </div>
          <div class="benefit">
            <span class="benefit-icon">🔄</span>
            <span>Mevcut Veri Aktarımı</span>
          </div>
          <div class="benefit">
            <span class="benefit-icon">💰</span>
            <span>Maliyet Analizi Raporu</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero Section */
  .hero-section {
    background: linear-gradient(135deg, #2c3e50 0%, #3498db 100%);
    color: white;
    padding: 4rem 0;
  }
  
  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  
  .hero-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.2);
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }
  
  .hero-text h1 {
    font-size: 3rem;
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }
  
  .highlight {
    color: #f1c40f;
  }
  
  .hero-subtitle {
    font-size: 1.2rem;
    opacity: 0.9;
    margin-bottom: 2rem;
  }
  
  .hero-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin: 2rem 0;
  }
  
  .stat-item {
    text-align: center;
    background: rgba(255, 255, 255, 0.1);
    padding: 1rem;
    border-radius: 10px;
    backdrop-filter: blur(10px);
  }
  
  .stat-icon {
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }
  
  .stat-number {
    font-size: 1.5rem;
    font-weight: bold;
    color: #f1c40f;
    margin-bottom: 0.3rem;
  }
  
  .stat-label {
    font-size: 0.8rem;
    opacity: 0.8;
  }
  
  .hero-buttons {
    display: flex;
    gap: 1rem;
    margin: 2rem 0;
  }
  
  .btn-large {
    padding: 1rem 2rem;
    font-size: 1.1rem;
  }
  
  .hero-features {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  
  .feature {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
    background: rgba(255, 255, 255, 0.1);
    padding: 0.5rem 1rem;
    border-radius: 20px;
  }
  
  .feature-icon {
    font-size: 1rem;
  }
  
  /* Workforce Dashboard */
  .workforce-dashboard {
    background: white;
    border-radius: 15px;
    padding: 1.5rem;
    box-shadow: 0 20px 40px rgba(0,0,0,0.2);
    color: #2c3e50;
  }
  
  .dashboard-header {
