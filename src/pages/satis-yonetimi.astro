---
// src/pages/satis-yonetimi.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/variables.css';
import '../styles/global.css';
import '../styles/components.css';

// Özellikler
const features = [
  {
    icon: "🎯",
    title: "Müşteri Yönetimi",
    description: "Tüm müşterilerinizi tek platformda yönetin",
    details: [
      "Müşteri profilleri ve geçmişi",
      "İletişim geçmişi takibi",
      "Satın alma alışkanlıkları",
      "Segmentasyon ve etiketleme"
    ]
  },
  {
    icon: "📊",
    title: "Satış Analizi",
    description: "Detaylı satış raporları ve performans analizi",
    details: [
      "Gerçek zamanlı satış dashboard",
      "Ürün bazlı performans",
      "Bölgesel satış analizi",
      "Kar marjı hesaplama"
    ]
  },
  {
    icon: "📈",
    title: "Satış Tahminleme",
    description: "Yapay zeka destekli satış tahminleri",
    details: [
      "AI destekli tahminleme",
      "Trend analizi",
      "Sezonluk tahminler",
      "Stok planlama önerileri"
    ]
  },
  {
    icon: "🔄",
    title: "Satış Süreçleri",
    description: "Satış süreçlerinizi otomatikleştirin",
    details: [
      "Teklif ve fiyatlandırma",
      "Sipariş takip sistemi",
      "Otomatik hatırlatmalar",
      "Ödeme takibi"
    ]
  },
  {
    icon: "🤝",
    title: "Müşteri İlişkileri",
    description: "Müşterilerinizle ilişkilerinizi güçlendirin",
    details: [
      "Otomatik e-posta kampanyaları",
      "Doğum günü hatırlatmaları",
      "Sadakat programı",
      "Müşteri geri bildirimleri"
    ]
  },
  {
    icon: "📱",
    title: "Mobil Satış",
    description: "Mobil cihazlardan satış yapın ve takip edin",
    details: [
      "Mobil satış uygulaması",
      "Offline çalışma",
      "Anlık senkronizasyon",
      "Fotoğraflı ürün gösterimi"
    ]
  }
];

// Satış kanalları
const salesChannels = [
  {
    channel: "Mağaza Satışları",
    icon: "🏬",
    features: [
      "POS entegrasyonu",
      "Fiş ve fatura basımı",
      "Stok anlık güncelleme",
      "Kampanya yönetimi"
    ],
    benefits: ["%30 daha hızlı satış", "%40 daha az hata"]
  },
  {
    channel: "E-Ticaret",
    icon: "🛒",
    features: [
      "E-ticaret entegrasyonu",
      "Otomatik sipariş aktarımı",
      "Stok senkronizasyonu",
      "Müşteri veri aktarımı"
    ],
    benefits: ["%50 zaman tasarrufu", "%100 doğru sipariş"]
  },
  {
    channel: "Saha Satışları",
    icon: "🚗",
    features: [
      "Mobil satış uygulaması",
      "Offline sipariş alma",
      "Müşteri ziyaret planlama",
      "GPS konum takibi"
    ],
    benefits: ["%60 daha fazla ziyaret", "%35 satış artışı"]
  },
  {
    channel: "Telefon Satışları",
    icon: "📞",
    features: [
      "Çağrı merkezi entegrasyonu",
      "Otomatik müşteri kaydı",
      "Konuşma kayıtları",
      "Performans analizi"
    ],
    benefits: ["%45 daha fazla çağrı", "%25 başarı oranı artışı"]
  }
];

// İstatistikler
const statistics = [
  { number: "%35", label: "Satış Artışı", icon: "📈" },
  { number: "%50", label: "Zaman Tasarrufu", icon: "⏱️" },
  { number: "%40", label: "Müşteri Memnuniyeti", icon: "😊" },
  { number: "%60", label: "Satış Verimliliği", icon: "⚡" }
];

// Satış süreç adımları
const salesProcess = [
  {
    step: 1,
    title: "Potansiyel Müşteri",
    description: "Yeni müşteri adayları bulun ve kaydedin",
    icon: "🔍"
  },
  {
    step: 2,
    title: "Değerlendirme",
    description: "Müşteri ihtiyaçlarını analiz edin",
    icon: "📋"
  },
  {
    step: 3,
    title: "Teklif",
    description: "Özelleştirilmiş teklif hazırlayın",
    icon: "💼"
  },
  {
    step: 4,
    title: "Görüşme",
    description: "Müşteri ile detaylı görüşme yapın",
    icon: "🤝"
  },
  {
    step: 5,
    title: "Satış",
    description: "Satışı tamamlayın ve sipariş oluşturun",
    icon: "💰"
  },
  {
    step: 6,
    title: "Takip",
    description: "Satış sonrası hizmet ve takip",
    icon: "📞"
  }
];

// Başarı hikayeleri
const successStories = [
  {
    company: "Tekstil Perakende",
    result: "%45 Satış Artışı",
    quote: "Stok Pratik ile satış ekibimizin verimliliği %60 arttı. Müşteri takibimiz artık çok daha kolay.",
    author: "Ahmet Yılmaz",
    position: "Satış Müdürü"
  },
  {
    company: "Elektronik Toptancı",
    result: "%30 Karlılık Artışı",
    quote: "Satış tahminleme özelliği ile stok optimizasyonu yaparak kar marjımızı önemli ölçüde artırdık.",
    author: "Mehmet Kaya",
    position: "Genel Müdür"
  }
];

// İç linkler
const relatedPages = [
  { title: "CRM Sistemi", url: "/crm", desc: "Müşteri ilişkileri yönetimi" },
  { title: "Stok Yönetimi", url: "/stok-yonetimi", desc: "Satış ve stok entegrasyonu" },
  { title: "Proje Yönetimi", url: "/proje-yonetimi", desc: "Satış projeleri takibi" },
  { title: "ERP Sistemi", url: "/erp-sistemi", desc: "Entegre iş yönetimi" }
];
---

<BaseLayout 
  title="Satış Yönetim Sistemi | Stok Pratik - Satışları Artırın" 
  description="Satış yönetim sistemi ile satışlarınızı artırın, müşteri ilişkilerinizi güçlendirin. Satış analizi, müşteri takibi ve satış tahminleme ile işinizi büyütün."
>
  
  <!-- Hero Section -->
  <section class="hero-section">
    <div class="container">
      <div class="hero-content">
        <div class="hero-text">
          <span class="hero-badge">Satış Çözümleri</span>
          <h1>Satış Yönetim Sistemi ile <span class="highlight">Satışlarınızı Artırın</span></h1>
          <p class="hero-subtitle">Müşteri takibi, satış analizi ve satış tahminleme ile satış ekibinizin performansını maksimize edin</p>
          
          <div class="hero-stats">
            {statistics.map((stat, index) => (
              <div class="stat-item" key={index}>
                <div class="stat-icon">{stat.icon}</div>
                <div class="stat-number">{stat.number}</div>
                <div class="stat-label">{stat.label}</div>
              </div>
            ))}
          </div>
          
          <div class="hero-buttons">
            <a 
              href="https://wa.me/+905325000999?text=Merhaba,%20Satış%20Yönetim%20Sistemi%20demo%20talep%20ediyorum" 
              class="btn btn-secondary btn-large"
              target="_blank"
              rel="noopener noreferrer"
            >
              🚀 Ücretsiz Demo İste
            </a>
            <a 
              href="tel:+905325000999" 
              class="btn btn-secondary btn-large"
            >
              📞 Satış Danışmanıyla Görüş
            </a>
          </div>
          
          <div class="sales-channels">
            <div class="channel-tag">
              <span class="channel-icon">🏬</span>
              <span>Mağaza Satışı</span>
            </div>
            <div class="channel-tag">
              <span class="channel-icon">🛒</span>
              <span>E-Ticaret</span>
            </div>
            <div class="channel-tag">
              <span class="channel-icon">🚗</span>
              <span>Saha Satışı</span>
            </div>
            <div class="channel-tag">
              <span class="channel-icon">📞</span>
              <span>Telefon Satışı</span>
            </div>
          </div>
        </div>
        
        <div class="hero-image">
          <div class="sales-dashboard">
            <div class="dashboard-header">
              <div class="dashboard-title">
                <span class="title-icon">📊</span>
                <span>Satış Performans Paneli</span>
              </div>
              <div class="dashboard-period">Ağustos 2024</div>
            </div>
            
            <div class="sales-overview">
              <div class="sales-metric">
                <div class="metric-label">Toplam Ciro</div>
                <div class="metric-value">₺245,800</div>
                <div class="metric-change positive">↑ %12.5</div>
              </div>
              
              <div class="sales-metric">
                <div class="metric-label">Satış Adeti</div>
                <div class="metric-value">148</div>
                <div class="metric-change positive">↑ %8.3</div>
              </div>
              
              <div class="sales-metric">
                <div class="metric-label">Ort. Sepet Tutarı</div>
                <div class="metric-value">₺1,660</div>
                <div class="metric-change positive">↑ %3.9</div>
              </div>
              
              <div class="sales-metric">
                <div class="metric-label">Yeni Müşteri</div>
                <div class="metric-value">45</div>
                <div class="metric-change positive">↑ %15.2</div>
              </div>
            </div>
            
            <div class="top-salespeople">
              <div class="section-title">🏆 En İyi Satış Temsilcileri</div>
              <div class="salesperson">
                <div class="salesperson-name">Ahmet Yılmaz</div>
                <div class="salesperson-sales">₺48,500</div>
              </div>
              <div class="salesperson">
                <div class="salesperson-name">Ayşe Demir</div>
                <div class="salesperson-sales">₺42,300</div>
              </div>
              <div class="salesperson">
                <div class="salesperson-name">Mehmet Kaya</div>
                <div class="salesperson-sales">₺38,700</div>
              </div>
            </div>
            
            <div class="sales-target">
              <div class="target-label">Aylık Hedef: ₺300,000</div>
              <div class="target-progress">
                <div class="progress-bar">
                  <div class="progress-fill" style="width: 82%"></div>
                </div>
                <div class="target-percent">%82</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Problem Çözüm -->
  <section class="problem-section">
    <div class="container">
      <div class="section-header">
        <h2>Satış Yönetimi Zorluklarını Çözüyoruz</h2>
        <p>İşletmelerin yaşadığı satış yönetimi problemlerine akıllı çözümler</p>
      </div>
      
      <div class="problem-grid">
        <div class="problem-card">
          <div class="problem-icon">😫</div>
          <h3>Müşteri Takip Zorluğu</h3>
          <p>Excel tabloları ile müşteri takibi, veri kaybı riski</p>
          <ul>
            <li>Müşteri geçmişi takipsizliği</li>
            <li>İletişim kayıtları dağınık</li>
            <li>Satış fırsatları kaçırma</li>
          </ul>
        </div>
        
        <div class="solution-card">
          <div class="solution-icon">✅</div>
          <h3>Merkezi Müşteri Veritabanı</h3>
          <p>Tüm müşteri bilgileri tek platformda güvenli saklama</p>
          <ul>
            <li>Tam müşteri geçmişi</li>
            <li>Tüm iletişim kayıtları</li>
            <li>Otomatik takip sistemi</li>
          </ul>
        </div>
        
        <div class="problem-card">
          <div class="problem-icon">📉</div>
          <h3>Satış Performans Analizi</h3>
          <p>Satış performansını ölçememe, hedef takip zorluğu</p>
          <ul>
            <li>Satış raporları manuel</li>
            <li>Performans karşılaştırması yok</li>
            <li>Hedef takibi zor</li>
          </ul>
        </div>
        
        <div class="solution-card">
          <div class="solution-icon">📊</div>
          <h3>Gerçek Zamanlı Satış Dashboard</h3>
          <p>Anlık satış performansı ve detaylı analiz raporları</p>
          <ul>
            <li>Anlık satış verileri</li>
            <li>Ekip performans analizi</li>
            <li>Otomatik hedef takibi</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Özellikler -->
  <section class="features-section">
    <div class="container">
      <div class="section-header">
        <h2>Stok Pratik Satış Yönetimi Özellikleri</h2>
        <p>Satış ekibinizin ihtiyaç duyduğu tüm araçlar tek platformda</p>
      </div>
      
      <div class="features-grid">
        {features.map((feature, index) => (
          <div class="feature-card" key={index}>
            <div class="feature-header">
              <div class="feature-icon">{feature.icon}</div>
              <div>
                <h3>{feature.title}</h3>
                <p class="feature-desc">{feature.description}</p>
              </div>
            </div>
            
            <ul class="feature-details">
              {feature.details.map((detail, i) => (
                <li key={i}>
                  <span class="detail-check">✓</span>
                  {detail}
                </li>
              ))}
            </ul>
            
            <div class="feature-cta">
              <a 
                href={`https://wa.me/+905325000999?text=Merhaba,%20${encodeURIComponent(feature.title)}%20özelliği%20hakkında%20bilgi%20almak%20istiyorum`}
                class="btn-feature"
                target="_blank"
                rel="noopener noreferrer"
              >
                Bu Özellik Hakkında Bilgi Al
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Satış Kanalları -->
  <section class="channels-section">
    <div class="container">
      <div class="section-header">
        <h2>Tüm Satış Kanallarınız İçin Tek Çözüm</h2>
        <p>Hangi kanaldan satış yaparsanız yapın, tüm veriler tek merkezde</p>
      </div>
      
      <div class="channels-grid">
        {salesChannels.map((channel, index) => (
          <div class="channel-card" key={index}>
            <div class="channel-header">
              <div class="channel-icon">{channel.icon}</div>
              <h3>{channel.channel}</h3>
            </div>
            
            <div class="channel-features">
              <h4>Özellikler:</h4>
              <ul>
                {channel.features.map((feature, i) => (
                  <li key={i}>
                    <span class="feature-icon">✨</span>
                    {feature}
                  </li>
                ))}
              </ul>
            </div>
            
            <div class="channel-benefits">
              <h4>Kazançlar:</h4>
              <div class="benefits-list">
                {channel.benefits.map((benefit, i) => (
                  <div class="benefit-item" key={i}>
                    <span class="benefit-icon">🚀</span>
                    <span>{benefit}</span>
                  </div>
                ))}
              </div>
            </div>
            
            <a 
              href={`https://wa.me/+905325000999?text=Merhaba,%20${encodeURIComponent(channel.channel)}%20için%20satış%20yönetim%20sistemi%20demo%20talep%20ediyorum`}
              class="btn btn-channel"
              target="_blank"
              rel="noopener noreferrer"
            >
              🎯 Bu Kanal İçin Demo İste
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Satış Süreci -->
  <section class="process-section">
    <div class="container">
      <div class="section-header">
        <h2>6 Adımda Mükemmel Satış Süreci</h2>
        <p>Stok Pratik ile satış süreçlerinizi standartlaştırın ve optimize edin</p>
      </div>
      
      <div class="process-timeline">
        {salesProcess.map((step, index) => (
          <div class="process-step" key={index}>
            <div class="step-number">{step.step}</div>
            <div class="step-icon">{step.icon}</div>
            <div class="step-content">
              <h3>{step.title}</h3>
              <p>{step.description}</p>
              <div class="step-tools">
                {index === 0 && (
                  <>
                    <span class="tool">📱 Müşteri Kayıt</span>
                    <span class="tool">📋 İhtiyaç Analizi</span>
                  </>
                )}
                {index === 2 && (
                  <>
                    <span class="tool">💼 Teklif Hazırlama</span>
                    <span class="tool">💰 Fiyatlandırma</span>
                  </>
                )}
                {index === 4 && (
                  <>
                    <span class="tool">📝 Sipariş Oluşturma</span>
                    <span class="tool">✅ Ödeme Takibi</span>
                  </>
                )}
              </div>
            </div>
          </div>
        ))}
      </div>
      
      <div class="process-result">
        <div class="result-icon">🏆</div>
        <div class="result-content">
          <h3>%35 Daha Fazla Satış ve Mutlu Müşteriler!</h3>
          <p>Stok Pratik ile satış süreçlerinizi otomatikleştirin, müşteri memnuniyetinizi artırın ve satışlarınızı büyütün.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Başarı Hikayeleri -->
  <section class="success-section">
    <div class="container">
      <div class="section-header">
        <h2>Stok Pratik ile Büyüyen İşletmeler</h2>
        <p>Satış yönetim sistemimizi kullanan işletmelerin başarı hikayeleri</p>
      </div>
      
      <div class="success-stories">
        {successStories.map((story, index) => (
          <div class="story-card" key={index}>
            <div class="story-header">
              <div class="story-company">{story.company}</div>
              <div class="story-result">{story.result}</div>
            </div>
            
            <div class="story-quote">
              <div class="quote-icon">❝</div>
              <p>{story.quote}</p>
            </div>
            
            <div class="story-author">
              <div class="author-name">{story.author}</div>
              <div class="author-position">{story.position}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Entegrasyonlar -->
  <section class="integrations-section">
    <div class="container">
      <div class="section-header">
        <h2>Popüler Platformlarla Tam Entegrasyon</h2>
        <p>Mevcut sistemlerinizle sorunsuz çalışır</p>
      </div>
      
      <div class="integrations-grid">
        <div class="integration-card">
          <div class="integration-icon">📧</div>
          <h4>E-Posta</h4>
          <p>Gmail, Outlook entegrasyonu</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">💬</div>
          <h4>WhatsApp</h4>
          <p>WhatsApp Business API</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">🏬</div>
          <h4>POS Sistemleri</h4>
          <p>Tüm POS cihazları</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">🛒</div>
          <h4>E-Ticaret</h4>
          <p>Trendyol, Hepsiburada, n11</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">📊</div>
          <h4>Analiz Araçları</h4>
          <p>Google Analytics entegrasyonu</p>
        </div>
        
        <div class="integration-card">
          <div class="integration-icon">💳</div>
          <h4>Ödeme Sistemleri</h4>
          <p>İyzico, PayTR, Stripe</p>
        </div>
      </div>
    </div>
  </section>

  <!-- İlgili Sayfalar -->
  <section class="related-pages">
    <div class="container">
      <div class="section-header">
        <h2>Satış Yönetimi ile Entegre Çalışan Diğer Sistemler</h2>
        <p>İş süreçlerinizi tamamlayan çözümlerimiz</p>
      </div>
      
      <div class="pages-grid">
        {relatedPages.map((page, index) => (
          <a href={page.url} class="page-card" key={index}>
            <h3>{page.title}</h3>
            <p>{page.desc}</p>
            <div class="page-link">
              <span>İncele</span>
              <span class="arrow">→</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Son CTA -->
  <section class="final-cta">
    <div class="container">
      <div class="cta-content">
        <div class="cta-icon">💰</div>
        <h2>Satışlarınızı Artırmaya Hazır mısınız?</h2>
        <p class="hero-badge highlight">Satış yönetim sistemimizi keşfedin, satış ekibinizin performansını artırın.</p>
        
        <div class="cta-buttons">
          <a 
            href="https://wa.me/+905325000999?text=Merhaba,%20Satış%20Yönetim%20Sistemi%20demo%20talep%20ediyorum"
            class="btn btn-secondary btn-large"
            target="_blank"
            rel="noopener noreferrer"
          >
            🚀 Ücretsiz Demo Başlat
          </a>
          
          <a 
            href="tel:+905325000999"
            class="btn btn-secondary btn-large"
          >
            📞 Satış Danışmanıyla Görüş
          </a>
        </div>
        
        <div class="cta-benefits">
          <div class="benefit">
            <span class="benefit-icon">📈</span>
            <span>Ücretsiz Satış Analizi</span>
          </div>
          <div class="benefit">
            <span class="benefit-icon">👨‍🏫</span>
            <span>Satış Ekibi Eğitimi</span>
          </div>
          <div class="benefit">
            <span class="benefit-icon">🔄</span>
            <span>Mevcut Veri Aktarımı</span>
          </div>
          <div class="benefit">
            <span class="benefit-icon">🎯</span>
            <span>Satış Hedef Planlaması</span>
          </div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero Section */
  .hero-section {
    background: linear-gradient(135deg, #2c3e50 0%, #e74c3c 100%);
    color: white;
    padding: 4rem 0;
  }
  
  .hero-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
