---
// src/components/Header.astro
import SocialMedia from './SocialMedia.astro';
---

<header class="site-header">
  <nav class="container site-nav">
    <!-- Logo -->
    <a class="site-logo" href="/">
      <span class="site-logo-text">Stok Pratik</span>
    </a>

    <!-- Desktop Navigation -->
    <div class="desktop-nav-container">
      <div class="nav-left">
        <ul class="nav-list">
          <li><a href="/" title="Ana Sayfa">🏠</a></li>
          <li><a href="/ozelliklerimiz">Özellikler</a></li>
          <li><a href="/paketlerimiz">Paketler</a></li>
          <li><a href="/oto-tamir-yazilimi">Oto Servis</a></li>
          <li><a href="/neden-stok-pratik">SSS?</a></li>
          <li><a href="/ekran-goruntuleri">SS</a></li>
          <li><a href="/referanslarimiz">Referanslar</a></li>
          <li class="contact-link">
            <a href="/iletisim" title="İletişim">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </li>
        </ul>
      </div>
      
      <div class="nav-right">
        <!-- Sosyal Medya - Desktop'ta sağ üstte -->
        <div class="social-media-wrapper">
          <SocialMedia />
        </div>
        
        <div class="nav-actions">
          <a class="btn btn-primary" href="https://wa.me/+905325000999">Demo Talep Et</a>
        </div>
      </div>
    </div>

    <!-- Mobile Menu Button ve Demo Butonu -->
    <div class="mobile-header-actions">
      <div class="nav-actions mobile-only">
        <a class="btn btn-primary btn-sm" href="https://wa.me/+905325000999">Demo</a>
      </div>
      
      <button id="mobileMenuBtn" class="mobile-menu-button">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
          <path d="M4 6h16M4 12h16M4 18h16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div id="mobileMenu" class="mobile-menu">
    <div class="container">
      <button id="mobileMenuClose" class="mobile-menu-close">×</button>

      <ul class="mobile-nav-links">
        <li><a href="/" class="mobile-nav-link">🏠 Ana Sayfa</a></li>
        <li><a href="/ozelliklerimiz" class="mobile-nav-link">📋 Özelliklerimiz</a></li>
        <li><a href="/neden-stok-pratik" class="mobile-nav-link">❓ SSS (Sık Sorulan Sorular)</a></li>
        <li><a href="/paketlerimiz" class="mobile-nav-link">💰 Paketlerimiz</a></li>
        <li><a href="/ekran-goruntuleri" class="mobile-nav-link">🖼️ Ekran Görüntüleri</a></li>
        <li><a href="/referanslarimiz" class="mobile-nav-link">⭐ Referanslarımız</a></li>
        <li>
          <a href="/iletisim" class="mobile-nav-link">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" style="margin-right: 8px;">
              <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            📞 İletişim
          </a>
        </li>
      </ul>

      <!-- Mobile Sosyal Medya -->
      <div class="mobile-social-media">
        <SocialMedia />
      </div>

      <div class="mt-8">
        <a href="https://wa.me/+905325000999" class="btn btn-primary w-full">Demo Talep Et</a>
      </div>
    </div>
  </div>
</header>

<style>
  :root {
    --primary-red: #dc2626;
    --primary-red-dark: #b91c1c;
    --text-gray: #4b5563;
    --text-dark: #1f2937;
    --bg-white: #ffffff;
    --secondary-light: #f3f4f6;
    --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .site-header {
    background: var(--bg-white);
    box-shadow: var(--shadow-md);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .site-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 0;
    position: relative;
  }

  .site-logo {
    display: flex;
    align-items: center;
    color: var(--primary-red);
    font-weight: 700;
    text-decoration: none;
    font-size: 1.4rem;
    white-space: nowrap;
    z-index: 101;
  }

  .site-logo-text {
    color: var(--primary-red);
  }

  .desktop-nav-container {
    display: none;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    gap: 1rem;
  }

  .nav-left {
    display: flex;
    align-items: center;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-list {
    display: flex;
    list-style: none;
    gap: 1rem;
    align-items: center;
    margin: 0;
    padding: 0;
  }

  .nav-list a {
    text-decoration: none;
    color: var(--text-gray);
    font-weight: 500;
    transition: color 0.2s;
    padding: 0.5rem 0.75rem;
    display: flex;
    align-items: center;
    white-space: nowrap;
    font-size: 0.95rem;
  }

  .nav-list a:hover {
    color: var(--primary-red);
  }

  .contact-link a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--secondary-light);
    transition: all 0.3s;
  }

  .contact-link a:hover {
    background: var(--primary-red);
    color: white;
  }

  .contact-link a:hover svg {
    stroke: white;
  }

  .contact-link svg {
    stroke: var(--text-gray);
  }

  .social-media-wrapper {
    display: flex;
    align-items: center;
  }

  .mobile-header-actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .mobile-only {
    display: none;
  }

  .mobile-menu-button {
    background: none;
    border: none;
    font-size: 1.25rem;
    color: var(--text-gray);
    cursor: pointer;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 101;
  }

  .mobile-menu-button:hover {
    color: var(--primary-red);
  }

  .mobile-menu {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--bg-white);
    transform: translateX(100%);
    transition: transform 0.3s ease;
    z-index: 1000;
    overflow-y: auto;
    padding: 1.25rem 0;
    opacity: 0;
    visibility: hidden;
  }

  .mobile-menu.active {
    transform: translateX(0);
    opacity: 1;
    visibility: visible;
  }

  .mobile-menu-close {
    position: absolute;
    top: 1.25rem;
    right: 1rem;
    background: none;
    border: none;
    font-size: 2rem;
    color: var(--text-gray);
    cursor: pointer;
    padding: 0.5rem;
    line-height: 1;
    z-index: 1001;
  }

  .mobile-menu-close:hover {
    color: var(--primary-red);
  }

  .mobile-nav-links {
    list-style: none;
    padding: 0;
    margin: 3.75rem 0 0 0;
  }

  .mobile-nav-links li {
    margin-bottom: 0.5rem;
  }

  .mobile-nav-link {
    display: flex;
    align-items: center;
    padding: 0.75rem 0;
    text-decoration: none;
    color: var(--text-gray);
    font-size: 1.125rem;
    font-weight: 500;
    border-bottom: 1px solid var(--secondary-light);
  }

  .mobile-nav-link:hover {
    color: var(--primary-red);
  }

  .mobile-social-media {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--secondary-light);
  }

  .btn {
    display: inline-block;
    padding: 0.5rem 1.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    text-align: center;
    border-radius: 0.375rem;
    transition: all 0.3s;
    cursor: pointer;
    border: 2px solid transparent;
    text-decoration: none;
    white-space: nowrap;
  }

  .btn-sm {
    padding: 0.375rem 0.875rem;
    font-size: 0.85rem;
  }

  .btn-primary {
    background-color: var(--primary-red);
    color: white;
    border-color: var(--primary-red);
  }

  .btn-primary:hover {
    background-color: var(--primary-red-dark);
    border-color: var(--primary-red-dark);
    transform: translateY(-2px);
  }

  .w-full {
    width: 100%;
  }

  .mt-8 {
    margin-top: 2rem;
  }

  @media (min-width: 768px) {
    .desktop-nav-container {
      display: flex;
    }
    
    .mobile-menu-button,
    .mobile-only {
      display: none;
    }
    
    .site-logo {
      font-size: 1.5rem;
      margin-right: 2rem;
    }
    
    .nav-list {
      gap: 1.25rem;
    }
    
    .nav-list a {
      font-size: 1rem;
    }
  }

  @media (max-width: 767px) {
    .mobile-only {
      display: block;
    }
    
    .mobile-header-actions {
      display: flex;
    }
    
    .site-logo {
      font-size: 1.25rem;
      flex: 1;
    }
    
    .nav-actions:not(.mobile-only) {
      display: none;
    }
    
    .social-media-wrapper {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .site-logo {
      font-size: 1.1rem;
    }
    
    .btn-sm {
      padding: 0.25rem 0.75rem;
      font-size: 0.8rem;
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('mobileMenuBtn');
    const menu = document.getElementById('mobileMenu');
    const closeBtn = document.getElementById('mobileMenuClose');

    if (!btn || !menu) return;

    function openMenu() {
      menu.classList.add('active');
      document.body.style.overflow = 'hidden';
      btn.setAttribute('aria-expanded', 'true');
    }

    function closeMenu() {
      menu.classList.remove('active');
      document.body.style.overflow = '';
      btn.setAttribute('aria-expanded', 'false');
    }

    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = menu.classList.contains('active');
      if (isOpen) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    if (closeBtn) {
      closeBtn.addEventListener('click', closeMenu);
    }

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menu.classList.contains('active')) {
        closeMenu();
      }
    });

    // Close menu when clicking on a link
    const mobileLinks = menu.querySelectorAll('.mobile-nav-link');
    mobileLinks.forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    // Close menu when clicking outside
    document.addEventListener('click', (e) => {
      if (menu.classList.contains('active') && 
          !menu.contains(e.target) && 
          e.target !== btn && 
          !btn.contains(e.target)) {
        closeMenu();
      }
    });
  });
</script>