  }
];
---

<BaseLayout 
  title="Teknik Servis Yönetimi | Stok Pratik - Akıllı Servis Çözümleri"
  description="Teknik servis yönetimi sistemi ile servis süreçlerinizi optimize edin. Talep yönetimi, teknisyen atama, stok takibi tek sistemde."
>

  <!-- Hero Section -->
  <section style="padding: 4rem 0; background: linear-gradient(135deg, #ea580c, #f97316); color: white;">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto;">
        <h1 style="color: white; margin-bottom: 1.5rem; font-size: 2.5rem;">
          Profesyonel Teknik Servis Yönetimi
        </h1>
        <p style="font-size: 1.25rem; margin-bottom: 2rem; opacity: 0.9;">
          Servis taleplerinden müşteri memnuniyetine, tüm süreçleri tek sistemde yönetin.
        </p>
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a 
            href="https://wa.me/+905325000999?text=Merhaba,%20teknik%20servis%20yönetimi%20demo%20talep%20ediyorum"
            class="btn btn-primary"
            style="min-height: 52px; background: white; color: #ea580c; border-color: white;"
            target="_blank"
            rel="noopener noreferrer"
          >
            🔧 Servis Demo İste
          </a>
          <a 
            href="https://wa.me/+905325000999?text=Merhaba,%20teknik%20servis%20analizi%20yaptırmak%20istiyorum"
            class="btn btn-secondary"
            style="min-height: 52px; border-color: white; color: white;"
            target="_blank"
            rel="noopener noreferrer"
          >
            📊 Ücretsiz Servis Analizi
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Ana İçerik -->
  <main style="padding: 3rem 0; background: var(--bg-white);">
    <div class="container">
      
      <!-- Servis Modülleri -->
      <section style="margin-bottom: 4rem;">
        <h2 style="text-align: center; color: #ea580c; margin-bottom: 2rem;">
          6 Temel Servis Yönetimi Modülü
        </h2>
        
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
          {serviceModules.map((module) => (
            <div style="background: white; padding: 2rem; border-radius: 1rem; border: 1px solid #fed7aa; box-shadow: var(--shadow-md); text-align: center;">
              <div style="font-size: 3rem; margin-bottom: 1rem;">{module.icon}</div>
              <h3 style="color: #ea580c; margin-bottom: 0.75rem; font-size: 1.1rem;">{module.title}</h3>
              <p style="color: var(--text-gray); margin-bottom: 1rem; font-size: 0.95rem;">{module.description}</p>
              <div style="background: #ffedd5; padding: 0.5rem; border-radius: 0.5rem; border-left: 3px solid #f97316;">
                <span style="color: #9a3412; font-weight: 600;">{module.benefit}</span>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Servis Süreçleri -->
      <section style="margin-bottom: 4rem; background: #fff7ed; padding: 3rem; border-radius: 1rem;">
        <h2 style="text-align: center; color: #ea580c; margin-bottom: 2rem;">
          4 Adımda Profesyonel Servis
        </h2>
        
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;">
          {serviceProcess.map((process) => (
            <div style="position: relative; text-align: center;">
              <div style="position: absolute; top: -1.5rem; left: 50%; transform: translateX(-50%); background: #f97316; color: white; width: 3rem; height: 3rem; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 1.25rem; z-index: 10;">
                {process.step}
              </div>
              <div style="background: white; padding: 2rem 1.5rem 1.5rem; border-radius: 1rem; border: 2px solid #fdba74; height: 100%;">
                <h3 style="color: #ea580c; margin-top: 1rem; margin-bottom: 0.75rem; font-size: 1.1rem;">{process.title}</h3>
                <p style="color: var(--text-gray); margin: 0; font-size: 0.95rem;">{process.description}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Servis Türleri -->
      <section style="margin-bottom: 4rem;">
        <h2 style="text-align: center; color: #ea580c; margin-bottom: 2rem;">
          Farklı Sektörler İçin Teknik Servis Çözümleri
        </h2>
        
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem;">
          {serviceTypes.map((service) => (
            <div style="background: white; padding: 2rem; border-radius: 1rem; border: 1px solid #fed7aa; box-shadow: var(--shadow-sm);">
              <div style="display: flex; align-items: center; gap: 1rem; margin-bottom: 1.5rem;">
                <div style="font-size: 2.5rem;">{service.icon}</div>
                <div>
                  <h3 style="color: #ea580c; margin: 0; font-size: 1.25rem;">{service.type}</h3>
                  <div style="color: var(--text-gray); font-size: 0.9rem;">{service.equipment.join(", ")}</div>
                </div>
              </div>
              
              <div style="margin-bottom: 1.5rem;">
                <div style="font-weight: 600; color: var(--text-dark); margin-bottom: 0.5rem;">Özellikler:</div>
                <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.5rem;">
                  {service.features.map((feature) => (
                    <div style="display: flex; align-items: center; gap: 0.5rem;">
                      <div style="color: #f97316;">•</div>
                      <div style="color: var(--text-dark); font-size: 0.95rem;">{feature}</div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Performans Metrikleri -->
      <section style="margin-bottom: 4rem;">
        <h2 style="text-align: center; color: #ea580c; margin-bottom: 2rem;">
          Teknik Servis Performans Metrikleri
        </h2>
        
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem;">
          {performanceMetrics.map((metric) => (
            <div style="background: white; padding: 2rem; border-radius: 1rem; border: 1px solid #fed7aa;">
              <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 1rem;">
                <div>
                  <div style="font-size: 2rem; font-weight: bold; color: #ea580c;">{metric.metric}</div>
                  <div style="font-weight: 600; color: var(--text-dark); margin-top: 0.25rem;">{metric.title}</div>
                </div>
                <div style="background: #ffedd5; color: #9a3412; padding: 0.5rem 1rem; border-radius: 0.5rem; font-weight: 600;">
                  {metric.target}
                </div>
              </div>
              
              <div style="color: var(--text-gray); font-size: 0.95rem;">
                <div style="font-weight: 600; color: var(--text-dark); margin-bottom: 0.25rem;">Etkisi:</div>
                {metric.impact}
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Teknisyen Yönetimi -->
      <section style="margin-bottom: 4rem; background: #fff7ed; padding: 3rem; border-radius: 1rem;">
        <h2 style="text-align: center; color: #ea580c; margin-bottom: 2rem;">
          Akıllı Teknisyen Yönetimi
        </h2>
        
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem;">
          {technicianFeatures.map((feature) => (
            <div style="background: white; padding: 2rem; border-radius: 1rem; border: 1px solid #fed7aa;">
              <h3 style="color: #ea580c; margin-top: 0; margin-bottom: 0.75rem; font-size: 1.1rem;">{feature.feature}</h3>
              <p style="color: var(--text-gray); margin-bottom: 1rem; font-size: 0.95rem;">{feature.description}</p>
              <div style="background: #ffedd5; padding: 0.75rem; border-radius: 0.5rem; border-left: 3px solid #f97316;">
                <div style="font-weight: 600; color: #9a3412;">Fayda: {feature.benefit}</div>
              </div>
            </div>
          ))}
        </div>
        
        <div style="text-align: center; margin-top: 2rem;">
          <div style="display: inline-block; background: #ea580c; color: white; padding: 1rem 2rem; border-radius: 0.75rem;">
            <div style="font-size: 1.25rem; font-weight: bold;">Teknisyen Başına Verimlilik Artışı: %40</div>
            <div style="font-size: 0.9rem;">Ortalama performans iyileşmesi</div>
          </div>
        </div>
      </section>

      <!-- Başarı Hikayeleri -->
      <section style="margin-bottom: 4rem;">
        <h2 style="text-align: center; color: #ea580c; margin-bottom: 2rem;">
          Teknik Serviste Başarı Hikayeleri
        </h2>
        
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
          {successStories.map((story) => (
            <div style="background: white; padding: 2rem; border-radius: 1rem; border: 1px solid #fed7aa; box-shadow: var(--shadow-md); text-align: center;">
              <div style="font-size: 2rem; margin-bottom: 1rem;">🔧</div>
              <h3 style="color: #ea580c; margin-bottom: 0.5rem;">{story.company}</h3>
              <div style="color: var(--text-gray); margin-bottom: 1rem;">📍 {story.location}</div>
              
              <div style="margin-bottom: 1rem;">
                <div style="font-weight: 600; color: var(--text-dark); margin-bottom: 0.25rem;">Problem:</div>
                <div style="color: #dc2626; background: #fef2f2; padding: 0.5rem; border-radius: 0.5rem; border-left: 3px solid #dc2626;">
                  {story.problem}
                </div>
              </div>
              
              <div style="margin-bottom: 1rem;">
                <div style="font-weight: 600; color: var(--text-dark); margin-bottom: 0.25rem;">Çözüm:</div>
                <div style="color: var(--text-dark); background: #ffedd5; padding: 0.5rem; border-radius: 0.5rem; border-left: 3px solid #f97316;">
                  {story.solution}
                </div>
              </div>
              
              <div style="background: linear-gradient(135deg, #f97316, #ea580c); color: white; padding: 0.75rem; border-radius: 0.5rem;">
                <div style="font-weight: 600; font-size: 1.1rem;">Sonuç: {story.result}</div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- İç Linkler -->
      <section style="margin-bottom: 4rem;">
        <h2 style="text-align: center; color: #ea580c; margin-bottom: 2rem;">
          Teknik Servis ile Entegre Çözümlerimiz
        </h2>
        
        <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
          {internalLinks.map((link) => (
            <a 
              href={link.url}
              style="display: flex; align-items: center; gap: 1rem; background: white; padding: 1.5rem; border-radius: 0.75rem; text-decoration: none; color: var(--text-dark); border: 1px solid #fed7aa; transition: all 0.3s;"
            >
              <div style="font-size: 2rem;">{link.icon}</div>
              <div>
                <div style="font-weight: 600; color: #ea580c; margin-bottom: 0.25rem;">{link.title}</div>
                <div style="color: var(--text-gray); font-size: 0.95rem;">{link.description}</div>
              </div>
            </a>
          ))}
        </div>
      </section>

      <!-- FAQ -->
      <section style="margin-bottom: 4rem;">
        <h2 style="text-align: center; color: #ea580c; margin-bottom: 2rem;">
          Teknik Servis Yönetimi Hakkında Sıkça Sorulan Sorular
        </h2>
        
        <div style="max-width: 800px; margin: 0 auto;">
          {faqItems.map((item, index) => (
            <div style="background: white; padding: 1.5rem; border-radius: 0.75rem; margin-bottom: 1rem; border: 1px solid #fed7aa; box-shadow: var(--shadow-sm);">
              <div style="display: flex; gap: 1rem;">
                <div style="color: #ea580c; font-weight: bold;">Q{index + 1}:</div>
                <div style="flex: 1;">
                  <h3 style="color: #ea580c; margin: 0 0 0.75rem 0; font-size: 1.1rem;">{item.question}</h3>
                  <p style="margin: 0; color: var(--text-dark); line-height: 1.6;">{item.answer}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section style="background: linear-gradient(135deg, #ea580c, #f97316); padding: 4rem; border-radius: 1.5rem; text-align: center; color: white;">
        <h2 style="color: white; margin-bottom: 1rem; font-size: 2rem;">Teknik Servis Sisteminizi Ücretsiz Analiz Edelim</h2>
        <p style="margin-bottom: 2rem; font-size: 1.1rem; opacity: 0.9; max-width: 600px; margin-left: auto; margin-right: auto;">
          Teknik servis uzmanlarımız mevcut sisteminizi analiz edip, size öyel optimizasyon planı hazırlasın.
        </p>
        
        <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
          <a 
            href="https://wa.me/+905325000999?text=Merhaba,%20teknik%20servis%20sistemi%20analizi%20için%20görüşmek%20istiyorum"
            style="display: inline-flex; align-items: center; justify-content: center; padding: 1rem 2rem; background-color: white; color: #ea580c; text-decoration: none; border-radius: 0.75rem; font-weight: 600; gap: 0.5rem; border: none; cursor: pointer; font-size: 1.1rem;"
            target="_blank"
            rel="noopener noreferrer"
          >
            🔧 Ücretsiz Servis Analizi
          </a>
          
          <a 
            href="https://wa.me/+905325000999?text=Merhaba,%20teknik%20servis%20yönetimi%20demo%20ve%20fiyat%20teklifi%20almak%20istiyorum"
            style="display: inline-flex; align-items: center; justify-content: center; padding: 1rem 2rem; background-color: transparent; color: white; text-decoration: none; border-radius: 0.75rem; font-weight: 600; gap: 0.5rem; border: 2px solid white; cursor: pointer; font-size: 1.1rem;"
            target="_blank"
            rel="noopener noreferrer"
          >
            📱 Demo + Mobil Uygulama İnceleme
          </a>
        </div>
        
        <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin-top: 3rem; text-align: center;">
          <div>
