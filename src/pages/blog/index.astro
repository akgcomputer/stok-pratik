---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allBlogPosts = await getCollection('blog');
---

<BaseLayout title="Blog | Stok Pratik">
  <div class="blog-container">
    <h1>Stok Pratik Blog</h1>
    <p>Ön muhasebe, stok yönetimi ve işletme verimliliği hakkında en güncel yazılar.</p>
    
    <div class="blog-grid">
      {allBlogPosts.map((post) => {
        const category = post.data.category || 'genel';
        const link = post.data.externalLink || `/blog/${category}/${post.slug}`;
        const target = post.data.externalLink ? '_blank' : '_self';
        return (
          <article class="blog-card">
            <h2><a href={link} target={target}>{post.data.title}</a></h2>
            <p class="desc">{post.data.description}</p>
            <a href={link} target={target} class="read-more">Devamını Oku &rarr;</a>
          </article>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .blog-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 100px 20px 60px;
  }
  .blog-container h1 {
    font-size: 2.5rem;
    color: var(--primary-color, #1a1a1a);
    margin-bottom: 10px;
  }
  .blog-container > p {
    font-size: 1.1rem;
    color: #666;
    margin-bottom: 40px;
  }
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 30px;
  }
  .blog-card {
    background: #fff;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
    transition: transform 0.3s ease;
  }
  .blog-card:hover {
    transform: translateY(-5px);
  }
  .blog-card h2 {
    font-size: 1.4rem;
    margin-bottom: 10px;
    line-height: 1.3;
  }
  .blog-card h2 a {
    color: inherit;
    text-decoration: none;
  }
  .date {
    font-size: 0.9rem;
    color: #888;
    margin-bottom: 15px;
  }
  .desc {
    color: #555;
    margin-bottom: 20px;
    line-height: 1.6;
  }
  .read-more {
    display: inline-block;
    font-weight: 600;
    color: var(--accent-color, #0056b3);
    text-decoration: none;
  }
</style>
