    solution: "Gerçek zamanlı takip + öncelik sistemi",
    result: "SLA uyumu %95'e çıktı"
  },
  {
    company: "IT Destek Şirketi",
    location: "İzmir",
    problem: "Know-how kaybı, tekrarlayan arızalar",
