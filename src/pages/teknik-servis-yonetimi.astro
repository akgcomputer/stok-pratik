  }
];

// FAQ
const faqItems = [
  {
    question: "Teknik servis yönetimi yazılımı fiyatları ne kadar?",
    answer: "Stok Pratik teknik servis paketleri uygun fiyattan başlar. Fiyat; teknisyen sayısı, servis noktası sayısı ve mobil özelliklere göre değişir. İlk ay %25 indirim imkanı sunuyoruz."
  },
  {
    question: "Mobil uygulama ile sahada nasıl çalışırız?",
    answer: "Android ve iOS uygulamalarımızla teknisyenler sahada arıza kaydı yapabilir, fotoğraf/video ekleyebilir, parça tüketimini girebilir, müşteri onayı alabilir. Offline modda da çalışabilir."
  },
  {
    question: "Garanti takibini yapabilir miyiz?",
