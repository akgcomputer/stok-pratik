---
// src/pages/bulut-muhasebe-sistemi.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/variables.css';
import '../styles/global.css';
import '../styles/components.css';

// İç linkler için data
const internalLinks = [
  { 
    title: "Online Muhasebe Programı", 
    url: "/online-muhasebe-programi",
    description: "İnternet tabanlı muhasebe çözümleri"
  },
  { 
    title: "Muhasebe Yazılımı", 
    url: "/muhasebe-yazilimi",
    description: "Modern muhasebe yazılımı avantajları"
  },
  { 
    title: "KOBİ Muhasebe Programı", 
    url: "/kobi-muhasebe-programi",
    description: "KOBİ'lere özel bulut muhasebe çözümleri"
  },
  { 
    title: "ERP Sistemi", 
    url: "/erp-sistemi",
    description: "Kurumsal bulut ERP çözümleri"
  },
  { 
    title: "Mağaza Yönetim Yazılımı", 
    url: "/magaza-yonetim-yazilimi",
    description: "Bulut tabanlı mağaza otomasyonu"
  }
];

// Bulut muhasebe avantajları
const cloudAdvantages = [
  {
    icon: "☁️",
    title: "İnternet Üzerinden Erişim",
    description: "İnternet bağlantısı olan her yerden 7/24 erişim. Ofise bağlı kalmadan çalışın."
  },
  {
    icon: "💰",
    title: "Düşük Yatırım Maliyeti",
    description: "Sunucu, lisans, bakım gibi ek maliyetler yok. Sadece abonelik ücreti."
  },
  {
    icon: "🔄",
    title: "Otomatik Güncelleme",
    description: "Yazılım güncellemeleri otomatik. Her zaman en güncel versiyonu kullanın."
  },
  {
    icon: "🔐",
    title: "Güvenli Veri Saklama",
    description: "Verileriniz banka seviyesinde güvenlikle bulutta saklanır. Yedekleme otomatik."
  },
  {
    icon: "📱",
    title: "Çoklu Cihaz Desteği",
    description: "Bilgisayar, tablet, telefon - tüm cihazlardan sorunsuz erişim."
  },
  {
    icon: "👥",
    title: "Ekip Çalışması",
    description: "Aynı anda birden fazla kullanıcı çalışabilir. Gerçek zamanlı senkronizasyon."
  }
];

// Geleneksel vs Bulut Karşılaştırması
const comparisonData = [
  {
    kategori: "Kurulum Maliyeti",
    geleneksel: "Yüksek (Sunucu + Lisans)",
    bulut: "Yok / Düşük",
    fark: "%90 tasarruf"
  },
  {
    kategori: "Bakım ve Güncelleme",
    geleneksel: "Manuel / Ek Maliyet",
    bulut: "Otomatik / Ücretsiz",
    fark: "Zamandan tasarruf"
  },
  {
    kategori: "Erişim",
    geleneksel: "Sadece ofis",
    bulut: "Her yerden 7/24",
    fark: "Esneklik"
  },
  {
    kategori: "Veri Güvenliği",
    geleneksel: "Yerel yedekleme",
    bulut: "Profesyonel bulut",
    fark: "Daha güvenli"
  },
  {
    kategori: "Ölçeklenebilirlik",
    geleneksel: "Sınırlı",
    bulut: "Sınırsız",
    fark: "Büyümeye uygun"
  }
];

// Stok Pratik Bulut Özellikleri
const stokPratikFeatures = [
  {
    title: "DataCenter Altyapısı",
    description: "Veri Merkezi Web Services üzerinde çalışan güvenli ve yüksek performanslı altyapı",
    benefit: "Yüksek hız ve %99,9 uptime garantisi"
  },
  {
    title: "256-bit SSL Şifreleme",
    description: "Banka seviyesinde güvenlik ile veri transferi",
    benefit: "Verileriniz maksimum güvenlikte"
  },
  {
    title: "Otomatik Yedekleme",
    description: "Günlük otomatik yedekleme ile veri kaybı riski yok",
    benefit: "7/30/90 günlük yedekleme seçenekleri"
  },
  {
    title: "CDN Desteği",
    description: "Content Delivery Network ile yüksek hızda erişim",
    benefit: "Tüm Türkiye'de yüksek performans"
  },
  {
    title: "Load Balancing",
    description: "Yük dengeleme ile kesintisiz hizmet",
    benefit: "Yoğun kullanımda bile performans"
  },
  {
    title: "Disaster Recovery",
    description: "Felaket kurtarma planı ile veri güvenliği",
    benefit: "Olağanüstü durumlarda bile güvende"
  }
];

// Kullanım Senaryoları
const usageScenarios = [
  {
    senaryo: "Saha Satış Ekibi",
    problem: "Müşteri ziyaretlerinde fatura kesememe",
    cozum: "Tablet üzerinden bulut muhasebe ile anında fatura kesme",
    sonuc: "Satışlar %40 arttı"
  },
  {
    senaryo: "Çok Şubeli İşletme",
    problem: "Şubeler arası stok senkronizasyonu",
    cozum: "Bulut tabanlı merkezi stok yönetimi",
    sonuc: "Stok maliyetleri %25 azaldı"
  },
  {
    senaryo: "E-Ticaret Firması",
    problem: "Farklı platformlardaki satışların takibi",
    cozum: "Otomatik entegrasyon ve bulut raporlama",
    sonuc: "İş yükü %60 azaldı"
  },
  {
    senaryo: "Muhasebe Bürosu",
    problem: "Müşteri verilerine uzaktan erişim",
    cozum: "Bulut üzerinden müşteri portföyü yönetimi",
    sonuc: "Verimlilik %70 arttı"
  }
];

// FAQ
const faqItems = [
  {
    question: "Bulut muhasebe sistemi güvenli mi?",
    answer: "Stok Pratik, DataCenter Web Services altyapısında çalışır. 256-bit SSL şifreleme, günlük otomatik yedekleme, çok katmanlı güvenlik duvarları ve ISO 27001 sertifikalı güvenlik protokolleri ile banka seviyesinde güvenlik sunar."
  },
  {
    question: "İnternet kesintisinde ne olur?",
    answer: "Stok Pratik, offline modda çalışabilme özelliğine sahiptir. İnternet kesintisinde işlemlerinize devam edebilir, internet bağlantısı sağlandığında tüm veriler otomatik senkronize edilir."
  },
  {
    question: "Verilerim nerede saklanıyor?",
    answer: "Verileriniz Türkiye'de bulunan veri merkezlerinde saklanır. Böylece KVKK uyumluluğu sağlanır ve yüksek hızda erişim imkanı sunulur."
  },
  {
    question: "Kaç kullanıcı aynı anda çalışabilir?",
    answer: "Paketinize göre sınırsıza yakın kullanıcı desteği sunuyoruz. Aynı anda onlarca kullanıcı aynı veri üzerinde çalışabilir, gerçek zamanlı senkronizasyon ile çakışma yaşanmaz."
  },
  {
    question: "Mevcut verilerimi nasıl taşıyabilirim?",
    answer: "Excel, XML veya diğer muhasebe programlarından otomatik veri aktarımı yapabiliriz. Ücretsiz veri taşıma hizmeti ile geçiş sürecinizi sorunsuz tamamlıyoruz."
  }
];

// SEO için meta
const seoTitle = "Bulut Muhasebe Sistemi | Stok Pratik - Bulut Tabanlı Çözümler";
const seoDescription = "Bulut muhasebe sistemi ile işletmenizin finansal süreçlerini modernize edin. Güvenli, ekonomik ve esnek bulut çözümleri.";
---

<BaseLayout 
  title={seoTitle}
  description={seoDescription}
>

  <!-- Hero Section -->
  <section style="background: linear-gradient(135deg, #f0f9ff 0%, var(--bg-white) 100%); padding: 4rem 0;">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto;">
        <h1 style="background: linear-gradient(135deg, #0ea5e9, #3b82f6); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 1.5rem; font-size: 2.5rem;">
          Bulut Muhasebe Sistemi: İşletmenizin Geleceği Bulutta
        </h1>
        <p style="font-size: 1.25rem; color: var(--text-gray); margin-bottom: 2rem;">
          İnternet üzerinden erişilebilen, güvenli ve ekonomik muhasebe çözümü ile tanışın. Ofis sınırlarını aşın.
        </p>
      </div>
    </div>
  </section>

  <!-- Ana İçerik -->
  <main style="padding: 3rem 0; background: var(--bg-white);">
    <div class="container">
      <div style="max-width: 1000px; margin: 0 auto;">
        
        <!-- Giriş -->
        <section style="margin-bottom: 3rem;">
          <h2>Bulut Muhasebe Nedir?</h2>
          <p>Bulut muhasebe sistemi, muhasebe yazılımının ve verilerinizin internete bağlı sunucularda (bulut) barındırıldığı, tarayıcı üzerinden erişilebilen modern bir çözümdür.</p>
          
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin: 2rem 0;">
            <div style="text-align: center; padding: 1.5rem; background: #f0f9ff; border-radius: 0.75rem; border: 1px solid #bae6fd;">
              <div style="font-size: 2.5rem;">☁️</div>
              <div style="font-weight: bold; color: #0ea5e9; margin: 0.5rem 0;">Bulutta Barındırma</div>
            </div>
            <div style="text-align: center; padding: 1.5rem; background: #f0f9ff; border-radius: 0.75rem; border: 1px solid #bae6fd;">
              <div style="font-size: 2.5rem;">🌐</div>
              <div style="font-weight: bold; color: #0ea5e9; margin: 0.5rem 0;">İnternet Erişimi</div>
            </div>
            <div style="text-align: center; padding: 1.5rem; background: #f0f9ff; border-radius: 0.75rem; border: 1px solid #bae6fd;">
              <div style="font-size: 2.5rem;">🔄</div>
              <div style="font-weight: bold; color: #0ea5e9; margin: 0.5rem 0;">Otomatik Güncelleme</div>
            </div>
          </div>
        </section>

        <!-- Karşılaştırma Tablosu -->
        <section style="margin-bottom: 3rem;">
          <h2>Geleneksel vs Bulut Muhasebe Karşılaştırması</h2>
          
          <div style="overflow-x: auto; margin: 1.5rem 0;">
            <table style="width: 100%; border-collapse: collapse; min-width: 600px;">
              <thead>
                <tr style="background: linear-gradient(135deg, #0ea5e9, #3b82f6); color: white;">
                  <th style="padding: 1rem; text-align: left; width: 30%;">Kategori</th>
                  <th style="padding: 1rem; text-align: center; width: 25%;">Geleneksel Sistem</th>
                  <th style="padding: 1rem; text-align: center; width: 25%;">Bulut Muhasebe</th>
                  <th style="padding: 1rem; text-align: center; width: 20%;">Fark</th>
                </tr>
              </thead>
              <tbody>
                {comparisonData.map((item, index) => (
                  <tr style={index % 2 === 0 ? 'background: #f8fafc;' : ''}>
                    <td style="padding: 1rem; border: 1px solid #e2e8f0; font-weight: 600;">{item.kategori}</td>
                    <td style="padding: 1rem; border: 1px solid #e2e8f0; text-align: center; color: #ef4444;">{item.geleneksel}</td>
                    <td style="padding: 1rem; border: 1px solid #e2e8f0; text-align: center; color: #10b981; font-weight: 600;">{item.bulut}</td>
                    <td style="padding: 1rem; border: 1px solid #e2e8f0; text-align: center;">{item.fark}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>

        <!-- Bulut Avantajları -->
        <section style="margin-bottom: 3rem;">
          <h2>Bulut Muhasebenin 6 Temel Avantajı</h2>
          
          <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; margin-top: 1.5rem;">
            {cloudAdvantages.map((advantage) => (
              <div style="background: var(--bg-white); padding: 1.5rem; border-radius: 0.75rem; border: 1px solid #e2e8f0; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
                <div style="font-size: 3rem; margin-bottom: 1rem; text-align: center;">{advantage.icon}</div>
                <h3 style="color: #0ea5e9; margin-bottom: 0.5rem; text-align: center; font-size: 1.1rem;">{advantage.title}</h3>
                <p style="text-align: center; margin: 0; color: var(--text-dark); font-size: 0.95rem;">{advantage.description}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- Stok Pratik Bulut Altyapısı -->
        <section style="margin-bottom: 3rem; background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%); padding: 2.5rem; border-radius: 1rem;">
          <h2 style="color: #0ea5e9;">Stok Pratik Bulut Altyapısı</h2>
          <p style="margin-bottom: 1.5rem;">Profesyonel bulut altyapımız ile maksimum performans ve güvenlik:</p>
          
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem;">
            {stokPratikFeatures.map((feature) => (
              <div style="background: white; padding: 1.5rem; border-radius: 0.75rem; border: 1px solid #bae6fd;">
                <h3 style="color: #0ea5e9; margin-top: 0; margin-bottom: 0.5rem; font-size: 1.1rem;">{feature.title}</h3>
                <p style="margin: 0 0 0.5rem 0; color: var(--text-dark); font-size: 0.95rem;">{feature.description}</p>
                <div style="background: #dcfce7; padding: 0.5rem; border-radius: 0.5rem; border-left: 3px solid #16a34a;">
                  <span style="color: #166534; font-weight: 600;">✓ {feature.benefit}</span>
                </div>
              </div>
            ))}
          </div>
          
          <div style="margin-top: 2rem; padding: 1.5rem; background: white; border-radius: 0.75rem; border: 1px solid #0ea5e9;">
            <div style="display: flex; align-items: center; gap: 1rem;">
              <div style="font-size: 2rem;">🛡️</div>
              <div>
                <h3 style="color: #0ea5e9; margin: 0 0 0.5rem 0;">%99,9 Uptime Garantisi</h3>
                <p style="margin: 0; color: var(--text-dark);">Yüksek erişilebilirlik ile kesintisiz hizmet. SLA garantisi.</p>
              </div>
            </div>
          </div>
        </section>

        <!-- Kullanım Senaryoları -->
        <section style="margin-bottom: 3rem;">
          <h2>Bulut Muhasebe ile Gerçek Hayat Çözümleri</h2>
          
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 1.5rem;">
            {usageScenarios.map((scenario) => (
              <div style="background: var(--bg-white); padding: 1.5rem; border-radius: 0.75rem; border: 1px solid var(--border-color);">
                <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
                  <div style="background: #0ea5e9; color: white; padding: 0.25rem 0.75rem; border-radius: 1rem; font-size: 0.9rem; font-weight: 600;">
                    {scenario.senaryo}
                  </div>
                </div>
                
                <div style="margin-bottom: 1rem;">
                  <div style="font-weight: 600; color: var(--text-dark); margin-bottom: 0.25rem;">Problem:</div>
                  <div style="color: #ef4444; font-size: 0.95rem;">{scenario.problem}</div>
                </div>
                
                <div style="margin-bottom: 1rem;">
                  <div style="font-weight: 600; color: var(--text-dark); margin-bottom: 0.25rem;">Çözüm:</div>
                  <div style="color: var(--text-dark); font-size: 0.95rem;">{scenario.cozum}</div>
                </div>
                
                <div style="background: #dcfce7; padding: 0.75rem; border-radius: 0.5rem; border-left: 3px solid #16a34a;">
                  <div style="font-weight: 600; color: #166534;">Sonuç: {scenario.sonuc}</div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- Maliyet Analizi -->
        <section style="margin-bottom: 3rem; background: #f8fafc; padding: 2rem; border-radius: 1rem;">
          <h2>Bulut Muhasebe Maliyet Avantajları</h2>
          
          <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin: 1.5rem 0;">
            <div style="text-align: center; padding: 1rem;">
              <div style="font-size: 2rem; font-weight: bold; color: #0ea5e9;">0₺</div>
              <div style="color: var(--text-dark); margin-top: 0.5rem;">Kurulum</div>
            </div>
            <div style="text-align: center; padding: 1rem;">
              <div style="font-size: 2rem; font-weight: bold; color: #0ea5e9;">0₺</div>
              <div style="color: var(--text-dark); margin-top: 0.5rem;">Sunucu</div>
            </div>
            <div style="text-align: center; padding: 1rem;">
              <div style="font-size: 2rem; font-weight: bold; color: #0ea5e9;">0₺</div>
              <div style="color: var(--text-dark); margin-top: 0.5rem;">Bakım</div>
            </div>
            <div style="text-align: center; padding: 1rem;">
              <div style="font-size: 2rem; font-weight: bold; color: #0ea5e9;">0₺</div>
              <div style="color: var(--text-dark); margin-top: 0.5rem;">Güncelleme</div>
            </div>
          </div>
          
          <div style="background: white; padding: 1.5rem; border-radius: 0.75rem; margin-top: 1rem;">
            <p style="margin: 0; text-align: center; font-size: 1.1rem;">
              <strong>Toplam Tasarruf:</strong> Geleneksel sistemlere göre <span style="color: #ef4444; font-weight: bold;">%85-90 daha ekonomik</span>
            </p>
          </div>
        </section>

        <!-- İç Linkler -->
        <section style="margin-bottom: 3rem;">
          <h2>İlgili Diğer Çözümlerimiz</h2>
          <p style="margin-bottom: 1.5rem;">Bulut teknolojisi ile sunduğumuz diğer çözümler:</p>
          
          <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem;">
            {internalLinks.map((link) => (
              <a 
                href={link.url}
                style="display: block; background: var(--bg-white); padding: 1.25rem; border-radius: 0.75rem; text-decoration: none; color: var(--text-dark); border: 1px solid #e2e8f0; transition: all 0.3s;"
              >
                <div style="display: flex; align-items: center; gap: 1rem;">
                  <div style="font-size: 1.5rem;">☁️</div>
                  <div>
                    <div style="font-weight: bold; color: #0ea5e9; margin-bottom: 0.25rem;">{link.title}</div>
                    <div style="color: var(--text-gray); font-size: 0.9rem;">{link.description}</div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </section>

        <!-- FAQ -->
        <section style="margin-bottom: 3rem;">
          <h2>Bulut Muhasebe Hakkında Sık Sorulan Sorular</h2>
          
          <div style="display: grid; gap: 1rem; margin-top: 1.5rem;">
            {faqItems.map((item) => (
              <div style="background: var(--bg-white); padding: 1.5rem; border-radius: 0.75rem; border: 1px solid #e2e8f0;">
                <h3 style="color: #0ea5e9; margin-top: 0; margin-bottom: 0.75rem;">{item.question}</h3>
                <p style="margin: 0; color: var(--text-dark); line-height: 1.6;">{item.answer}</p>
              </div>
            ))}
          </div>
        </section>

        <!-- CTA -->
        <section style="background: linear-gradient(135deg, #0ea5e9, #3b82f6); padding: 3rem; border-radius: 1rem; text-align: center; color: white;">
          <h2 style="color: white; margin-bottom: 1rem; font-size: 2rem;">Bulut Muhasebe Geçişinizi Planlayalım</h2>
          <p style="margin-bottom: 2rem; font-size: 1.1rem; opacity: 0.9;">
            Ücretsiz analiz ile mevcut sisteminizi değerlendirelim, size özel geçiş planı oluşturalım.
          </p>
          
          <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
            <a 
              href="https://wa.me/+905325000999?text=Merhaba,%20bulut%20muhasebe%20sistemi%20demo%20talep%20ediyorum"
              style="display: inline-flex; align-items: center; justify-content: center; padding: 1rem 2rem; background-color: white; color: #0ea5e9; text-decoration: none; border-radius: 0.5rem; font-weight: 600; gap: 0.5rem; border: none; cursor: pointer;"
              target="_blank"
              rel="noopener noreferrer"
            >
              ☁️ Ücretsiz Demo İste
            </a>
            
            <a 
              href="https://wa.me/+905325000999?text=Merhaba,%20bulut%20muhasebe%20geçiş%20danışmanlığı%20almak%20istiyorum"
              style="display: inline-flex; align-items: center; justify-content: center; padding: 1rem 2rem; background-color: transparent; color: white; text-decoration: none; border-radius: 0.5rem; font-weight: 600; gap: 0.5rem; border: 2px solid white; cursor: pointer;"
              target="_blank"
              rel="noopener noreferrer"
            >
              📋 Geçiş Danışmanlığı Al
            </a>
          </div>
          
          <div style="margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid rgba(255,255,255,0.2);">
            <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;">
              <div>
                <div style="font-size: 1.5rem; margin-bottom: 0.5rem;">🎯</div>
                <div>Ücretsiz Analiz</div>
              </div>
              <div>
                <div style="font-size: 1.5rem; margin-bottom: 0.5rem;">🔄</div>
                <div>Veri Taşıma Desteği</div>
              </div>
              <div>
                <div style="font-size: 1.5rem; margin-bottom: 0.5rem;">👨‍🏫</div>
                <div>Ücretsiz Eğitim</div>
              </div>
            </div>
          </div>
        </section>

      </div>
    </div>
  </main>

  <style>
    :root {
      --border-color: #e5e7eb;
    }
    
    h2 {
      color: #0ea5e9;
      margin-bottom: 1rem;
      font-size: 1.8rem;
    }
    
    h3 {
      color: var(--text-dark);
      margin-bottom: 0.5rem;
    }
    
    p {
      color: var(--text-dark);
      line-height: 1.6;
    }
    
    table {
      border: 1px solid #e2e8f0;
    }
    
    th, td {
      border: 1px solid #e2e8f0;
    }
    
    a:hover {
      transform: translateY(-2px);
      box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    }
    
    @media (max-width: 768px) {
      div[style*="grid-template-columns: repeat(3, 1fr)"] {
        grid-template-columns: repeat(2, 1fr);
      }
      
      div[style*="grid-template-columns: repeat(4, 1fr)"] {
