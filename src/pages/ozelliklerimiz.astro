---
// src/pages/ozelliklerimiz.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const images = {
  // Mevcut görselleriniz
  general: "/images/site-foto/Stok-pratik-genel.png",
  efatura: "/images/site-foto/stok-pratik-efatura.jpg",
  hesap: "/images/site-foto/Stok-pratik-hesap.png",
  crm: "/images/site-foto/crm.webp",
  stok: "/images/site-foto/stok.webp",
  barkod: "/images/site-foto/barkod.webp",
  otoservis: "/images/site-foto/oto-servis.webp",
  hesaplama: "/images/site-foto/Stok-pratik-hesaplama.png",
  hesaplamalar: "/images/site-foto/Stok-pratik-hesaplamalar.png",
  
  // Yeni modüller için görseller
  magaza: "/images/site-foto/Stok-pratik-hesap.png",
  servis: "/images/site-foto/stok-pratik-efatura.jpg",
  uretim: "/images/site-foto/uretim.webp",
  stokpratik: "/images/site-foto/stok-pratik.webp",
  finans: "/images/site-foto/Stok-pratik-hesap.png",
  eticaret: "/images/site-foto/stok-pratik-efatura.jpg",
  rapor: "/images/site-foto/Stok-pratik-hesaplama.png"
};

// Güçlü yönler listesi
const strongFeatures = [
  "🏪 Mağazacılık Bulut Muhasebe",
  "🛒 E-Ticaret",
  "📱 Mobil Uyumlu",
  "📊 Çok Şube Yönetimi",
  "🏷️ Barkodlu Çalışma",
  "🔧 Servis Takibi",
  "🏭 ERP- Üretim Modülü"
];

// Modül kategorileri
const moduleCategories = [
  {
    id: "magaza",
    title: "🏪 Mağazacılık & Perakende",
    features: [
      "Gün Sonu İşlemleri ve Kasa Raporu",
      "Mağaza Stok Takibi ve Sayım",
      "Mağazalar Arası Transfer",
      "POS Ekranı ve Hızlı Satış",
      "Çalışma Takvimi ve Vardiya Yönetimi",
      "Hediye/Kampanya Tanımları"
    ]
  },
  {
    id: "finans",
    title: "💰 Finans & Muhasebe",
    features: [
      "Kasa ve Banka Yönetimi (Anlık Bakiye Takibi)",
      "Kredi Kartı POS Takibi",
      "Çek ve Senet Portföy Yönetimi",
      "Gider Listesi ve Otomatik Giderler",
      "Cari Borç/Alacak Raporları",
      "e-Fatura ve e-Arşiv Entegrasyonu"
    ]
  },
  {
    id: "stok",
    title: "📦 Stok & Ürün Yönetimi",
    features: [
      "Stok Hareketleri (Giriş/Çıkış)",
      "Ürün ve Hizmet Kartları",
      "Kategori ve Marka Yönetimi",
      "Barkodlu Çalışma ve Barkod Okutma",
      "Varlık Takibi ve Demirbaş Yönetimi",
      "Fiyat Listeleri (Müşteri Özel)"
    ]
  },
  {
    id: "eticaret",
    title: "🛒 E-Ticaret & Pazaryeri",
    features: [
      "B2B Sipariş Yönetimi",
      "E-Ticaret Siparişleri Otomatik Aktarım",
      "Kupon ve Kampanya Yönetimi",
      "Misafir Form Takibi",
      "Pazaryeri Entegrasyonu (Trendyol, Hepsiburada, N11)"
    ]
  },
  {
    id: "uretim",
    title: "🏭 Üretim Yönetimi ERP",
    features: [
      "Üretim Emirleri ve Takibi",
      "Reçete/Şablon Yönetimi",
      "Terminal (PWA) ile Üretim Bandı Girişi",
      "Üretim Hatları ve Bilgisayar Takibi",
      "Üretim Maliyet ve Verimlilik Raporları"
    ]
  },
  {
    id: "servis",
    title: "🔧 Servis & Bakım Takibi (Oto Servis)",
    features: [
      "İş Emri Yönetimi (Araç Kabul / İş Başladı / Tamamlandı)",
      "Servis Şablonları (Periyodik Bakım)",
      "TV Board - Bekleme Odası Ekranı",
      "Müşteri ve Araç Geçmişi",
      "Servis Kârlılık Analizi",
      "Plaka ile Müşteri ve Araç Bilgilerini Otomatik Getirme"
    ]
  },
  {
    id: "rapor",
    title: "📊 Raporlama & Analiz",
    features: [
      "Günlük/Aylık Satış Raporları",
      "Satış Analizi ve Çok Satanlar",
      "Ciro ve Kârlılık Raporları",
      "Stok Raporları",
      "Alış Analizi ve KDV Raporları"
    ]
  },
  {
    id: "crm",
    title: "👥 Müşteri İlişkileri (CRM)",
    features: [
      "Potansiyel Müşteri ve Fırsat Takibi",
      "Aktivite ve Görev Yönetimi",
      "Toplu SMS/E-Posta Gönderimi",
      "Müşteri İşlem Geçmişi"
    ]
  }
];
---

<BaseLayout title="Stok Pratik Özelliklerimiz | Tüm Modüller ve Yenilikler">
  <!-- Hero Section -->
<section class="page-hero py-12">
  <div class="container">
    <div class="text-center max-w-4xl mx-auto">
      <h1 class="page-title">Stok Pratik ile Entegrasyon Firmasına Gerek Yok!🚀</h1>
      <h3>Bulut Tabanlı En Hızlı Barkodlu Mağazacılık,</h3>
      <h4>Ön Muhasebe, E-Ticaret ve B2B Yazılımı</h4>
      
      <!-- Hızlı Navigasyon Butonları (Tıklanabilir - Kırmızı Çerçeveli) -->
      <div class="nav-buttons">

        <p class="price-banner-text">
        <a href="#magaza" class="nav-btn">
          <span class="nav-icon">🏪</span>
          Mağazacılık
        </a>
        <a href="#finans" class="nav-btn">
          <span class="nav-icon">💰</span>
          Finans
        </a>
        <a href="#stok" class="nav-btn">
          <span class="nav-icon">📦</span>
          Stok
        </a>
        <a href="#eticaret" class="nav-btn">
          <span class="nav-icon">🛒</span>
          E-Ticaret
        </a>  
        </p>

          <p class="price-banner-text">
          <a href="#uretim" class="nav-btn">
          <span class="nav-icon">🏭</span>
          Üretim
        </a>
        <a href="#servis" class="nav-btn">
          <span class="nav-icon">🔧</span>
          Oto Servis
        </a>
        <a href="#rapor" class="nav-btn">
          <span class="nav-icon">📊</span>
          Raporlama
        </a>
        <a href="#crm" class="nav-btn">
          <span class="nav-icon">👥</span>
          CRM
        </a>
          </p>
        
        
      </div>

      

      <!-- Fiyat Banner -->
      <div class="price-banner">
        <div class="price-banner-content">
          <span class="price-banner-icon">💰</span>
          <p class="price-banner-text">
            Tüm bu özellikler size özel fiyatlarla! Detaylı bilgi ve paket fiyatları için:
          </p>
          <a href="/paketlerimiz" class="btn btn-primary">
            Paketleri İncele
            <span class="btn-arrow">→</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>



  <!-- Fiziksel Mağazanız ve Pazaryeri Aynı Ekranda (İlk versiyondaki bölüm) -->
  <section class="feature-section py-16 bg-gray-50">
    <div class="container">
      <div class="feature-header text-center mb-12">
        <h2 class="feature-title">Fiziksel Mağazanız ve Pazaryeri Aynı Ekranda</h2>
        <p class="feature-description">
          Geleneksel mağaza işlemlerinizi ve online pazaryeri satışlarınızı tek bir platformda birleştirin. 
          Stok, satış ve müşteri takibini merkezi olarak yönetin, verimliliğinizi maksimuma çıkarın.
        </p>
      </div>
      
      <div class="feature-image-full">
        <img 
          src={images.general} 
          alt="Stok Pratik Genel Görünüm" 
          width="1920" 
          height="1080"
          loading="lazy"
          class="feature-img-full"
        />
      </div>
    </div>
  </section>

  <!-- Mağazacılık & Gün Sonu İşlemleri -->
  <section class="feature-section py-16" id="magaza">
    <div class="container">
      <div class="feature-header text-center mb-12">
        <h2 class="feature-title">🏪 Mağazacılık ve Gün Sonu İşlemleri</h2>
        <p class="feature-description">
          Birden fazla mağazanızı tek merkezden yönetin. Gün sonu işlemleri, kasa/banka bakiyeleri, 
          gider takibi ve satış raporlarına anlık erişin.
        </p>
      </div>
      
      <div class="feature-grid-2col">
        <div class="feature-content">
          <div class="feature-list">
            <h3 class="list-title">📋 Gün Sonu İşlemleri</h3>
            <ul>
              <li>✅ Günlük brüt ciro, iade ve net ciro takibi</li>
              <li>✅ Kasa, banka ve POS bakiyeleri tek ekranda</li>
              <li>✅ Gider kategorileri ve anlık gider takibi</li>
              <li>✅ Satış ve iade listeleri detaylı görüntüleme</li>
              <li>✅ Mağaza stok sayımı ve transfer işlemleri</li>
              <li>✅ Çalışma takvimi ve vardiya yönetimi</li>
            </ul>
          </div>
          
          <div class="feature-list mt-6">
            <h3 class="list-title">💳 Hesap Bakiyeleri</h3>
            <ul>
              <li>✅ Banka hesapları anlık bakiye</li>
              <li>✅ Nakit kasa takibi</li>
              <li>✅ POS cihazları bakiyeleri</li>
              <li>✅ Toplam bakiye görüntüleme</li>
            </ul>
          </div>
        </div>
        
        <div class="feature-image">
          <img 
            src={images.barkod} 
            alt="Stok Pratik Mağaza ve Gün Sonu İşlemleri" 
            width="400" 
            height="400"
            loading="lazy"
            class="feature-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Finans & Muhasebe -->
  <section class="feature-section py-16 bg-gray-50" id="finans">
    <div class="container">
      <div class="feature-header text-center mb-12">
        <h2 class="feature-title">💰 Finans & Muhasebe</h2>
        <p class="feature-description">
          Kasa, banka, cari ve e-fatura işlemlerinizi tek merkezden yönetin. Anlık bakiye takibi ve detaylı raporlarla finansal kontrol sizde.
        </p>
      </div>
      
      <div class="feature-grid-2col reversed">
        <div class="feature-image">
          <img 
            src={images.finans} 
            alt="Stok Pratik Finans ve Muhasebe" 
            width="400" 
            height="400"
            loading="lazy"
            class="feature-img"
          />
        </div>
        
        <div class="feature-content">
          <div class="feature-list">
            <ul>
              <li>✅ Kasa ve Banka Yönetimi (Anlık Bakiye Takibi)</li>
              <li>✅ Kredi Kartı POS Takibi</li>
              <li>✅ Çek ve Senet Portföy Yönetimi</li>
              <li>✅ Gider Listesi ve Otomatik Giderler</li>
              <li>✅ Cari Borç/Alacak Raporları</li>
              <li>✅ e-Fatura ve e-Arşiv Entegrasyonu</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Stok & Ürün Yönetimi -->
  <section class="feature-section py-16" id="stok">
    <div class="container">
      <div class="feature-header text-center mb-12">
        <h2 class="feature-title">📦 Stok & Ürün Yönetimi</h2>
        <p class="feature-description">
          Stok hareketlerinizi anlık takip edin, barkodlu çalışma ile ürün giriş/çıkışlarını hızlandırın.
        </p>
      </div>
      
      <div class="feature-grid-2col">
        <div class="feature-content">
          <div class="feature-list">
            <ul>
              <li>✅ Stok Hareketleri (Giriş/Çıkış)</li>
              <li>✅ Ürün ve Hizmet Kartları</li>
              <li>✅ Kategori ve Marka Yönetimi</li>
              <li>✅ Barkodlu Çalışma ve Barkod Okutma</li>
              <li>✅ Varlık Takibi ve Demirbaş Yönetimi</li>
              <li>✅ Fiyat Listeleri (Müşteri Özel)</li>
            </ul>
          </div>
        </div>
        
        <div class="feature-image">
          <img 
            src={images.stok} 
            alt="Stok Pratik Stok Yönetimi" 
            width="400" 
            height="400"
            loading="lazy"
            class="feature-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- E-Ticaret & Pazaryeri -->
  <section class="feature-section py-16 bg-gray-50" id="eticaret">
    <div class="container">
      <div class="feature-header text-center mb-12">
        <h2 class="feature-title">🛒 E-Ticaret & Pazaryeri</h2>
        <p class="feature-description">
          Trendyol, Hepsiburada, N11 gibi pazaryerleriyle entegre çalışın. Siparişler otomatik aktarılsın, stoklar senkronize olsun.
        </p>
      </div>
      
      <div class="feature-grid-2col reversed">
        <div class="feature-image">
          <img 
            src={images.eticaret} 
            alt="Stok Pratik E-Ticaret" 
            width="400" 
            height="400"
            loading="lazy"
            class="feature-img"
          />
        </div>
        
        <div class="feature-content">
          <div class="feature-list">
            <ul>
              <li>✅ B2B Sipariş Yönetimi</li>
              <li>✅ E-Ticaret Siparişleri Otomatik Aktarım</li>
              <li>✅ Kupon ve Kampanya Yönetimi</li>
              <li>✅ Misafir Form Takibi</li>
              <li>✅ Pazaryeri Entegrasyonu (Trendyol, Hepsiburada, N11)</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Üretim Yönetimi -->
  <section class="feature-section py-16" id="uretim">
    <div class="container">
      <div class="feature-header text-center mb-12">
        <h2 class="feature-title">🏭 Üretim Yönetimi ERP</h2>
        <p class="feature-description">
          Hammadde girişinden mamul çıkışına kadar tüm üretim süreçlerini dijitalleştirin.
        </p>
      </div>
      
      <div class="feature-grid-2col">
        <div class="feature-content">
          <div class="feature-list">
            <ul>
              <li>✅ Üretim Emirleri ve Durum Takibi</li>
              <li>✅ Reçete/Şablon Yönetimi</li>
              <li>✅ Terminal (PWA) ile Üretim Bandı Girişi</li>
              <li>✅ Üretim Hatları ve Bilgisayar Takibi</li>
              <li>✅ Maliyet ve Verimlilik Raporları</li>
            </ul>
          </div>
        </div>
        
        <div class="feature-image">
          <img 
            src={images.uretim} 
            alt="Stok Pratik Üretim Yönetimi" 
            width="400" 
            height="400"
            loading="lazy"
            class="feature-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Oto Servis ve Bakım Takibi -->
  <section class="feature-section py-16 bg-gray-50" id="servis">
    <div class="container">
      <div class="feature-header text-center mb-12">
        <h2 class="feature-title">🔧 Oto Servis ve Bakım Takibi</h2>
        <p class="feature-description">
          Araç kabulünden iş emri oluşturmaya, parça stok takibinden bekleme odası TV ekranına kadar 
          tüm servis süreçlerinizi dijitalleştirin.
        </p>
      </div>
      
      <div class="feature-grid-2col reversed">
        <div class="feature-image">
          <img 
            src={images.otoservis} 
            alt="Stok Pratik Oto Servis Yönetimi" 
            width="400" 
            height="400"
            loading="lazy"
            class="feature-img"
          />
        </div>
        
        <div class="feature-content">
          <div class="feature-list">
            <h3 class="list-title">🛠️ Servis Özellikleri</h3>
            <ul>
              <li>✅ İş Emri Yönetimi (Araç Kabul / İş Başladı / Tamamlandı)</li>
              <li>✅ Plaka ile müşteri ve araç bilgilerini otomatik getirme</li>
              <li>✅ Periyodik bakım şablonları (10.000 km yağ bakımı vb.)</li>
              <li>✅ TV Board - Müşteri bekleme odası ekranı</li>
              <li>✅ Müşteri ve araç geçmişi (tüm işlemler)</li>
              <li>✅ Servis kârlılık analizi ve ciro takibi</li>
              <li>✅ Yedek parça stok takibi ve otomatik düşüm</li>
            </ul>
          </div>
          
          <div class="stats-grid mt-6">
            <div class="stat-card">
              <div class="stat-value">1.adım</div>
              <div class="stat-label">İş Emrini Aç, Aşamaları Kaydet</div>
            </div>
            <div class="stat-card">
              <div class="stat-value">2.adım</div>
              <div class="stat-label">Durumunu Güncelle</div>
            </div>
            <div class="stat-card">
              <div class="stat-value">3.adım</div>
              <div class="stat-label">Müşteri heryerden takip etsin</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Raporlama & Analiz -->
  <section class="feature-section py-16" id="rapor">
    <div class="container">
      <div class="feature-header text-center mb-12">
        <h2 class="feature-title">📊 Raporlama & Analiz</h2>
        <p class="feature-description">
          İşletmenizin performansını anlık raporlarla takip edin, veri odaklı kararlar alın.
        </p>
      </div>
      
      <div class="feature-grid-2col">
        <div class="feature-content">
          <div class="feature-list">
            <ul>
              <li>✅ Günlük/Aylık Satış Raporları</li>
              <li>✅ Satış Analizi ve Çok Satanlar</li>
              <li>✅ Ciro ve Kârlılık Raporları</li>
              <li>✅ Stok Raporları</li>
              <li>✅ Alış Analizi ve KDV Raporları</li>
            </ul>
          </div>
        </div>
        
        <div class="feature-image">
          <img 
            src={images.rapor} 
            alt="Stok Pratik Raporlama" 
            width="400" 
            height="400"
            loading="lazy"
            class="feature-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Müşteri İlişkileri (CRM) -->
  <section class="feature-section py-16 bg-gray-50" id="crm">
    <div class="container">
      <div class="feature-header text-center mb-12">
        <h2 class="feature-title">👥 Müşteri İlişkileri (CRM)</h2>
        <p class="feature-description">
          Müşterilerinizle ilişkilerinizi güçlendirin, satış süreçlerinizi yönetin.
        </p>
      </div>
      
      <div class="feature-grid-2col reversed">
        <div class="feature-image">
          <img 
            src={images.crm} 
            alt="Stok Pratik CRM" 
            width="400" 
            height="400"
            loading="lazy"
            class="feature-img"
          />
        </div>
        
        <div class="feature-content">
          <div class="feature-list">
            <ul>
              <li>✅ Potansiyel Müşteri ve Fırsat Takibi</li>
              <li>✅ Aktivite ve Görev Yönetimi</li>
              <li>✅ Toplu SMS/E-Posta Gönderimi</li>
              <li>✅ Müşteri İşlem Geçmişi</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- E-Fatura Section -->
  <section class="feature-section py-16" id="efatura">
    <div class="container">
      <div class="feature-header text-center mb-12">
        <h2 class="feature-title">e-Fatura Entegrasyonlarımız</h2>
        <p class="feature-description">
          Stok Pratik ile e-fatura süreçlerinizi otomatikleştirin. Tüm fatura işlemlerinizi hızlı, 
          güvenli ve hatasız şekilde yönetin.
        </p>
      </div>
      <div class="feature-image-full">
        <img 
          src={images.efatura} 
          alt="Stok Pratik e-Fatura Entegrasyonu" 
          width="1920" 
          height="1080"
          loading="lazy"
          class="feature-img-full"
        />
      </div>
    </div>
  </section>

  <!-- Neden Stok Pratik Section -->
  <section class="why-section py-16 bg-gray-50">
    <div class="container">
      <div class="section-header text-center mb-12">
        <h2 class="section-title">Neden Stok Pratik</h2>
        <p class="section-subtitle">
          İşletmenizi büyütmek için ihtiyacınız olan tüm araçlar tek platformda
        </p>
      </div>

      <!-- Feature 1 -->
      <div class="why-feature">
        <div class="why-grid">
          <div class="why-image">
            <img 
              src={images.stokpratik} 
              alt="Stok Pratik Stok Takip ve İş Yönetimi" 
              width="400" 
              height="400"
              loading="lazy"
              class="why-img"
            />
          </div>
          <div class="why-content">
            <div class="why-icon">💡</div>
            <h3 class="why-title">"Stok Takibi Pratik, <br>İş Yönetimi Daha Kolay!"</h3>
            <p class="why-description">
              Stok Pratik, işletmenizin tüm süreçlerini dijitalleştiren, kurulum gerektirmeyen ve her cihazdan anında erişilebilen bulut tabanlı yönetim yazılımıdır.
            </p>
            
            <div class="why-benefits">
              <div class="benefit-item">
                <span class="benefit-icon">✅</span>
                <div>
                  <strong>Kurulum Gerekmez</strong>
                  <p>Sadece internete bağlanın, hemen kullanmaya başlayın.</p>
                </div>
              </div>
              <div class="benefit-item">
                <span class="benefit-icon">📱</span>
                <div>
                  <strong>Tüm Cihazlardan Erişim</strong>
                  <p>Telefon, tablet, bilgisayar… İnternet olduğu her yerden 7/24 erişim.</p>
                </div>
              </div>
              <div class="benefit-item">
                <span class="benefit-icon">🔐</span>
