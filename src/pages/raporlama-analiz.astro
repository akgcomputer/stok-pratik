    frequency: "Günlük/Haftalık/Aylık"
  },
  {
    icon: "📦",
    title: "Stok Raporları",
    reports: ["Stok Durumu", "En Çok Satanlar", "Slow-Moving", "ABC Analizi", "Stok Devir Hızı"],
    frequency: "Anlık/Günlük"
  },
  {
    icon: "💰",
    title: "Satış Raporları",
    reports: ["Satış Performansı", "Müşteri Segmentasyonu", "Bölgesel Analiz", "Kampanya ROI", "Satış Tahmini"],
    frequency: "Anlık/Günlük"
  },
  {
    icon: "👥",
    title: "Müşteri Raporları",
    reports: ["Müşteri Segmentasyonu", "CLV Analizi", "Şikayet Analizi", "Memnuniyet Raporu", "Tekrar Satış Oranı"],
    frequency: "Haftalık/Aylık"
  },
  {
    icon: "👷",
    title: "Personel Raporları",
    reports: ["Performans Analizi", "İş Yükü Dağılımı", "Prim Hesaplama", "Eğitim İhtiyacı", "Başarı Oranları"],
    frequency: "Aylık/Çeyrek"
