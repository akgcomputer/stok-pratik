---
// src/pages/raporlama-analiz.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/variables.css';
import '../styles/global.css';
import '../styles/components.css';

// İç linkler için data
const internalLinks = [
  { 
    title: "ERP Sistemi", 
    url: "/erp-sistemi",
    icon: "🔄",
    description: "Entegre raporlama ve analiz modülleri"
  },
  { 
    title: "Stok Takip Sistemi", 
    url: "/stok-takip-sistemi",
    icon: "📦",
    description: "Stok hareketleri ve envanter analizleri"
  },
  { 
    title: "Satış Yönetimi", 
    url: "/satis-yonetimi",
    icon: "💰",
    description: "Satış performansı ve müşteri analizleri"
