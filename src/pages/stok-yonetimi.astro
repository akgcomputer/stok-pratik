<script>
  // Demo form submit handler
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('stockDemoForm');
    
    if (form) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        
        // Form verilerini al
        const formData = new FormData(form);
        const data = Object.fromEntries(formData);
        
        // WhatsApp mesajı oluştur
        const message = `Merhaba, Stok Yönetim Sistemi demo talebim var:\n\n` +
                       `Ad Soyad: ${data.name}\n` +
                       `Firma: ${data.company}\n` +
                       `Telefon: ${data.phone}\n` +
                       `E-posta: ${data.email}\n` +
                       `Sektör: ${data.sector}\n` +
                       `Ürün Sayısı: ${data.product_count || 'Belirtilmedi'}\n` +
                       `Stok Problemi: ${data.current_problem || 'Belirtilmedi'}`;
        
        // WhatsApp URL'si
        const whatsappUrl = `https://wa.me/+905325000999?text=${encodeURIComponent(message)}`;
        
        // WhatsApp'ı aç
        window.open(whatsappUrl, '_blank');
        
        // Formu temizle
        form.reset();
        
        // Teşekkür mesajı göster
        alert('Demo talebiniz alındı! WhatsApp üzerinden yönlendiriliyorsunuz.');
      });
    }
  });
</script>