.scroll-to-top {
  position: fixed;
  bottom: 30px;
  left: 30px;  /* right: 30px yerine left: 30px */
  width: 50px;
  height: 50px;
  background: var(--primary-red);
  color: white;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  box-shadow: var(--shadow-lg);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s ease;
  z-index: 1000;
}

.scroll-to-top.visible {
  opacity: 1;
  visibility: visible;
}

.scroll-to-top:hover {
  background: var(--primary-red-dark);
  transform: translateY(-5px);
  box-shadow: var(--shadow-xl);
}

.scroll-icon {
  font-size: 1.8rem;
  font-weight: bold;
  line-height: 1;
}

/* Responsive */
@media (max-width: 768px) {
  .scroll-to-top {
    bottom: 20px;
    left: 20px;  /* right: 20px yerine left: 20px */
    width: 45px;
    height: 45px;
  }
  
  .scroll-icon {
    font-size: 1.5rem;
  }
}

@media (max-width: 480px) {
  .scroll-to-top {
    bottom: 15px;
    left: 15px;  /* right: 15px yerine left: 15px */
    width: 40px;
    height: 40px;
  }
  
  .scroll-icon {
    font-size: 1.3rem;
  }
}
  </style>
  <script>
  // Sayfa yüklendiğinde tüm detayları kapat
  document.addEventListener('DOMContentLoaded', function() {
    // Tüm feature-details ve feature-subdetails elementlerini bul
    const details = document.querySelectorAll('.feature-details, .feature-subdetails');
    
    // Her birinden open attribute'unu kaldır
    details.forEach(detail => {
      detail.removeAttribute('open');
    });
  });
</script>

<!-- Yukarı Çık Butonu -->
<a href="#" class="scroll-to-top" id="scrollToTop" aria-label="Sayfa Başına Çık">
  <span class="scroll-icon">↑</span>
</a>

<script>
  // Yukarı çık butonu için scroll olayı
  document.addEventListener('DOMContentLoaded', function() {
    const scrollButton = document.getElementById('scrollToTop');
    
    // Scroll olayını dinle
    window.addEventListener('scroll', function() {
      if (window.scrollY > 300) {
        scrollButton.classList.add('visible');
      } else {
        scrollButton.classList.remove('visible');
      }
    });
    
    // Butona tıklandığında yumuşak scroll
    scrollButton.addEventListener('click', function(e) {
      e.preventDefault();
      window.scrollTo({
        top: 0,
        behavior: 'smooth'
      });
    });
  });
</script>

