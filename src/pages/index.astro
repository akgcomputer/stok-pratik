---
// src/pages/index.astro
import BaseLayout from '../layouts/BaseLayout.astro';

const heroImage = "/images/hero-image.jpg";
const featuresImage = "/images/features.jpg";
const erpDashboard = "/images/erp-dashboard.jpg";
const mainImage = "/images/site-foto/Stok-pratik-33.png";
---

<BaseLayout title="Stok Pratik - İşinizi Büyütün, Şirketinizin Geleceğini Planlayın">
  <!-- Main Features Section -->
 
  <section class="main-features py-12">
  <div class="container">
    <!-- Üst Banner - Marka ve Fiyat -->
    <div class="hero-banner">
      <div class="hero-banner-content">
        <h2 class="hero-brand">Stok Pratik</h2>
        <h3 class="hero-tagline">Bulut Tabanlı En Hızlı Çalışan, Barkodlu Mağazacılık, E-Ticaret ve Ön Muhasebe Yazılımı</h3>
        <div class="hero-price price-pulse">
          <a href="/paketlerimiz" class="hero-price-link pulse-link">
            <span class="hero-price-number pulse-text">149₺'ye</span>
            <span class="hero-price-text pulse-text">tüm süreçlerini yönet</span>
          </a>
        </div>
      </div>
    </div>


    <!-- Ana İçerik Grid -->
    <div class="content-grid">
      <!-- Sol Kolon - Güçlü Yönler -->
      <div class="features-left">
        <h4 class="features-title">🎯 Güçlü Yönlerimiz</h4>
        
        <div class="features-grid-2col">
          <!-- Barkodlu Mağazacılık -->
          <div class="feature-card">
            <div class="feature-card-header">
              <span class="feature-card-icon">🏪</span>
              <strong>Barkodlu Mağazacılık</strong>
            </div>
            <p class="feature-card-text">İster tek, ister çok şubeli mağaza yönetiminizi kolaylaştıran entegre çözüm</p>
            <div class="feature-card-links">
              <a href="/ozelliklerimiz#magaza" class="card-link">Tüm Özellikler <span class="link-arrow">›</span></a>
              <a href="/paketlerimiz" class="feature-link2">Paketler <span class="link-arrow">›</span></a>
            </div>
          </div>

          <!-- ERP + CRM -->
          <div class="feature-card">
            <div class="feature-card-header">
              <span class="feature-card-icon">🔄</span>
              <strong>ERP Üretim + CRM</strong>
            </div>
            <p class="feature-card-text">ERP Kurumsal kaynak planlama ile tüm süreçleri yönetin, CRM ile satış süreçlerinizi optimize edin.</p>
            <div class="feature-card-links">
              <a href="/ozelliklerimiz#uretim" class="card-link">Tüm Özellikler <span class="link-arrow">›</span></a>
              <a href="/paketlerimiz" class="feature-link2">Paketler <span class="link-arrow">›</span></a>
            </div>
          </div>

          <!-- E-Ticaret + B2B -->
          <div class="feature-card">
            <div class="feature-card-header">
              <span class="feature-card-icon">🛒</span>
              <strong>Entegrasyonsuz <br>E-Ticaret + B2B</strong>
            </div>
            <p class="feature-card-text">Online satışlarınızı tek platformdan yönetin, hiçbir aracı yazılım-firma gerekmez.</p>
            <div class="feature-card-links">
              <a href="/ozelliklerimiz#eticaret" class="card-link">Tüm Özellikler <span class="link-arrow">›</span></a>
              <a href="/paketlerimiz" class="feature-link2">Paketler <span class="link-arrow">›</span></a>
            </div>
          </div>

          <!-- Bulut Ön Muhasebe -->
          <div class="feature-card">
            <div class="feature-card-header">
              <span class="feature-card-icon">☁️</span>
              <strong>Bulut Ön Muhasebe</strong>
            </div>
            <p class="feature-card-text">Her yerden erişilebilir, güvenli muhasebe, E-Fatura E-İrsaliye süreçlerinizi yönetin.</p>
            <div class="feature-card-links">
              <a href="/ozelliklerimiz#finans" class="card-link">Tüm Özellikler <span class="link-arrow">›</span></a>
              <a href="/paketlerimiz" class="feature-link2">Paketler <span class="link-arrow">›</span></a>
            </div>
          </div>

          <!-- Mobil Uyumlu -->
          <div class="feature-card">
            <div class="feature-card-header">
              <span class="feature-card-icon">📱</span>
              <strong>Mobil Uyumlu</strong>
            </div>
            <p class="feature-card-text">İstediğiniz cihazdan, internetin olduğu her yerden 24 saat erişim</p>
            <div class="feature-card-links">
              <a href="/ozelliklerimiz" class="card-link">Tüm Özellikler <span class="link-arrow">›</span></a>
              <a href="/paketlerimiz" class="feature-link2">Paketler <span class="link-arrow">›</span></a>
            </div>
          </div>

          <!-- Çok Depo/Şube -->
          <div class="feature-card">
            <div class="feature-card-header">
              <span class="feature-card-icon">📊</span>
              <strong>Çok Depo ve Şube Yönetimi</strong>
            </div>
            <p class="feature-card-text">Tüm şubelerinizi ve depolarınızı merkezi olarak yönetin</p>
            <div class="feature-card-links">
              <a href="/ozelliklerimiz#magaza" class="card-link">Tüm Özellikler <span class="link-arrow">›</span></a>
              <a href="/paketlerimiz" class="feature-link2">Paketler <span class="link-arrow">›</span></a>
            </div>
          </div>

          <!-- Oto Servis -->
          <div class="feature-card feature-card-full">
            <div class="feature-card-header">
              <span class="feature-card-icon">🚗</span>
              <strong>Oto Servis ve Yedek Parça Yönetimi</strong>
            </div>
            <p class="feature-card-text">Plaka-Şase ile İş emri sistemi, Barkod sistemi ile hızlı ve hatasız işlemler, online müşteri bildirimleri</p>
            <div class="feature-card-links">
              <a href="/ozelliklerimiz#servis" class="card-link">Tüm Özellikler <span class="link-arrow">›</span></a>
              <a href="/paketlerimiz" class="feature-link2">Paketler <span class="link-arrow">›</span></a>
            </div>
          </div>
        </div>

        <!-- Butonlar -->
        <div class="action-buttons">
          <a href="https://wa.me/+905325000999?text=Merhaba,%20Stok%20Pratik%20demo%20talep%20ediyorum" 
             class="btn btn-primary">
            Demo Talep Et
            <span class="btn-subtext">WhatsApp ile Görüş</span>
          </a>
          
          <a href="https://wa.me/+905325000999?text=Merhaba,%20Stok%20Pratik%20fiyat%20teklifi%20alıyorum" 
             class="btn btn-outline">
            Fiyat Teklifi Al
            <span class="btn-subtext">WhatsApp ile Görüş</span>
          </a>
        </div>
      </div>

      <!-- Sağ Kolon - Görsel -->
      <div class="features-right">
        <div class="image-wrapper">
          <img 
            src={mainImage} 
            alt="Stok Pratik Stok ve Muhasebe Yazılımı" 
            width="650" 
            height="825"
            loading="lazy"
            class="feature-main-image"
          />
        </div>
      </div>
    </div>
  </div>
</section>
  

  <!-- CTA Section -->
  <section class="cta-section py-16">
    <div class="container text-center">
      <h2>Hazır mısınız?  <br>Şimdi İşletmenizi Dijitalleştirin!</h2>
      <p>Stok Pratik Online Muhasebe, Mağazacılık ve ERP ile iş süreçlerinizi optimize edin, zaman ve maliyet tasarrufu sağlayın.</p>
      <a href="/paketlerimiz" class="btn btn-primary">Paketleri inceleyin</a>
    </div>
  </section>

  <!-- Hero Section -->
  <section class="hero py-16">
    <div class="container">
      <div class="hero-content text-center">
        <h1>İşinizi Büyütün, Şirketinizin Geleceğini Planlayın</h1>
        <p class="hero-subtitle">
          Stok Pratik Online Muhasebe, Mağazacılık ve ERP ile üretim süreçlerinizi dijitalleştirin, verimliliğinizi katlayın. 
          Gerçek zamanlı takip, entegre yönetim ve sınırsız fırsatlarla işletmenizin potansiyelini en üst seviyeye çıkarın.
        </p>
        <a href="/ozelliklerimiz" class="btn btn-primary">Bugün Deneyin, Farkı Yaşayın!, <br>Özellikleri inceleyin</a>
        
       
      </div>
    </div>
  </section>

  <style>

    /* Hero Banner */
.hero-banner {
  background: linear-gradient(135deg, var(--primary-red-light) 0%, white 100%);
  border-radius: var(--radius-lg);
  padding: 2rem;
  margin-bottom: 2rem;
  box-shadow: var(--shadow-md);
}

.hero-banner-content {
  text-align: center;
}

.hero-brand {
  font-size: 2.5rem;
  color: var(--primary-red);
  margin-bottom: 0.5rem;
  font-weight: 800;
}

.hero-tagline {
  font-size: 1.1rem;
  color: var(--text-gray);
  margin-bottom: 1rem;
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
}

.hero-price-link {
  display: inline-flex;
  align-items: baseline;
  text-decoration: none;
  background: white;
  padding: 0.75rem 2rem;
  border-radius: 50px;
  box-shadow: var(--shadow-md);
  transition: all 0.3s ease;
}

.hero-price-link:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-lg);
}

.hero-price-number {
  font-size: 2rem;
  font-weight: 800;
  color: var(--primary-red);
  margin-right: 0.5rem;
}

.hero-price-text {
  font-size: 1.2rem;
  color: var(--text-dark);
  font-weight: 600;
}

/* Content Grid */
.content-grid {
  display: grid;
  grid-template-columns: 1fr 400px;
  gap: 2rem;
}

/* Features Grid */
.features-grid-2col {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1rem;
  margin-bottom: 2rem;
}

.feature-card {
  background: white;
  border-radius: var(--radius-lg);
  padding: 1.25rem;
  box-shadow: var(--shadow-sm);
  border: 1px solid var(--secondary-light);
  transition: all 0.3s ease;
}

.feature-card:hover {
  transform: translateY(-3px);
  box-shadow: var(--shadow-md);
  border-color: var(--primary-red-light);
}

.feature-card-full {
  grid-column: span 2;
}

.feature-card-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 0.75rem;
}

.feature-card-icon {
  font-size: 1.5rem;
}

.feature-card-header strong {
  font-size: 1rem;
  color: var(--text-dark);
}

.feature-card-text {
  font-size: 0.9rem;
  color: var(--text-gray);
  line-height: 1.5;
  margin-bottom: 1rem;
}

.feature-card-links {
  display: flex;
  gap: 1rem;
  border-top: 1px dashed var(--secondary-light);
  padding-top: 0.75rem;
}

.card-link {
  color: var(--primary-red);
  text-decoration: none;
  font-size: 0.85rem;
  font-weight: 600;
  display: inline-flex;
  align-items: center;
  transition: all 0.3s ease;
}

.card-link:hover {
  color: var(--primary-red-dark);
  transform: translateX(3px);
}

/* Action Buttons */
.action-buttons {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin-top: 1rem;
}

.action-buttons .btn {
  flex: 1;
  max-width: 250px;
}

/* Right Column */
.features-right {
  position: sticky;
  top: 100px;
  align-self: start;
}

.image-wrapper {
  background: white;
  border-radius: var(--radius-lg);
  padding: 1rem;
  box-shadow: var(--shadow-lg);
  border: 1px solid var(--secondary-light);
}

.feature-main-image {
  width: 100%;
  height: auto;
  border-radius: var(--radius-md);
  display: block;
}

/* Responsive */
@media (max-width: 1200px) {
  .content-grid {
    grid-template-columns: 1fr 350px;
  }
}

@media (max-width: 992px) {
  .content-grid {
    grid-template-columns: 1fr;
  }
  
  .features-right {
    display: none;
  }
  
  .features-grid-2col {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .hero-brand {
    font-size: 2rem;
  }
  
  .hero-price-number {
    font-size: 1.5rem;
  }
  
  .hero-price-text {
    font-size: 1rem;
  }
  
  .features-grid-2col {
    grid-template-columns: 1fr;
  }
  
  .feature-card-full {
    grid-column: span 1;
  }
  
  .action-buttons {
    flex-direction: column;
    align-items: center;
  }
  
  .action-buttons .btn {
    max-width: 100%;
    width: 100%;
  }
}
    /* Kalp atışı efekti */
.price-pulse {
  margin-bottom: 1.5rem;
  text-align: center;
}

.pulse-link {
  display: inline-block;
  text-decoration: none;
  animation: pulse 2s infinite;
}

.pulse-text {
  font-size: 3rem;
  font-weight: 800;
  color: var(--primary-red);
  margin-right: 0.5rem;
  display: inline-block;
}

.pulse-link span:last-child {
  font-size: 1.5rem;
  color: var(--text-dark);
  font-weight: 600;
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
  100% {
    transform: scale(1);
  }
}

/* Feature linkler */
.feature-links {
  margin-top: 0.75rem;
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
}

.feature-link {
  color: var(--primary-red);
  text-decoration: none;
  font-weight: 600;
  font-size: 0.9rem;
  display: inline-flex;
  align-items: center;
  transition: all 0.3s ease;
  border-bottom: 1px dashed var(--primary-red-light);
  padding-bottom: 2px;
}
.feature-link2 {
  color: blue;
  text-decoration: none;
  font-weight: 600;
  font-size: 0.9rem;
  display: inline-flex;
  align-items: center;
  transition: all 0.3s ease;
  border-bottom: 1px dashed var(--primary-red-light);
  padding-bottom: 2px;
}

.feature-link:hover {
  color: var(--primary-red-dark);
  border-bottom-color: var(--primary-red-dark);
  transform: translateX(3px);
}

.link-arrow {
  color: rgb(0, 0, 0);
  font-size: 1.2rem;
  margin-left: 0.25rem;
  transition: transform 0.3s ease;
}

.feature-link:hover .link-arrow {
  transform: translateX(3px);
}

/* Responsive */
@media (max-width: 768px) {
  .pulse-text {
    font-size: 2.5rem;
  }
  
  .pulse-link span:last-child {
    font-size: 1.2rem;
  }
  
  .feature-links {
    gap: 1rem;
  }
}

@media (max-width: 480px) {
  .pulse-text {
    font-size: 2rem;
  }
  
  .pulse-link span:last-child {
    font-size: 1rem;
  }
  
  .feature-links {
    flex-direction: column;
    gap: 0.5rem;
  }
}
    /* Hero Section */
    .hero {
      background: linear-gradient(135deg, var(--primary-red-light) 0%, var(--bg-white) 100%);
    }

    .hero-content {
      max-width: 800px;
      margin: 0 auto;
    }

    .hero h1 {
      background: linear-gradient(135deg, var(--primary-red), var(--primary-red-dark));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: var(--spacing-md);
    }

    .hero-subtitle {
      font-size: 1.25rem;
      color: var(--text-gray);
      margin-bottom: var(--spacing-lg);
    }

    .hero-features {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: var(--spacing-lg);
      margin-top: var(--spacing-xl);
    }

    .feature-card {
      background: var(--bg-white);
      padding: var(--spacing-xl);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-md);
      text-align: center;
      transition: transform var(--transition-normal);
    }

    .feature-card:hover {
      transform: translateY(-5px);
    }

    .feature-card .feature-icon {
      width: 60px;
      height: 60px;
      background: var(--primary-red);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto var(--spacing-md);
      font-size: 1.5rem;
      color: white;
    }

    /* Main Features Section */
    .main-features {
      background-color: var(--bg-white);
    }

    .features-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--spacing-xl);
      align-items: center;
    }

    @media (min-width: 992px) {
      .features-grid {
        grid-template-columns: 1fr 1fr;
        gap: var(--spacing-xl);
      }
    }

    .brand-header {
      margin-bottom: var(--spacing-xl);
    }

    .brand-name {
      font-size: 3rem;
      font-weight: 800;
      color: var(--primary-red);
      margin-bottom: 0.5rem;
      line-height: 1;
    }

    .brand-tagline {
      font-size: 1.5rem;
      color: var(--text-dark);
      font-weight: 600;
      line-height: 1.3;
    }

    .features-title {
      font-size: 1.75rem;
      color: var(--text-dark);
      margin-bottom: var(--spacing-lg);
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .features-list {
      list-style: none;
      margin: var(--spacing-lg) 0;
    }

    .features-list li {
      display: flex;
      align-items: flex-start;
      gap: var(--spacing-md);
      padding: var(--spacing-md) 0;
      border-bottom: 1px solid var(--secondary-light);
    }

    .features-list li:last-child {
      border-bottom: none;
    }

    .features-list .feature-icon {
      font-size: 1.75rem;
      flex-shrink: 0;
      width: 50px;
      text-align: center;
    }

    .features-list strong {
      font-size: 1.1rem;
      color: var(--text-dark);
      display: block;
      margin-bottom: 0.25rem;
    }

    .features-list p {
      color: var(--text-gray);
      font-size: 0.95rem;
      margin: 0;
    }

    .feature-buttons {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: var(--spacing-md);
      margin-top: var(--spacing-xl);
    }

    .btn {
      position: relative;
      overflow: hidden;
    }

    .btn-red {
      background: linear-gradient(135deg, #dc2626, #f97316);
      border-color: #dc2626;
    }

    .btn-red:hover {
      background: linear-gradient(135deg, #b91c1c, #ea580c);
      border-color: #b91c1c;
    }

    .btn-green {
      background: linear-gradient(135deg, #059669, #10b981);
      border-color: #059669;
    }

    .btn-green:hover {
      background: linear-gradient(135deg, #047857, #0d9488);
      border-color: #047857;
    }

    .btn-subtext {
      display: block;
      font-size: 0.85rem;
      opacity: 0.9;
      margin-top: 0.25rem;
      font-weight: normal;
    }

    .features-image {
      text-align: center;
    }

    .features-image img {
      max-width: 100%;
      height: auto;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      border: 8px solid white;
    }

    @media (min-width: 992px) {
      .features-image img {
        max-width: 650px;
        max-height: 825px;
      }
    }

    /* Benefits Section */
    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--spacing-xl);
      align-items: center;
    }

    .benefits-list {
      list-style: none;
      margin: var(--spacing-lg) 0;
    }

    .benefits-list li {
      padding: var(--spacing-xs) 0;
      padding-left: var(--spacing-lg);
      position: relative;
    }

    .benefits-list li::before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--primary-red);
      font-weight: bold;
      font-size: 1.2rem;
    }

    .benefits-image {
      text-align: center;
    }

    .benefits-image img {
      max-width: 100%;
      height: auto;
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
    }

    .cta-buttons {
      display: flex;
      gap: var(--spacing-md);
      margin-top: var(--spacing-lg);
    }

    /* Pricing Section */
    .pricing {
      background-color: var(--primary-red-light);
    }

    .pricing-header p {
      font-size: 1.125rem;
      margin-bottom: var(--spacing-xl);
    }

    .pricing-cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--spacing-lg);
      max-width: 1000px;
      margin: 0 auto;
    }

    .pricing-card {
      background: var(--bg-white);
      padding: var(--spacing-xl);
      border-radius: var(--radius-lg);
      text-align: center;
      box-shadow: var(--shadow-md);
      position: relative;
      transition: transform var(--transition-normal);
    }

    .pricing-card:hover {
      transform: translateY(-5px);
    }

    .pricing-card.featured {
      border: 3px solid var(--primary-red);
    }

    .pricing-card.featured::before {
      content: "POPÜLER";
      position: absolute;
      top: -15px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--primary-red);
      color: white;
      padding: 5px 20px;
      border-radius: var(--radius-full);
      font-size: 0.875rem;
      font-weight: 600;
    }

    .price {
      font-size: 3rem;
      font-weight: 800;
      color: var(--primary-red);
      margin: var(--spacing-md) 0;
    }

    .price-features {
      list-style: none;
      margin: var(--spacing-lg) 0;
    }

    .price-features li {
      padding: var(--spacing-xs) 0;
      border-bottom: 1px solid var(--secondary-light);
    }

    .price-features li:last-child {
      border-bottom: none;
    }

