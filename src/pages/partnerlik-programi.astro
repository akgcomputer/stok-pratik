---
// src/pages/partnerlik-programi.astro
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Partnerlik Programı - Stok Pratik ERP">
  <!-- Hero Section -->
  <section class="hero py-16">
    <div class="container">
      <div class="hero-content text-center">
        <h1>Stok Pratik Partner</h1>
        <h2 class="hero-subtitle">Satış Partnerimiz Ol Birlikte Kazanalım</h2>
        <p class="hero-description">
          Bugüne kadar onlarca firma tarafından tercih edilen Stok Pratik 
          altyapısını satarak gelirlerinizi arttırın.
        </p>
        <a href="#basvur" class="btn btn-primary btn-lg">Hemen Partner Ol</a>
      </div>
    </div>
  </section>

  <!-- Avantajlar Grid -->
  <section class="advantages py-16">
    <div class="container">
      <div class="section-header text-center">
        <h2>Neden Stok Pratik Partneri Olmalısınız?</h2>
        <p>İş ortaklığı programımızın avantajlarını keşfedin</p>
      </div>

      <div class="advantages-grid">
        <div class="advantage-card">
          <div class="advantage-icon">💰</div>
          <h3>Yüksek Komisyon</h3>
          <p>Stok Pratik'in sunduğu cazip komisyon oranlarıyla ortaklığınızı kazançlı bir iş modeline dönüştürün.</p>
        </div>

        <div class="advantage-card">
          <div class="advantage-icon">📈</div>
          <h3>Yüksek Gelir Fırsatı</h3>
          <p>Ayda 200.000 TL'ye varan gelir fırsatları sunan iş ortaklığı programıyla hedeflerinize ulaşın.</p>
        </div>

        <div class="advantage-card">
          <div class="advantage-icon">🏆</div>
          <h3>Marka Bilinirliği</h3>
          <p>Binlerce mutlu müşteriyle Stok Pratik, stok ve muhasebe yazılımlarının güvenilir ismidir.</p>
        </div>

        <div class="advantage-card">
          <div class="advantage-icon">🚀</div>
          <h3>Sektörde Olmayan Özellikler</h3>
          <p>Stok Pratik'in sektördeki birçok rakibinden ayıran özellikler, 
            iş ortaklarına güvenilirlik ve yüksek kazanç fırsatları sunuyor.</p>
        </div>

        <div class="advantage-card">
          <div class="advantage-icon">🎓</div>
          <h3>Partner Eğitimleri ve Pazarlama Desteği</h3>
          <p>Stok Pratik, iş ortaklarına özel eğitimlerle sektörel bilgi ve satış becerilerini geliştirme fırsatı sunuyor.</p>
        </div>

        <div class="advantage-card">
          <div class="advantage-icon">🤝</div>
          <h3>CRM Desteği ile Müşteri Takibi</h3>
          <p>Stok Pratik, iş ortaklarına sunduğu CRM desteğiyle müşteri yönetimini kolaylaştırır ve verimliliği artırır.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Motivasyon Sections -->
  <section class="motivation py-16">
    <div class="container">
      <div class="motivation-grid">
        <div class="motivation-card">
          <div class="motivation-content">
            <h2>Sen de Partner Ol Birlikte Büyüyelim</h2>
            <p>
              Stok ve muhasebe yazılımı sektörünün öncüsü Stok Pratik'in partneri ol, 
              birlikte daha büyük hedeflere ulaşalım. İş birliğimizle kazancını arttır, 
              sektörde güçlü bir yer edin.
            </p>
            <ul class="motivation-list">
              <li>✓ Özel partner indirimleri</li>
              <li>✓ Teknik destek ve eğitim</li>
              <li>✓ Pazarlama materyalleri</li>
              <li>✓ Performans bonusları</li>
            </ul>
          </div>
          <div class="motivation-image">
            <div class="image-placeholder">
              <span style="font-size: 4rem;">🤝</span>
            </div>
          </div>
        </div>

        <div class="motivation-card reverse">
          <div class="motivation-content">
            <h2>Birlikte Büyüyor Birlikte Kutluyoruz</h2>
            <p>
              Stok Pratik partner ağıyla her geçen gün büyüyerek yeni başarılara imza atıyoruz. 
              Bayilerimizin desteğiyle elde ettiğimiz bu başarıları, hep birlikte kutlamaktan gurur duyuyoruz.
            </p>
            <ul class="motivation-list">
              <li>✓ Yıllık partner buluşmaları</li>
              <li>✓ Başarı ödülleri</li>
              <li>✓ Network etkinlikleri</li>
              <li>✓ Özel tanıtım fırsatları</li>
            </ul>
          </div>
          <div class="motivation-image">
            <div class="image-placeholder">
              <span style="font-size: 4rem;">🎉</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Nasıl Çalışır -->
  <section class="how-it-works py-16">
    <div class="container">
      <div class="section-header text-center">
        <h2>Partnerlik Süreci Nasıl İşliyor?</h2>
        <p>3 adımda Stok Pratik partneri olun</p>
      </div>

      <div class="steps-grid">
        <div class="step">
          <div class="step-number">1</div>
          <h3>Başvuru Yap</h3>
          <p>Partnerlik başvuru formunu doldurarak başvurunuzu yapın.</p>
        </div>

        <div class="step">
          <div class="step-number">2</div>
          <h3>Değerlendirme</h3>
          <p>Başvurunuz ekibimiz tarafından değerlendirilir.</p>
        </div>

                <div class="step">
          <div class="step-number">3</div>
          <h3>Satışa Başla</h3>
          <p>Partner paneliniz aktif edilir ve satışlara başlayabilirsiniz.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Başvuru Formu -->
  <section class="application py-16" id="basvur">
    <div class="container">
      <div class="application-card">
        <div class="application-content">
          <h2>Partner Olmak İçin Hemen Başvurun</h2>
          <p>
            Stok Pratik ailesine katılmak ve yüksek komisyon oranlarından yararlanmak için 
            WhatsApp üzerinden bizimle iletişime geçin.
          </p>
          
          <div class="application-buttons">
            <a 
              href="https://wa.me/+905325000999?text=Merhaba,%20Stok%20Pratik%20partnerlik%20programı%20hakkında%20bilgi%20almak%20istiyorum" 
              class="btn btn-primary btn-lg btn-whatsapp"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span style="margin-right: 8px;">💬</span> WhatsApp'tan Başvur
            </a>
            
            <a 
              href="tel:+905325000999" 
              class="btn btn-secondary btn-lg"
            >
              <span style="margin-right: 8px;">📞</span> Telefonla Ara
            </a>
          </div>
          
          <div class="application-info">
            <p><strong>Partnerlik Koşulları:</strong></p>
            <ul>
              <li>Az da olsa sektör deneyimi</li>
              <li>Düzenli müşteri portföyü</li>
              <li>Teknik bilgi ve satış becerisi</li>
              <li>Finans, muhasebe ve bilişim sektörlerine uygunluk..</li>
              <li>Franchise bedeli istenmemektedir.</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
    /* Hero Section */
    .hero {
      background: linear-gradient(135deg, var(--primary-red), var(--primary-red-dark));
      color: white;
    }

    .hero h1 {
      color: white;
      margin-bottom: var(--spacing-sm);
      font-size: 3rem;
    }

    .hero-subtitle {
      font-size: 1.75rem;
      color: rgba(255, 255, 255, 0.9);
      margin-bottom: var(--spacing-md);
      font-weight: 600;
    }

    .hero-description {
      font-size: 1.25rem;
      color: rgba(255, 255, 255, 0.8);
      max-width: 800px;
      margin: 0 auto var(--spacing-lg);
      line-height: 1.6;
    }

    .btn-lg {
      padding: 1rem 2rem;
      font-size: 1.1rem;
      font-weight: 600;
    }

    /* Advantages Section */
    .advantages {
      background-color: var(--bg-white);
    }

    .section-header h2 {
      color: var(--primary-red);
      margin-bottom: var(--spacing-sm);
    }

    .section-header p {
      color: var(--text-gray);
      font-size: 1.125rem;
      margin-bottom: var(--spacing-xl);
    }

    .advantages-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--spacing-lg);
    }

    .advantage-card {
      background: var(--bg-white);
      padding: var(--spacing-xl);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-md);
      text-align: center;
      border: 2px solid var(--primary-red-light);
      transition: transform var(--transition-normal);
    }

    .advantage-card:hover {
      transform: translateY(-10px);
      box-shadow: var(--shadow-lg);
    }

    .advantage-icon {
      font-size: 3rem;
      margin-bottom: var(--spacing-md);
    }

    .advantage-card h3 {
      color: var(--primary-red);
      margin-bottom: var(--spacing-md);
    }

    .advantage-card p {
      color: var(--text-gray);
      line-height: 1.6;
    }

    /* Motivation Sections */
    .motivation {
      background-color: var(--bg-light);
    }

    .motivation-grid {
      display: flex;
      flex-direction: column;
      gap: var(--spacing-xl);
    }

    .motivation-card {
      background: var(--bg-white);
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-md);
      display: grid;
      grid-template-columns: 1fr 1fr;
      align-items: center;
    }

    .motivation-card.reverse {
      direction: rtl;
    }

    .motivation-card.reverse .motivation-content {
      direction: ltr;
      text-align: left;
    }

    .motivation-card.reverse .motivation-list {
      direction: ltr;
    }

    .motivation-content {
      padding: var(--spacing-xl);
    }

    .motivation-content h2 {
      color: var(--primary-red);
      margin-bottom: var(--spacing-md);
    }

    .motivation-content p {
      color: var(--text-dark);
      line-height: 1.6;
      margin-bottom: var(--spacing-lg);
    }

    .motivation-list {
      list-style: none;
    }

    .motivation-list li {
      padding: var(--spacing-xs) 0;
      color: var(--text-dark);
    }

    .motivation-list li::before {
      content: "✓";
      color: var(--primary-red);
      font-weight: bold;
      margin-right: 10px;
    }

    .motivation-image {
      padding: var(--spacing-xl);
      background: linear-gradient(135deg, var(--primary-red-light), var(--primary-red));
      display: flex;
      align-items: center;
      justify-content: center;
      height: 100%;
    }

    .image-placeholder {
      text-align: center;
      color: white;
    }

    /* How It Works */
    .how-it-works {
      background-color: var(--bg-white);
    }

    .steps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: var(--spacing-lg);
      max-width: 1000px;
      margin: 0 auto;
    }

    .step {
      text-align: center;
      padding: var(--spacing-lg);
      position: relative;
    }

    .step-number {
      width: 60px;
      height: 60px;
      background: linear-gradient(135deg, var(--primary-red), var(--primary-red-dark));
      color: white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 1.5rem;
      font-weight: bold;
      margin: 0 auto var(--spacing-md);
    }

    .step h3 {
      color: var(--primary-red);
      margin-bottom: var(--spacing-sm);
    }

    .step p {
      color: var(--text-gray);
      line-height: 1.6;
    }

    /* Application Section */
    .application {
      background: linear-gradient(135deg, var(--primary-red-light), var(--bg-light));
    }

    .application-card {
      background: var(--bg-white);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-lg);
      padding: var(--spacing-xl);
      max-width: 800px;
      margin: 0 auto;
    }

    .application-content h2 {
      color: var(--primary-red);
      margin-bottom: var(--spacing-md);
      text-align: center;
    }

    .application-content p {
      color: var(--text-dark);
      text-align: center;
      margin-bottom: var(--spacing-xl);
      line-height: 1.6;
    }

    .application-buttons {
      display: flex;
      gap: var(--spacing-md);
      justify-content: center;
      margin-bottom: var(--spacing-xl);
    }

    .btn-whatsapp {
      background: linear-gradient(135deg, #25D366, #128C7E);
      border-color: #25D366;
      color: white;
    }

    .btn-whatsapp:hover {
      background: linear-gradient(135deg, #128C7E, #075E54);
      border-color: #128C7E;
    }

    .application-info {
      background: var(--primary-red-light);
      padding: var(--spacing-lg);
      border-radius: var(--radius-md);
    }

    .application-info p {
      text-align: left;
      margin-bottom: var(--spacing-sm);
    }

    .application-info ul {
      list-style: none;
      margin: 0;
      padding: 0;
    }

    .application-info li {
      padding: var(--spacing-xs) 0;
      padding-left: var(--spacing-lg);
      position: relative;
    }

    .application-info li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--primary-red);
      font-size: 1.2rem;
    }

    /* Responsive Design */
    @media (max-width: 992px) {
      .motivation-card {
        grid-template-columns: 1fr;
      }
      
      .motivation-card.reverse {
        direction: ltr;
      }
      
      .motivation-image {
        min-height: 200px;
      }
      
      .application-buttons {
        flex-direction: column;
      }
    }

    @media (max-width: 768px) {
      .hero h1 {
        font-size: 2.5rem;
      }
      
      .hero-subtitle {
        font-size: 1.5rem;
      }
      
      .hero-description {
        font-size: 1.1rem;
      }
      
      .advantages-grid {
        grid-template-columns: 1fr;
      }
      
      .steps-grid {
        grid-template-columns: 1fr;
      }
      
      .advantage-card,
      .motivation-content,
      .application-card {
        padding: var(--spacing-lg);
      }
    }

    @media (max-width: 480px) {
      .hero h1 {
        font-size: 2rem;
      }
      
      .hero-subtitle {
        font-size: 1.25rem;
      }
      
      .btn-lg {
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
      }
    }
  </style>
</BaseLayout>