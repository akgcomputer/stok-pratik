      "Vade takip sistemi",
      "Toplu fiyat güncelleme"
    ],
    benefits: ["%30 stok maliyeti azalması", "%50 zaman tasarrufu"]
  },
  {
    industry: "Üretim Firmaları",
    icon: "🏭",
    features: [
      "Hammadde takibi",
      "Yarı mamül kontrolü",
      "Fire oranı analizi",
      "Üretim emri entegrasyonu"
    ],
    benefits: ["%25 fire azalması", "%35 verimlilik artışı"]
  },
  {
