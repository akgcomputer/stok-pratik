---
// src/pages/neden-stok-pratik.astro
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const destekPosts = await getCollection('destek');
---

<BaseLayout title="Neden Stok Pratik? - Stok Pratik ERP">
  <!-- Hero Section -->
  <section class="hero py-16">
    <div class="container">
      <div class="hero-content text-center">
        <h1>Neden Stok Pratik?</h1>
        <p class="hero-subtitle">
          İşletmenizin stok yönetimi, satış, muhasebe ve üretim gibi tüm kritik süreçlerini tek bir bulut tabanlı platformda entegre edin.
        </p>
      </div>
    </div>
  </section>

  <!-- Ana Özellikler -->
  <section class="features py-16">
    <div class="container">
      <div class="why-content">
        <p class="intro-text">
          Stok Pratik, işletmenizin stok yönetimi, satış, muhasebe ve üretim gibi tüm kritik süreçlerini tek bir bulut tabanlı platformda entegre eder. Kurulum gerektirmeyen ve internet bağlantısı olan her cihazdan 7/24 erişilebilen bu sistem, geleneksel muhasebe yazılımlarının önüne geçerek işletmenize hız, esneklik ve finansal özgürlük kazandırır. Fiziksel mağazanızla, e-ticaret siteniz ve tüm pazaryerlerinizi aynı ekrandan yönetebilir, verimliliğinizi artırabilirsiniz.
        </p>
        
        <div class="benefits-grid">
          <div class="benefit-card">
            <div class="benefit-icon">☁️</div>
            <h3>Bulut Tabanlı</h3>
            <p>İnternet olan her yerden, her cihazdan erişim</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon">⚡</div>
            <h3>Kurulumsuz</h3>
            <p>Teknik kurulum gerektirmez, hemen başlayın</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon">🔄</div>
            <h3>Entegre Çözüm</h3>
            <p>Tüm iş süreçleriniz tek platformda</p>
          </div>
          
          <div class="benefit-card">
            <div class="benefit-icon">🛡️</div>
            <h3>Güvenli</h3>
            <p>Verileriniz şifrelenmiş bulutta saklanır</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SSS Section -->
  <section class="faq-section py-16" id="sss">
    <div class="container">
      <div class="section-header text-center">
        <h2>❓ Sıkça Sorulan Sorular (SSS)</h2>
        <p>En çok sorulan sorular ve cevapları</p>
      </div>

      <!-- SSS Kategorileri -->
      <div class="faq-categories">
        <div class="category-card">
          <div class="category-header">
            <span class="category-icon">🔧</span>
            <h3>Genel & Teknik</h3>
          </div>
          
          <div class="faq-list">
            <div class="faq-item">
              <h4 class="faq-question">Stok Pratik nedir?</h4>
              <p class="faq-answer">Stok, cari, satış, e-fatura ve muhasebe işlemlerinizi tek platformda yönetmenizi sağlayan, bulut tabanlı entegre bir iş yönetim yazılımıdır.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">Kurulum gerektiriyor mu?</h4>
              <p class="faq-answer">Hayır. Hiçbir teknik kurulum gerekmez. Sadece internete bağlanıp hemen kullanmaya başlayabilirsiniz.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">Verilerim güvende mi?</h4>
              <p class="faq-answer">Evet. Verileriniz güvenli bulut altyapısında şifrelenerek saklanır ve düzenli olarak yedeklenir.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">Hangi cihazlardan erişebilirim?</h4>
              <p class="faq-answer">İnternet olan her yerden bilgisayar, tablet ve akıllı telefon gibi tüm cihazlardan erişim sağlayabilirsiniz.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">7/24 destek sunuyor musunuz?</h4>
              <p class="faq-answer">Evet. WhatsApp, telefon ve e-posta kanallarından 7/24 teknik destek hizmetimiz mevcuttur.</p>
            </div>
          </div>
        </div>

        <div class="category-card">
          <div class="category-header">
            <span class="category-icon">💰</span>
            <h3>Fiyatlandırma & Paketler</h3>
          </div>
          
          <div class="faq-list">
            <div class="faq-item">
              <h4 class="faq-question">Ücretsiz deneyeblir miyim?</h4>
              <p class="faq-answer">Evet, E-Ticaret, E-Dönüşüm hariç tüm özelliklerini içerir. Mağazacılık, kasa, banka, çek-senet gibi gelişmiş birçok modülü test edebilirsiniz.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">Kaç farklı paketiniz var?</h4>
              <p class="faq-answer">İhtiyaca göre şekillenen, Tek Şube'den Sınırsız Şubeli paketlere kadar geniş bir yelpazede hizmet sunuyoruz.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">Birden fazla şubem var, hangi paketi seçmeliyim?</h4>
              <p class="faq-answer">5 Şubeli, 10 Şubeli, 15 Şubeli ve Sınırsız Şubeli özel Mağaza Paketlerimiz mevcuttur. Size özel bir fiyat teklifi oluşturabiliriz.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">Ödeme yöntemleriniz neler?</h4>
              <p class="faq-answer">Aylık veya yıllık abonelik şeklinde kredi kartı ile ödeme yapabilirsiniz. Kurumsal müşterilerimiz için EFT/Havale seçeneği de mevcuttur.</p>
            </div>
          </div>
        </div>

        <div class="category-card">
          <div class="category-header">
            <span class="category-icon">📦</span>
            <h3>Özellikler & Entegrasyonlar</h3>
          </div>
          
          <div class="faq-list">
            <div class="faq-item">
              <h4 class="faq-question">Hangi pazaryerleri ile entegre?</h4>
              <p class="faq-answer">Trendyol, Hepsiburada, N11, Amazon, AliExpress ve birçok yerel/global pazaryeri ile entegre çalışır. Tüm siparişleriniz tek ekrana gelir.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">Barkod okuyucu ile çalışır mı?</h4>
              <p class="faq-answer">Evet. Barkod okuyucularla tam uyumludur. Stok giriş-çıkış ve satış işlemlerinizi hızlı ve hatasız bir şekilde yapabilirsiniz.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">ERP modülü nedir? Ne işe yarar?</h4>
              <p class="faq-answer">ERP modülü, üretim, satın alma, satış, muhasebe ve insan kaynakları gibi tüm departmanlarınızı entegre ederek verimliliği maksimum seviyeye çıkarır.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">Mobil uygulamanız var mı?</h4>
              <p class="faq-answer">Evet. Yazılımın tüm özelliklerine iOS ve Android işletim sistemli mobil cihazlardan da ulaşabilirsiniz.</p>
            </div>
          </div>
        </div>

        <div class="category-card">
          <div class="category-header">
            <span class="category-icon">🚀</span>
            <h3>Kullanım & İş Akışı</h3>
          </div>
          
          <div class="faq-list">
            <div class="faq-item">
              <h4 class="faq-question">Nasıl başlayabilirim?</h4>
              <p class="faq-answer">Sitemizden ücretsiz kayıt olarak hemen kullanmaya başlayabilir veya demo talep ederek bizimle iletişime geçebilirsiniz.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">Kaç kullanıcı ekleyebilirim?</h4>
              <p class="faq-answer">Kullanıcı sayısı, seçtiğiniz pakete göre değişir. Tüm ücretli paketlerde, kullanıcı yetkilendirme sistemi ile birden fazla kullanıcı ekleyebilirsiniz.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">Stok sayımı (envanter) yapabilir miyim?</h4>
              <p class="faq-answer">Evet. Ücretli paketler, fiziksel stok sayımı yapmanızı ve sistem kayıtlarıyla karşılaştırma yapmanızı sağlayan araçlar sunar.</p>
            </div>
            
            <div class="faq-item">
              <h4 class="faq-question">Şube bazlı kar/zarar raporu alabilir miyim?</h4>
              <p class="faq-answer">Evet. Çok şubeli paketlerde, her bir şubenizin performansını ayrı ayrı veya karşılaştırmalı olarak detaylı raporlarla izleyebilirsiniz.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Destek ve Nasıl Yapılır Section -->
  <section class="destek-section py-16">
    <div class="container">
      <div class="section-header text-center">
        <h2>🛠️ Destek & Nasıl Yapılır?</h2>
        <p>Sistem kullanımıyla ilgili kılavuzlar ve rehberler</p>
      </div>
      
      <div class="destek-grid">
        {destekPosts.map(post => (
          <a href={`/destek/${post.slug}`} class="destek-card">
            <h4>{post.data.title}</h4>
            <span class="read-more">Kılavuzu İncele &rarr;</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section py-16">
    <div class="container text-center">
      <h2>Hala sorularınız mı var?</h2>
      <p>WhatsApp üzerinden bize ulaşın, size yardımcı olalım</p>
      <a 
        href="https://wa.me/+905325000999?text=Merhaba,%20Stok%20Pratik%20hakkında%20soru%20sormak%20istiyorum" 
        class="btn btn-primary btn-whatsapp"
        target="_blank"
        rel="noopener noreferrer"
      >
        WhatsApp'tan Sorunuzu Sorun
      </a>
    </div>
  </section>

  <style>
    /* Hero Section */
    .hero {
      background: linear-gradient(135deg, var(--primary-red-light) 0%, var(--bg-white) 100%);
    }

    .hero h1 {
      background: linear-gradient(135deg, var(--primary-red), var(--primary-red-dark));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      margin-bottom: var(--spacing-md);
    }

    .hero-subtitle {
      font-size: 1.25rem;
      color: var(--text-gray);
      max-width: 800px;
      margin: 0 auto;
    }

    /* Features Section */
    .features {
      background-color: var(--bg-white);
    }

    .intro-text {
      font-size: 1.125rem;
      line-height: 1.8;
      color: var(--text-dark);
      margin-bottom: var(--spacing-xl);
      text-align: center;
      max-width: 900px;
      margin-left: auto;
      margin-right: auto;
    }

    .benefits-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: var(--spacing-lg);
      margin-top: var(--spacing-xl);
    }

    .benefit-card {
      background: var(--bg-white);
      padding: var(--spacing-lg);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-md);
      text-align: center;
      transition: transform var(--transition-normal);
      border: 2px solid var(--primary-red-light);
    }

    .benefit-card:hover {
      transform: translateY(-5px);
      box-shadow: var(--shadow-lg);
    }

    .benefit-icon {
      font-size: 2.5rem;
      margin-bottom: var(--spacing-md);
    }

    .benefit-card h3 {
      color: var(--primary-red);
      margin-bottom: var(--spacing-sm);
    }

    /* FAQ Section */
    .faq-section {
      background-color: var(--bg-light);
    }

    .section-header h2 {
      color: var(--primary-red);
      margin-bottom: var(--spacing-sm);
    }

    .section-header p {
      color: var(--text-gray);
      font-size: 1.125rem;
      margin-bottom: var(--spacing-xl);
    }

    .faq-categories {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: var(--spacing-lg);
      max-width: 1200px;
      margin: 0 auto;
    }

    .category-card {
      background: var(--bg-white);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-md);
      overflow: hidden;
    }

    .category-header {
      background: linear-gradient(135deg, var(--primary-red), var(--primary-red-dark));
      color: white;
      padding: var(--spacing-lg);
      display: flex;
      align-items: center;
      gap: var(--spacing-md);
    }

    .category-icon {
      font-size: 2rem;
    }

    .category-header h3 {
      margin: 0;
      color: white;
    }

    .faq-list {
      padding: var(--spacing-lg);
    }

    .faq-item {
      margin-bottom: var(--spacing-lg);
      padding-bottom: var(--spacing-lg);
      border-bottom: 1px solid var(--secondary-light);
    }

    .faq-item:last-child {
      margin-bottom: 0;
      padding-bottom: 0;
      border-bottom: none;
    }

    .faq-question {
      color: var(--primary-red);
      font-size: 1.1rem;
      margin-bottom: var(--spacing-sm);
      cursor: pointer;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .faq-question::after {
      content: "+";
      font-size: 1.5rem;
      color: var(--primary-red);
    }

    .faq-answer {
      color: var(--text-dark);
      line-height: 1.6;
      margin: 0;
      animation: fadeIn 0.3s ease-in;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-10px); }
      to { opacity: 1; transform: translateY(0); }
    }

    /* Destek Section */
    .destek-section {
      background-color: var(--bg-white);
    }

    .destek-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: var(--spacing-lg);
      max-width: 1200px;
      margin: 0 auto;
    }

    .destek-card {
      background: var(--bg-light);
      padding: var(--spacing-lg);
      border-radius: var(--radius-md);
      text-decoration: none;
      color: var(--text-dark);
      border: 1px solid var(--secondary-light);
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
    }

    .destek-card:hover {
      border-color: var(--primary-red);
      transform: translateY(-3px);
      box-shadow: var(--shadow-sm);
    }

    .destek-card h4 {
      margin-bottom: var(--spacing-sm);
      color: var(--text-dark);
      font-size: 1.1rem;
    }

    .read-more {
      color: var(--primary-red);
      font-weight: 600;
      font-size: 0.9rem;
      margin-top: var(--spacing-sm);
    }

    /* CTA Section */
    .cta-section {
      background: linear-gradient(135deg, var(--primary-red-light), var(--primary-red));
      color: white;
    }

    .cta-section h2 {
      color: white;
      margin-bottom: var(--spacing-md);
    }

    .cta-section p {
      color: rgba(255, 255, 255, 0.9);
      font-size: 1.125rem;
      margin-bottom: var(--spacing-lg);
    }

    .btn-whatsapp {
      background: linear-gradient(135deg, #25D366, #128C7E);
      border-color: #25D366;
      color: white;
      padding: 0.75rem 2rem;
      font-size: 1.1rem;
    }

    .btn-whatsapp:hover {
      background: linear-gradient(135deg, #128C7E, #075E54);
      border-color: #128C7E;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
      .faq-categories {
        grid-template-columns: 1fr;
      }
      
      .destek-grid {
        grid-template-columns: repeat(2, 1fr);
      }
      
      .benefits-grid {
        grid-template-columns: 1fr;
      }
      
      .category-header {
        padding: var(--spacing-md);
      }
      
      .faq-list {
        padding: var(--spacing-md);
      }
      
      .intro-text {
        font-size: 1rem;
        padding: 0 var(--spacing-md);
      }
    }

    @media (max-width: 480px) {
      .benefit-card {
        padding: var(--spacing-md);
      }
      
      .destek-grid {
        grid-template-columns: 1fr;
      }
      
      .faq-question {
        font-size: 1rem;
      }
      
      .cta-section h2 {
        font-size: 1.5rem;
      }
    }
  </style>

  <script>
    // Tıklanınca cevabı göster/gizle
    document.addEventListener('DOMContentLoaded', function() {
      const faqQuestions = document.querySelectorAll('.faq-question');
      
      faqQuestions.forEach(question => {
        question.addEventListener('click', function() {
          const answer = this.nextElementSibling;
          const isVisible = answer.style.display === 'block';
          
          // Tüm cevapları gizle
          document.querySelectorAll('.faq-answer').forEach(ans => {
            ans.style.display = 'none';
          });
          
          // Tüm soruların işaretini sıfırla
          document.querySelectorAll('.faq-question').forEach(q => {
            q.textContent = q.textContent.replace('−', '+');
          });
          
          // Eğer bu cevap gizliyse göster
          if (!isVisible) {
            answer.style.display = 'block';
            this.textContent = this.textContent.replace('+', '−');
          }
        });
        
        // İlk başta tüm cevapları gizle
        question.nextElementSibling.style.display = 'none';
      });
    });
  </script>
</BaseLayout>