// Paket detayları
const packageDetails = {
  free: {
    title: "Ücretsiz Paket Detayları",
    description: "Temel işletme ihtiyaçlarınız için başlangıç paketi",
    modules: [
      "📦 Stok Yönetimi – Detaylı stok takibi ve envanter kontrolü",
      "🔍 Cari Yönetimi – Müşteri ve tedarikçi hesaplarının yönetimi"
    ]
  },
  magaza: {
    title: "Mağazacılık Paketi Detayları",
    description: "Tam entegre mağaza yönetim çözümü",
    modules: [
      "📦 Stok Yönetimi – Detaylı stok takibi ve envanter kontrolü",
      "🔍 Cari Yönetimi – Müşteri ve tedarikçi hesaplarının yönetimi",
      "🧾 e-Fatura – Tam entegre elektronik fatura çözümü",
      "📑 e-İrsaliye – Elektronik irsaliye yönetimi",
      "💼 Kasa – Nakit ve banka hesaplarının detaylı takibi",
      "🏦 Banka – Banka hesap yönetimi ve takibi",
