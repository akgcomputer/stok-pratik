---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

export async function getStaticPaths() {
  const destekEntries = await getCollection('destek');
  return destekEntries.map(entry => ({
    params: { slug: entry.slug }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Process YouTube link to embed format
let videoEmbedUrl = entry.data.videoLink;
if (videoEmbedUrl) {
  const ytMatch = videoEmbedUrl.match(/^(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/watch\?v=|youtu\.be\/)([^&?\s]+)/);
  if (ytMatch) {
    videoEmbedUrl = `https://www.youtube.com/embed/${ytMatch[1]}`;
  }
}
---

<BaseLayout title={`${entry.data.title} | Stok Pratik Destek`}>
  <article class="destek-post">
    <header class="post-header">
      <span class="category">{entry.data.category}</span>
      <h1>{entry.data.title}</h1>
    </header>
    
    {videoEmbedUrl && (
      <div class="video-container">
        <iframe 
          src={videoEmbedUrl} 
          title="Video Player" 
          frameborder="0" 
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
          allowfullscreen>
        </iframe>
      </div>
    )}

    <div class="post-content">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .destek-post {
    max-width: 800px;
    margin: 0 auto;
    padding: 100px 20px 60px;
  }
  .post-header {
    margin-bottom: 30px;
    text-align: center;
  }
  .category {
    background: var(--accent-color, #0056b3);
    color: white;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
    display: inline-block;
    margin-bottom: 15px;
  }
  .post-header h1 {
    font-size: 2.5rem;
    color: var(--primary-color, #1a1a1a);
  }
  .video-container {
    position: relative;
    padding-bottom: 56.25%; /* 16:9 aspect ratio */
    height: 0;
    overflow: hidden;
    margin-bottom: 40px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  .video-container iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
  }
  .post-content {
    font-size: 1.1rem;
    line-height: 1.8;
    color: #333;
    background: #fff;
    padding: 40px;
    border-radius: 12px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }
  .post-content h2 {
    margin-top: 30px;
    margin-bottom: 20px;
    font-size: 1.8rem;
    color: var(--primary-color, #1a1a1a);
    border-bottom: 1px solid #eee;
    padding-bottom: 10px;
  }
  .post-content p {
    margin-bottom: 20px;
  }
  .post-content ol {
    margin-bottom: 20px;
    padding-left: 20px;
  }
  .post-content li {
    margin-bottom: 10px;
  }
</style>
