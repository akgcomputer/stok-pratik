    icon: "🏪",
    features: [
      "Barkodlu satış",
      "Kasa entegrasyonu",
      "Kampanya yönetimi",
      "Müşteri takibi"
    ],
    benefits: ["%40 hızlı satış", "%60 stok sayım tasarrufu"]
  },
  {
